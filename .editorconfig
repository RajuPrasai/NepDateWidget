root = true

# Default for every text file in the repo.
[*]
charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown preserves trailing whitespace because two spaces means line break.
[*.md]
trim_trailing_whitespace = false

# YAML and JSON conventionally use 2-space indent.
[*.{yml,yaml,json}]
indent_size = 2

# Project, package, and config files use 2-space indent.
[*.{csproj,props,targets,xml,xaml,pubxml,manifest,slnx}]
indent_size = 2

# Shell scripts.
[*.{ps1,psm1,psd1}]
end_of_line = crlf

[*.sh]
end_of_line = lf

# ── C# code style ─────────────────────────────────────────────────────────────
[*.cs]
indent_size = 4

# Prefer file-scoped namespaces (matches the codebase).
csharp_style_namespace_declarations = file_scoped:warning

# `var` only when the type is apparent from the right-hand side.
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_elsewhere = false:suggestion

# Expression-bodied members for trivial accessors and lambdas only.
csharp_style_expression_bodied_methods = when_on_single_line:silent
csharp_style_expression_bodied_constructors = false:silent
csharp_style_expression_bodied_operators = when_on_single_line:silent
csharp_style_expression_bodied_properties = true:silent
csharp_style_expression_bodied_indexers = true:silent
csharp_style_expression_bodied_accessors = true:silent

# Prefer pattern matching over null/type checks.
csharp_style_pattern_matching_over_is_with_cast_check = true:suggestion
csharp_style_pattern_matching_over_as_with_null_check = true:suggestion

# Always use braces, even for single-line blocks. Prevents goto-fail bugs.
csharp_prefer_braces = true:warning

# Modifier order matches what the existing codebase already uses.
csharp_preferred_modifier_order = public,private,protected,internal,static,extern,new,virtual,abstract,sealed,override,readonly,unsafe,volatile,async:warning

# Underscore prefix for private fields (matches the codebase).
dotnet_naming_rule.private_fields_with_underscore.severity = suggestion
dotnet_naming_rule.private_fields_with_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_with_underscore.style = underscore_prefix

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_style.underscore_prefix.required_prefix = _
dotnet_naming_style.underscore_prefix.capitalization = camel_case

# Treat unused usings as a warning so CI catches dead imports.
dotnet_diagnostic.IDE0005.severity = warning
