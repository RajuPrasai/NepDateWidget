<Application x:Class="NepDateWidget.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cvt="clr-namespace:NepDateWidget.Converters"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Themes/DefaultTheme.xaml" />
                <ResourceDictionary Source="Resources/Styles/Icons.xaml" />
                <ResourceDictionary Source="Resources/Styles/TextBoxStyles.xaml" />
                <ResourceDictionary Source="Resources/Styles/ShellResources.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <cvt:BoolToVisibilityConverter x:Key="BoolToVis"        Invert="False" />
            <cvt:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"  />
        </ResourceDictionary>
    </Application.Resources>
</Application>
