<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>..\..\publish\win-arm64-store\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0-windows10.0.17763.0</TargetFramework>
    <RuntimeIdentifier>win-arm64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <!-- MSIX requires individual files on disk - single-file bundling is
         incompatible with the block-map structure MakeAppx builds. -->
    <PublishSingleFile>false</PublishSingleFile>
    <!-- ReadyToRun cross-compilation from a Windows x64 host to arm64 is
         supported by the .NET SDK for .NET 6 and later. -->
    <PublishReadyToRun>true</PublishReadyToRun>
    <!-- Trimming is unsafe for WPF apps that rely on reflection (resources,
         converters, data templates, dependency properties). Keep disabled. -->
    <PublishTrimmed>false</PublishTrimmed>
    <!-- Do not write XML doc files - they are unused in production. -->
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!-- Native WPF DLLs travel as loose files - do not bundle them. -->
    <IncludeNativeLibrariesForSelfExtract>false</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>
</Project>
