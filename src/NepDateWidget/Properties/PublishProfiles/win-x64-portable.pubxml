<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>..\..\publish\win-x64-portable\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0-windows</TargetFramework>
    <SelfContained>true</SelfContained>
    <!-- Bundle everything into a single EXE -->
    <!-- Include native WPF DLLs inside the single-file bundle so they don't
         appear as loose files in the publish folder. They are extracted to a
         per-version temp cache on first launch (transparent to the user). -->
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <!-- Enable compression to reduce the single-file EXE size. -->
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>
    <!-- ReadyToRun for faster cold-start. -->
    <!-- Trim unused code to further reduce output size. -->
    <!-- Do not include XML documentation files in the publish output. -->
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishSingleFile>true</PublishSingleFile>
    <PublishReadyToRun>true</PublishReadyToRun>
  </PropertyGroup>
</Project>