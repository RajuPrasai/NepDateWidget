<?xml version="1.0" encoding="utf-8"?>
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <PublishDir>..\..\publish\win-x64-store\</PublishDir>
    <PublishProtocol>FileSystem</PublishProtocol>
    <TargetFramework>net10.0-windows10.0.17763.0</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <SelfContained>true</SelfContained>
    <!-- MSIX requires individual files on disk — single-file bundling is
         incompatible with the block-map structure MakeAppx builds. -->
    <PublishSingleFile>false</PublishSingleFile>
    <!-- ReadyToRun pre-compiles IL to native on publish, improving cold-start.
         Safe to enable even though it increases package size. -->
    <PublishReadyToRun>true</PublishReadyToRun>
    <!-- Trimming is unsafe for WPF apps that rely on reflection (resources,
         converters, data templates, dependency properties). Keep disabled. -->
    <PublishTrimmed>false</PublishTrimmed>
    <!-- Do not write XML doc files — they are unused in production. -->
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <!-- Native WPF DLLs travel as loose files — do not bundle them. -->
    <IncludeNativeLibrariesForSelfExtract>false</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>
</Project>
