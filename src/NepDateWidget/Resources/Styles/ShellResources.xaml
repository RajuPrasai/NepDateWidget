<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:NepDateWidget.Helpers">

  <!--
        Shared resources used by both the collapsed mini-pill (MainWindow) and the
        expanded shell (ExpandedShellWindow). Anything that needs to look identical
        between the two windows lives here so a single edit updates both surfaces.
    -->

  <CubicEase x:Key="SmoothEase" EasingMode="EaseInOut" />

  <!-- Title-bar caption icons -->
  <StreamGeometry x:Key="IconChevronDown">M6 9l6 6l6 -6</StreamGeometry>
  <StreamGeometry x:Key="IconWindowClose">M18 6l-12 12 M6 6l12 12</StreamGeometry>
  <StreamGeometry x:Key="IconWindowMinimize">M5 12l14 0</StreamGeometry>
  <StreamGeometry x:Key="IconChevronLeft">M15 6l-6 6l6 6</StreamGeometry>

  <!-- ══════════════════════════════════════════════════════════════════
         Context Menu - chrome and items.
         ════════════════════════════════════════════════════════════════ -->

  <Style x:Key="WidgetContextMenuStyle" TargetType="ContextMenu">
    <Setter Property="Background"      Value="{DynamicResource WidgetBackgroundBrush}" />
    <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="BorderBrush"     Value="{DynamicResource WidgetBorderBrush}" />
    <Setter Property="BorderThickness" Value="0.7" />
    <Setter Property="HasDropShadow"   Value="True" />
    <Setter Property="SnapsToDevicePixels" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContextMenu">
          <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="0,4"
                            Margin="4"
                            SnapsToDevicePixels="True"
                            TextOptions.TextFormattingMode="Display"
                            TextOptions.TextRenderingMode="ClearType"
                            TextOptions.TextHintingMode="Fixed"
                            RenderOptions.ClearTypeHint="Enabled">
            <ItemsPresenter SnapsToDevicePixels="True" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="WidgetMenuItemStyle" TargetType="MenuItem">
    <Setter Property="Background"             Value="Transparent" />
    <Setter Property="Foreground"             Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="OverridesDefaultStyle"  Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="MenuItem">
          <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Margin="4,1"
                            Padding="10,7">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="IconCol" Width="24" />
                <ColumnDefinition Width="*"  />
                <ColumnDefinition Width="14" />
              </Grid.ColumnDefinitions>
              <Grid Grid.Column="0"
                                  Width="16" Height="16"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Left">
                <ContentPresenter x:Name="IconHost"
                                                  ContentSource="Icon"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center" />
              </Grid>
              <ContentPresenter Grid.Column="1"
                                              ContentSource="Header"
                                              VerticalAlignment="Center" />
              <TextBlock x:Name="Arrow"
                                       Grid.Column="2"
                                       Text="›"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource WidgetMutedForegroundBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Visibility="Collapsed" />
              <Popup x:Name="PART_Popup"
                                   Grid.Column="1"
                                   Placement="Right"
                                   HorizontalOffset="-8"
                                   IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="None">
                <Border Background="{DynamicResource WidgetBackgroundBrush}"
                                        BorderBrush="{DynamicResource WidgetBorderBrush}"
                                        BorderThickness="0.7"
                                        CornerRadius="6"
                                        Padding="0,4"
                                        Margin="0,4,4,4"
                                        SnapsToDevicePixels="True"
                                        TextOptions.TextFormattingMode="Display"
                                        TextOptions.TextRenderingMode="ClearType"
                                        TextOptions.TextHintingMode="Fixed"
                                        RenderOptions.ClearTypeHint="Enabled">
                  <ItemsPresenter SnapsToDevicePixels="True" />
                </Border>
              </Popup>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="Icon" Value="{x:Null}">
              <Setter TargetName="IconHost" Property="Visibility" Value="Collapsed" />
              <Setter TargetName="IconCol" Property="Width" Value="0" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource WidgetAccentBrushLight}" />
            </Trigger>
            <Trigger Property="Role" Value="SubmenuHeader">
              <Setter TargetName="Arrow" Property="Visibility" Value="Visible" />
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="Role" Value="SubmenuHeader" />
              </MultiTrigger.Conditions>
              <Setter Property="IsSubmenuOpen" Value="True" />
            </MultiTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="WidgetSeparatorStyle" TargetType="Separator">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Separator">
          <Border Background="{DynamicResource WidgetDividerBrush}"
                            Height="1" Margin="8,4"
                            SnapsToDevicePixels="True" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="WidgetSectionSeparatorStyle" TargetType="Separator">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Separator">
          <Border Background="{DynamicResource WidgetDividerBrush}"
                            Height="1" Margin="0,2"
                            SnapsToDevicePixels="True" />
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══════════════════════════════════════════════════════════════════
         Tab Control - themed tabs for the expanded shell.
         ════════════════════════════════════════════════════════════════ -->

  <Style x:Key="CachedTabControlStyle" TargetType="h:CachedTabControl">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="h:CachedTabControl">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0"
                                BorderBrush="{DynamicResource WidgetDividerBrush}"
                                BorderThickness="0,0,0,0.7"
                                Margin="0,4,0,2"
                                Background="Transparent">
              <UniformGrid IsItemsHost="True" Rows="1" />
            </Border>
            <Grid x:Name="PART_ContentPanel"
                              Grid.Row="1"
                              Margin="0,2,0,0" />
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="WidgetTabItemStyle" TargetType="TabItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="TabUnderline"
                            BorderThickness="0,0,0,1.5"
                            BorderBrush="Transparent"
                            Cursor="Hand"
                            HorizontalAlignment="Stretch"
                            SnapsToDevicePixels="True">
            <Border x:Name="TabBg"
                                Background="Transparent"
                                CornerRadius="4"
                                Padding="6,5"
                                Margin="0,1"
                                ClipToBounds="True">
              <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
            </Border>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="TabUnderline" Property="BorderBrush"
                                    Value="{DynamicResource WidgetAccentBrush}" />
              <Setter Property="Foreground"
                                    Value="{DynamicResource WidgetAccentBrush}" />
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsMouseOver" Value="True" />
                <Condition Property="IsSelected" Value="False" />
              </MultiTrigger.Conditions>
              <Setter TargetName="TabBg" Property="Background"
                                    Value="{DynamicResource WidgetAccentBrushLight}" />
            </MultiTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══════════════════════════════════════════════════════════════════
         Hover gate - applied directly to each badge wrapper Grid (direct child
         of the column wrapper Grid). Handles both conditions in one place:
           1. ShowHelpBadges: default Setter uses DynamicResource HelpBadgeVisibility.
              DynamicResource in a Style Setter is reactive - updates when the resource changes.
           2. Hover: DataTrigger collapses the Grid when the column wrapper (AncestorLevel=1)
              is not hovered. Trigger overrides the Setter while active.
         Collapsed rather than Opacity=0 so invisible badges never intercept clicks.
         ════════════════════════════════════════════════════════════════ -->
  <Style x:Key="HoverGateStyle" TargetType="Grid">
    <Setter Property="Visibility" Value="{DynamicResource HelpBadgeVisibility}" />
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Grid, AncestorLevel=1}}" Value="False">
        <Setter Property="Visibility" Value="Collapsed" />
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <!-- ══════════════════════════════════════════════════════════════════
         Info badge - 20×20 circle overlaid on active mode-selector pills.
         Shows the cursive "i" glyph; visible only when ShowHelpBadges=True.
         ════════════════════════════════════════════════════════════════ -->

  <!-- Field label: caption above inputs and control groups -->
  <Style x:Key="FieldLabel" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Opacity" Value="0.8" />
    <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
  </Style>

  <!-- iOS-style toggle CheckBox - use everywhere instead of the default WPF CheckBox -->
  <Style x:Key="WidgetCheckBox" TargetType="CheckBox">
    <Setter Property="OverridesDefaultStyle" Value="True" />
    <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="Cursor"     Value="Hand" />
    <Setter Property="Margin"     Value="0,2" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="CheckBox">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Border x:Name="Track"
                                Width="34" Height="18"
                                CornerRadius="9"
                                Background="{DynamicResource WidgetInputBrush}"
                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                BorderThickness="0.7">
              <Border x:Name="Thumb"
                                    Width="14" Height="14"
                                    CornerRadius="7"
                                    Background="{DynamicResource WidgetInputBorderBrush}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Margin="1,0,0,0" />
            </Border>
            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
          </StackPanel>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Track" Property="Background"         Value="{DynamicResource WidgetAccentBrush}" />
              <Setter TargetName="Track" Property="BorderBrush"        Value="{DynamicResource WidgetAccentBrush}" />
              <Setter TargetName="Thumb" Property="Background"         Value="White" />
              <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
              <Setter TargetName="Thumb" Property="Margin"             Value="0,0,1,0" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Thin themed progress bar for job progress indicators -->
  <Style x:Key="WidgetProgressBar" TargetType="ProgressBar">
    <Setter Property="Height"          Value="5" />
    <Setter Property="Minimum"         Value="0" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background"      Value="{DynamicResource WidgetInputBorderBrush}" />
    <Setter Property="Foreground"      Value="{DynamicResource WidgetAccentBrush}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ProgressBar">
          <Grid SnapsToDevicePixels="True">
            <Border Background="{TemplateBinding Background}" CornerRadius="3" />
            <Grid x:Name="PART_Track" ClipToBounds="True">
              <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left" />
            </Grid>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="InfoPillBadgeStyle" TargetType="Button">
    <Setter Property="Width"           Value="20" />
    <Setter Property="Height"          Value="20" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor"          Value="Hand" />
    <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
    <Setter Property="ToolTip"         Value="Help" />
    <Setter Property="Template">
      <Setter.Value>
        <!--
          WARNING: The ScaleTransform below MUST be named 'BadgeScale' and must NOT be replaced with a TransformGroup or other type.
          All Storyboard animations below target this transform directly for runtime safety.
          If you change the template structure, update all TargetName references accordingly.
        -->
        <ControlTemplate TargetType="Button">
          <Grid x:Name="Root" Width="20" Height="20" Opacity="0.8"
                RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
              <ScaleTransform x:Name="BadgeScale" ScaleX="1" ScaleY="1" />
            </Grid.RenderTransform>
            <Border CornerRadius="6"
                    BorderBrush="{TemplateBinding Foreground}"
                    BorderThickness="1"
                    Background="Transparent" />
            <Viewbox Stretch="Uniform" Width="14" Height="14"
                     HorizontalAlignment="Center" VerticalAlignment="Center">
              <Canvas Width="24" Height="24">
                    <Path Data="M8 8a3.5 3 0 0 1 3.5 -3h1a3.5 3 0 0 1 3.5 3a3 3 0 0 1 -2 3a3 4 0 0 0 -2 4"
                      Fill="Transparent"
                      Stroke="{TemplateBinding Foreground}"
                      StrokeThickness="2"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round" />
                    <Path Data="M12 19l0 .01"
                      Fill="Transparent"
                      Stroke="{TemplateBinding Foreground}"
                      StrokeThickness="2"
                      StrokeLineJoin="Round"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round" />
              </Canvas>
            </Viewbox>
            <!-- Fallback visual if SVG fails: simple ellipse -->
            <Ellipse x:Name="FallbackEllipse" Width="10" Height="10" Fill="Gray" Visibility="Collapsed" />
          </Grid>
          <ControlTemplate.Triggers>
            <!-- Animate Opacity and Scale on hover/click, targeting BadgeScale directly for safety -->
            <EventTrigger RoutedEvent="Mouse.MouseEnter">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation Storyboard.TargetName="Root"
                                   Storyboard.TargetProperty="Opacity"
                                   To="1" Duration="0:0:0.1" />
                  <DoubleAnimation Storyboard.TargetName="BadgeScale"
                                   Storyboard.TargetProperty="ScaleX"
                                   To="1.15" Duration="0:0:0.1" />
                  <DoubleAnimation Storyboard.TargetName="BadgeScale"
                                   Storyboard.TargetProperty="ScaleY"
                                   To="1.15" Duration="0:0:0.1" />
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="Mouse.MouseLeave">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation Storyboard.TargetName="Root"
                                   Storyboard.TargetProperty="Opacity"
                                   To="0.8" Duration="0:0:0.12" />
                  <DoubleAnimation Storyboard.TargetName="BadgeScale"
                                   Storyboard.TargetProperty="ScaleX"
                                   To="1" Duration="0:0:0.12" />
                  <DoubleAnimation Storyboard.TargetName="BadgeScale"
                                   Storyboard.TargetProperty="ScaleY"
                                   To="1" Duration="0:0:0.12" />
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="UIElement.PreviewMouseLeftButtonDown">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation Storyboard.TargetName="BadgeScale"
                                   Storyboard.TargetProperty="ScaleX"
                                   To="0.88" Duration="0:0:0.07" />
                  <DoubleAnimation Storyboard.TargetName="BadgeScale"
                                   Storyboard.TargetProperty="ScaleY"
                                   To="0.88" Duration="0:0:0.07" />
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="UIElement.PreviewMouseLeftButtonUp">
              <BeginStoryboard>
                <Storyboard>
                  <DoubleAnimation Storyboard.TargetName="BadgeScale"
                                   Storyboard.TargetProperty="ScaleX"
                                   To="1.15" Duration="0:0:0.08" />
                  <DoubleAnimation Storyboard.TargetName="BadgeScale"
                                   Storyboard.TargetProperty="ScaleY"
                                   To="1.15" Duration="0:0:0.08" />
                </Storyboard>
              </BeginStoryboard>
            </EventTrigger>
            <!-- Defensive: If SVG fails, show fallback ellipse -->
            <DataTrigger Binding="{Binding ActualWidth, RelativeSource={RelativeSource Self}}" Value="0">
              <Setter TargetName="FallbackEllipse" Property="Visibility" Value="Visible" />
            </DataTrigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ══════════════════════════════════════════════════════════════════
         Accent (primary action) button - used by tool views.
         AboutView and ConverterView define their own local variants.
         ════════════════════════════════════════════════════════════════ -->
  <Style x:Key="AccentButton" TargetType="Button">
    <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
    <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
    <Setter Property="BorderThickness" Value="0.7" />
    <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
    <Setter Property="FontSize"        Value="12" />
    <Setter Property="FontWeight"      Value="SemiBold" />
    <Setter Property="Height"          Value="36" />
    <Setter Property="Padding"         Value="8,0" />
    <Setter Property="Cursor"          Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid x:Name="Root">
            <Border x:Name="BgLayer"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" />
            <Border Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.4" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Opacity" Value="0.8" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="AccentButtonSm" TargetType="Button" BasedOn="{StaticResource AccentButton}">
    <Setter Property="Height"  Value="32" />
    <Setter Property="Padding" Value="12,0" />
  </Style>

  <!-- Secondary (cancel / copy) button -->
  <Style x:Key="SecondaryButton" TargetType="Button">
    <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrushLight}" />
    <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
    <Setter Property="BorderThickness" Value="0.7" />
    <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="FontSize"        Value="11" />
    <Setter Property="Height"          Value="36" />
    <Setter Property="Padding"         Value="10,0" />
    <Setter Property="Cursor"          Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Opacity" Value="0.8" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── PillButton: transparent mode-selector / tab pill ─────────── -->
  <Style x:Key="PillButton" TargetType="Button">
    <Setter Property="Background"      Value="Transparent" />
    <Setter Property="BorderBrush"     Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="FontSize"        Value="12" />
    <Setter Property="Height"          Value="28" />
    <Setter Property="Padding"         Value="14,0" />
    <Setter Property="Cursor"          Value="Hand" />
    <Setter Property="Opacity"         Value="0.55" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="5"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="PillButtonSm" TargetType="Button" BasedOn="{StaticResource PillButton}">
    <Setter Property="Padding" Value="10,0" />
  </Style>

  <!-- ── DirButton: bordered browse/action button ────────────────── -->
  <Style x:Key="DirButton" TargetType="Button">
    <Setter Property="Background"      Value="Transparent" />
    <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
    <Setter Property="BorderThickness" Value="0.7" />
    <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="FontSize"        Value="12" />
    <Setter Property="FontWeight"      Value="SemiBold" />
    <Setter Property="Height"          Value="36" />
    <Setter Property="Padding"         Value="8,0" />
    <Setter Property="Cursor"          Value="Hand" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="DirButtonSm" TargetType="Button" BasedOn="{StaticResource DirButton}">
    <Setter Property="Height" Value="32" />
  </Style>

  <!-- ── SectionLabel: 14pt semibold heading for card sections ─────── -->
  <Style x:Key="SectionLabel" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="14" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="Margin"     Value="0,0,0,8" />
  </Style>

  <!-- ── CardPanel: standard section card border ───────────────────── -->
  <Style x:Key="CardPanel" TargetType="Border">
    <Setter Property="Background"      Value="{DynamicResource WidgetBackgroundBrush}" />
    <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
    <Setter Property="BorderThickness" Value="0.7" />
    <Setter Property="CornerRadius"    Value="8" />
    <Setter Property="Padding"         Value="12,12" />
    <Setter Property="Margin"          Value="0,0,0,8" />
  </Style>

  <!-- ── LevelLabelStyle: small muted quality-level label ──────────── -->
  <Style x:Key="LevelLabelStyle" TargetType="TextBlock">
    <Setter Property="FontSize"   Value="10.5" />
    <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="Opacity"    Value="0.8" />
  </Style>

  <!-- ── PopupCloseBtn: 26×26 close button used by popup windows ───── -->
  <Style x:Key="PopupCloseBtn" TargetType="Button">
    <Setter Property="Background"      Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor"          Value="Hand" />
    <Setter Property="Padding"         Value="5,5" />
    <Setter Property="Width"           Value="26" />
    <Setter Property="Height"          Value="26" />
    <Setter Property="Opacity"         Value="0.48" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Chrome"
                  Background="{TemplateBinding Background}"
                  CornerRadius="6"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Chrome" Property="Background"
                      Value="{DynamicResource WidgetHoverBrush}" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- ── PopupSectionLabel: 10.5pt muted heading for help/popup sections -->
  <Style x:Key="PopupSectionLabel" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
    <Setter Property="FontSize"   Value="10.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Opacity"    Value="0.45" />
    <Setter Property="Margin"     Value="0,0,0,6" />
  </Style>

</ResourceDictionary>
