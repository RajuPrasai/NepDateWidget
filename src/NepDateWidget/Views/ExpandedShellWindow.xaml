<Window x:Class="NepDateWidget.Views.ExpandedShellWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
        xmlns:cvt="clr-namespace:NepDateWidget.Converters"
        xmlns:views="clr-namespace:NepDateWidget.Views"
        xmlns:h="clr-namespace:NepDateWidget.Helpers"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="NepDate Widget"
        WindowStyle="None"
        AllowsTransparency="False"
        ShowInTaskbar="False"
        Topmost="{Binding ExpandedPinned}"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        RenderOptions.ClearTypeHint="Enabled"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        Background="{DynamicResource WidgetBackgroundBrush}"
        Foreground="{DynamicResource WidgetForegroundBrush}"
        FontFamily="{DynamicResource WidgetFontFamily}"
        MinWidth="538" MinHeight="497"
        d:DataContext="{d:DesignInstance vm:MainViewModel}"
        d:Width="900" d:Height="650">

    <!-- Custom chrome: zero-height system caption so the entire titlebar surface is
         routed to WPF (right-click works for context menu, drag is handled via
         MouseLeftButtonDown -> DragMove). ResizeBorderThickness gives the user
         resize grips on all four edges via the standard Win32 hit-testing path. -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False" />
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <cvt:BoolToVisibilityConverter x:Key="BoolToVis"        Invert="False" />
        <cvt:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"  />
    </Window.Resources>

    <Border x:Name="ShellRoot"
            Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetBorderBrush}"
            BorderThickness="0.7">
        <Grid x:Name="ShellContentGrid">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ════════════════════════════════════════════════════════════
                 Row 0: Custom titlebar (VS Code style).
                 Layout: [icon] [title text] [drag region] [About] [Settings] [Close]
                 The drag region uses WindowChrome.IsHitTestVisibleInChromeFrom
                 = false (default for non-button items), so dragging the empty
                 stretch moves the window. Right-click on it opens the shared
                 context menu.
                 ════════════════════════════════════════════════════════════ -->
            <Grid Grid.Row="0"
                  x:Name="TitleBar"
                  Height="40"
                  Background="{DynamicResource WidgetBackgroundBrush}"
                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                  ContextMenuOpening="TitleBar_ContextMenuOpening">
                <Grid.ContextMenu>
                    <ContextMenu Style="{StaticResource WidgetContextMenuStyle}"
                                 DataContext="{Binding PlacementTarget.Tag,
                                               RelativeSource={RelativeSource Self}}">
                        <ContextMenu.Resources>
                            <Style TargetType="MenuItem" BasedOn="{StaticResource WidgetMenuItemStyle}" />
                            <Style TargetType="Separator" BasedOn="{StaticResource WidgetSeparatorStyle}" />
                        </ContextMenu.Resources>

                        <MenuItem Header="{Binding MenuToolsSectionLabel}"
                                  Style="{StaticResource WidgetMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconCalendar}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" />
                            </MenuItem.Icon>
                            <MenuItem Header="{Binding MenuToolsConvertLabel}" Command="{Binding OpenToolsConvertCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconConverter}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuToolsDaysLabel}" Command="{Binding OpenToolsDaysCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconDays}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuToolsTimeLabel}" Command="{Binding OpenToolsTimeCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconClock}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <MenuItem Header="{Binding MenuUnitSectionLabel}"
                                  Style="{StaticResource WidgetMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconRuler}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" />
                            </MenuItem.Icon>
                            <MenuItem Header="{Binding MenuUnitAreaLabel}" Command="{Binding OpenUnitAreaCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconArea}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuUnitWeightLabel}" Command="{Binding OpenUnitWeightCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconWeight}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <MenuItem Header="{Binding MenuTextSectionLabel}"
                                  Style="{StaticResource WidgetMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconText}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" />
                            </MenuItem.Icon>
                            <MenuItem Header="{Binding MenuTextUnicodeLabel}" Command="{Binding OpenTextUnicodeCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconUnicode}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuTextWordLabel}" Command="{Binding OpenTextWordCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconWordCount}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuTextPasswordLabel}" Command="{Binding OpenTextPasswordCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconLock}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuTextScriptLabel}" Command="{Binding OpenTextScriptCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconScript}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <MenuItem Header="{Binding MenuBankingSectionLabel}"
                                  Style="{StaticResource WidgetMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconBanking}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" />
                            </MenuItem.Icon>
                            <MenuItem Header="{Binding MenuBankingInterestLabel}" Command="{Binding OpenBankingInterestCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconCalculator}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuBankingEmiLabel}" Command="{Binding OpenBankingEmiCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconCalculator}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <MenuItem Header="{Binding MenuNetworkSectionLabel}"
                                  Style="{StaticResource WidgetMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconNetwork}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" />
                            </MenuItem.Icon>
                            <MenuItem Header="{Binding MenuNetworkMyIpLabel}" Command="{Binding OpenNetworkMyIpCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconMyIp}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuNetworkPingLabel}" Command="{Binding OpenNetworkPingCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconPing}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuNetworkScanLabel}" Command="{Binding OpenNetworkScanCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconScan}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuNetworkTraceLabel}" Command="{Binding OpenNetworkTraceCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconTrace}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuNetworkWhoisLabel}" Command="{Binding OpenNetworkWhoisCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconWhois}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                            <MenuItem Header="{Binding MenuNetworkDnsLabel}" Command="{Binding OpenNetworkDnsCommand}">
                                <MenuItem.Icon><Path Data="{StaticResource IconDns}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" /></MenuItem.Icon>
                            </MenuItem>
                        </MenuItem>

                        <MenuItem Header="{Binding MenuCopyTodayLabel}"
                                  Style="{StaticResource WidgetMenuItemStyle}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconCopy}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" />
                            </MenuItem.Icon>
                            <MenuItem Header="{Binding CopyTodayBsShortLabel}" Command="{Binding CopyTodayBsShortCommand}" />
                            <MenuItem Header="{Binding CopyTodayBsLongLabel}" Command="{Binding CopyTodayBsLongCommand}" />
                            <MenuItem Header="{Binding CopyTodayAdShortLabel}" Command="{Binding CopyTodayAdShortCommand}" />
                            <MenuItem Header="{Binding CopyTodayAdLongLabel}" Command="{Binding CopyTodayAdLongCommand}" />
                        </MenuItem>

                        <Separator Style="{StaticResource WidgetSectionSeparatorStyle}" />

                        <MenuItem Header="{Binding MenuMoreLabel}"
                                  Style="{StaticResource WidgetMenuItemStyle}"
                                  Command="{Binding OpenMoreCommand}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconMore}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="{Binding MenuSettingsLabel}"
                                  Style="{StaticResource WidgetMenuItemStyle}"
                                  Command="{Binding OpenSettingsCommand}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconSettings}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" />
                            </MenuItem.Icon>
                        </MenuItem>

                        <MenuItem Header="{Binding MenuExitLabel}"
                                  Style="{StaticResource WidgetMenuItemStyle}"
                                  Command="{Binding ExitCommand}">
                            <MenuItem.Icon>
                                <Path Data="{StaticResource IconExit}" Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1" Stretch="Uniform" />
                            </MenuItem.Icon>
                        </MenuItem>
                    </ContextMenu>
                </Grid.ContextMenu>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- App name + current date.
                     Reuses MiniBarView so the formatting and live-update behaviour
                     stay identical to the pill. Right-click bubbles up to the
                     TitleBar grid which owns the shared context menu. -->
                <views:MiniBarView Grid.Column="0"
                                   x:Name="TitleBarMiniBar"
                                   DataContext="{Binding MiniBar}"
                                   UseTransparentStyling="False"
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center" />

                <!-- Drag region (transparent stretch) - left as window chrome,
                     so it acts as caption for drag/double-click maximize.
                     Right-click is handled at the parent grid level so empty
                     space also opens the context menu. -->
                <Border Grid.Column="2" Background="Transparent" />

                <!-- Right-side button cluster -->
                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,4,0">

                    <!-- Pin / Always on top -->
                    <Button Command="{Binding ToggleExpandedPinCommand}"
                            ToolTip="Pin on top"
                            Cursor="Hand"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Width="28" Height="28">
                                                <Path Data="{StaticResource IconPin}"
                                                      Stroke="{TemplateBinding Foreground}"
                                                      StrokeThickness="1.2" StrokeLineJoin="Round"
                                                      Stretch="Uniform" Width="13" Height="13"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.7" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ExpandedPinned}" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- About / Heart -->
                    <Button Command="{Binding OpenAboutCommand}"
                            ToolTip="{Binding TooltipAbout}"
                            Cursor="Hand"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Width="28" Height="28">
                                                <Path Data="{StaticResource IconHeart}"
                                                      Stroke="{TemplateBinding Foreground}"
                                                      StrokeThickness="1.2" StrokeLineJoin="Round"
                                                      Stretch="Uniform" Width="13" Height="13"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.7" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="7">
                                        <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Settings -->
                    <Button Command="{Binding OpenSettingsCommand}"
                            ToolTip="{Binding TooltipSettings}"
                            Cursor="Hand"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Width="28" Height="28">
                                                <Path Data="{StaticResource IconSettings}"
                                                      Stroke="{TemplateBinding Foreground}"
                                                      StrokeThickness="1.2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Stretch="Uniform" Width="13" Height="13"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.7" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTabIndex}" Value="8">
                                        <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Close (collapses back to mini pill) - top-rightmost -->
                    <Button Click="CloseButton_Click"
                            ToolTip="{Binding TooltipMinimize}"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="CloseBg"
                                                    Background="{TemplateBinding Background}"
                                                    CornerRadius="6"
                                                    Width="28" Height="28">
                                                <Path Data="{StaticResource IconWindowClose}"
                                                      Stroke="{TemplateBinding Foreground}"
                                                      StrokeThickness="1.3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                      Stretch="Uniform" Width="11" Height="11"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="CloseBg" Property="Background" Value="#E81123" />
                                                    <Setter Property="Foreground" Value="White" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Row 1: divider -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource WidgetDividerBrush}" />

            <!-- Row 2: tabbed Calendar / Tools / Settings -->
            <h:CachedTabControl x:Name="ExpandedTabs"
                                Grid.Row="2"
                                Style="{StaticResource CachedTabControlStyle}"
                                SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem Style="{StaticResource WidgetTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconCalendar}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1"
                                  Stretch="Uniform" Width="15" Height="15"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TabHomeLabel}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:CalendarView DataContext="{Binding Calendar}" />
                </TabItem>
                <TabItem Style="{StaticResource WidgetTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconConverter}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1"
                                  Stretch="Uniform" Width="15" Height="15"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TabDateLabel}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:ConverterView DataContext="{Binding Calendar.Converter}" />
                </TabItem>
                <TabItem Style="{StaticResource WidgetTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconRuler}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1"
                                  Stretch="Uniform" Width="15" Height="15"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TabUnitLabel}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:UnitView DataContext="{Binding Unit}" />
                </TabItem>
                <TabItem Style="{StaticResource WidgetTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconText}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1"
                                  Stretch="Uniform" Width="15" Height="15"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TabTextLabel}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:TextToolsView DataContext="{Binding TextTools}" />
                </TabItem>
                <TabItem Style="{StaticResource WidgetTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconBanking}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1"
                                  Stretch="Uniform" Width="15" Height="15"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TabBankLabel}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:BankingView DataContext="{Binding Banking}" />
                </TabItem>
                <TabItem Style="{StaticResource WidgetTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconNetwork}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1"
                                  Stretch="Uniform" Width="15" Height="15"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TabNetworkLabel}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:NetworkToolsView DataContext="{Binding Network}" />
                </TabItem>
                <TabItem Style="{StaticResource WidgetTabItemStyle}">
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconMore}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.1"
                                  Stretch="Uniform" Width="15" Height="15"
                                  VerticalAlignment="Center" />
                            <TextBlock Text="{Binding TabMoreLabel}" VerticalAlignment="Center" Margin="4,0,0,0" />
                        </StackPanel>
                    </TabItem.Header>
                    <views:MoreView DataContext="{Binding More}" />
                </TabItem>
                <TabItem Style="{StaticResource WidgetTabItemStyle}" Visibility="Collapsed">
                    <TabItem.Header>
                        <TextBlock Text="{Binding TabAboutLabel}" />
                    </TabItem.Header>
                    <views:AboutView DataContext="{Binding About}" />
                </TabItem>
                <TabItem Style="{StaticResource WidgetTabItemStyle}" Visibility="Collapsed">
                    <TabItem.Header>
                        <TextBlock Text="{Binding TabSettingsLabel}" />
                    </TabItem.Header>
                    <views:SettingsView DataContext="{Binding Settings}" />
                </TabItem>
            </h:CachedTabControl>

            <!-- Row 3: RunBox trigger strip - click or hotkey opens the spotlight -->
            <Button x:Name="RunBoxStrip"
                    Grid.Row="3"
                    Height="28"
                    Margin="8,4,6,5"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"
                    Click="RunBoxStrip_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="StripBd"
                                Background="Transparent"
                                BorderBrush="{DynamicResource WidgetBorderBrush}"
                                BorderThickness="0.5"
                                CornerRadius="5"
                                Padding="9,0,4,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0"
                                      Data="{StaticResource IconScan}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}"
                                      StrokeThickness="1.3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Uniform"
                                      Width="11" Height="11"
                                      Opacity="0.4"
                                      VerticalAlignment="Center"
                                      Margin="0,0,8,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding RunBox.PlaceholderLabel}"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           Opacity="0.32"
                                           FontSize="11.5"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Calendar.FiscalFooterText}"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           Opacity="0.5"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,0,8,0" />
                                <Border Grid.Column="3"
                                        Background="{DynamicResource WidgetHoverBrush}"
                                        CornerRadius="4"
                                        Padding="7,3"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding RunBox.HotkeyHintLabel}" Value="">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding RunBox.HotkeyHintLabel}"
                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                               Opacity="0.32"
                                               FontSize="10.5"
                                               VerticalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StripBd" Property="Background"
                                        Value="{DynamicResource WidgetHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="StripBd" Property="Opacity" Value="0.7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>

