<Window x:Class="NepDateWidget.Views.ReminderPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
        xmlns:conv="clr-namespace:NepDateWidget.Converters"
        Title="Reminders"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource WidgetForegroundBrush}"
        FontFamily="{DynamicResource WidgetFontFamily}"
        SizeToContent="Height"
        Width="380"
        d:DataContext="{d:DesignInstance vm:ReminderViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True" />
        <conv:IntEqualConverter x:Key="IntEqual" />

        <!-- InputBoxStyle: from global TextBoxStyles.xaml -->

        <Style x:Key="RInput_Error" TargetType="TextBox" BasedOn="{StaticResource InputBoxStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasDateError}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetErrorBrush}" />
                    <Setter Property="BorderThickness" Value="0.7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RInput_TimeError" TargetType="TextBox" BasedOn="{StaticResource InputBoxStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasTimeError}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetErrorBrush}" />
                    <Setter Property="BorderThickness" Value="0.7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RInput_EndDateError" TargetType="TextBox" BasedOn="{StaticResource InputBoxStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding HasEndDateError}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetErrorBrush}" />
                    <Setter Property="BorderThickness" Value="0.7" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root">
                            <Border x:Name="BgLayer" Background="{TemplateBinding Background}" CornerRadius="6" />
                            <Border Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgLayer" Property="Opacity" Value="0.70" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgLayer" Property="Opacity" Value="0.52" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.40" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RBtnSecondary" TargetType="Button" BasedOn="{StaticResource RBtn}">
            <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
        </Style>

        <Style x:Key="RBtnDanger" TargetType="Button" BasedOn="{StaticResource RBtn}">
            <Setter Property="Background" Value="{DynamicResource WidgetErrorBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="4,4" />
        </Style>

        <Style x:Key="RBtnIcon" TargetType="Button" BasedOn="{StaticResource RBtn}">
            <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="Padding" Value="4,4" />
            <Setter Property="Width" Value="30" />
            <Setter Property="Height" Value="30" />
        </Style>

        <Style x:Key="RecurrenceToggle" TargetType="RadioButton">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bd"
                                Background="{DynamicResource WidgetInputBrush}"
                                CornerRadius="4"
                                Padding="8,4"
                                BorderThickness="0.7"
                                BorderBrush="{DynamicResource WidgetInputBorderBrush}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
        </Style>

        <Style x:Key="AmPmToggle" TargetType="Button" BasedOn="{StaticResource RBtn}">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="6,0" />
            <Setter Property="Height" Value="30" />
            <Setter Property="MinWidth" Value="36" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetBorderBrush}"
            BorderThickness="0.7"
            CornerRadius="10"
            ClipToBounds="True"
            Padding="18,16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.25" ShadowDepth="2" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="{Binding PopupTitleLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding DateHeader}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="12" Opacity="0.55" Margin="0,1,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Click="CloseButton_Click"
                        Style="{StaticResource RBtnIcon}" Width="28" Height="28"
                        VerticalAlignment="Top">
                    <Path Data="M18 6L6 18M6 6l12 12"
                          Stroke="{DynamicResource WidgetForegroundBrush}"
                          StrokeThickness="1.5" Stretch="Uniform"
                          Width="12" Height="12" />
                </Button>
            </Grid>

            <Border Grid.Row="1" Height="1"
                    Background="{DynamicResource WidgetDividerBrush}" Margin="0,2,0,4" />

            <!-- Reminder list (when not editing) -->
            <StackPanel Grid.Row="2"
                        Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                <TextBlock Text="{Binding NoRemindersLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           Opacity="0.5" FontSize="14" Margin="0,8"
                           HorizontalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Reminders.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <ItemsControl ItemsSource="{Binding Reminders}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ReminderEntryViewModel}">
                            <Border CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                                        <Setter Property="Opacity" Value="1" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Opacity" Value="0.5" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding CompletedLabel}"
                                                       Foreground="{DynamicResource WidgetAccentBrush}"
                                                       FontSize="12" Opacity="0.7" Margin="6,1,0,0"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Time12}"
                                                       Foreground="{DynamicResource WidgetAccentBrush}"
                                                       FontSize="13" />
                                            <TextBlock Text="{Binding RecurrenceText}"
                                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                                       Opacity="0.5" FontSize="13" Margin="6,0,0,0" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Notes}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   Opacity="0.5" FontSize="12"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="220"
                                                   Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                    <!-- Edit button: hidden for completed reminders -->
                                    <Button Grid.Column="1"
                                            Style="{StaticResource RBtnIcon}" Margin="4,0"
                                            Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}"
                                            Visibility="{Binding IsCompleted, Converter={StaticResource InverseBoolToVis}}">
                                        <Path Data="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"
                                              Stroke="{DynamicResource WidgetForegroundBrush}"
                                              StrokeThickness="1.2" Stretch="Uniform"
                                              Width="14" Height="14" />
                                    </Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource RBtnDanger}"
                                            Width="30" Height="30"
                                            Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding Id}">
                                        <Path Data="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"
                                              Stroke="White"
                                              StrokeThickness="1.2" Stretch="Uniform"
                                              Width="14" Height="14" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- Edit/Add form (when editing) -->
            <StackPanel Grid.Row="2"
                        Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}">
                <!-- Title -->
                <TextBlock Text="{Binding TitleLabel}" Style="{StaticResource FieldLabel}" Margin="0,2,0,2" />
                <TextBox x:Name="TitleInput"
                         Text="{Binding EditTitle, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource InputBoxStyle}" MaxLength="100"
                         Tag="{Binding HintReminderTitle}" TabIndex="0" />
                <TextBlock Text="{Binding TitleError}"
                           Foreground="{DynamicResource WidgetErrorBrush}"
                           FontSize="11" Margin="0,1,0,0" />

                <!-- Date + Time row -->
                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding DateLabel}" Style="{StaticResource FieldLabel}" Margin="0,6,0,2" />
                        <TextBox Text="{Binding EditDate, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource RInput_Error}" MaxLength="12"
                                 Tag="{Binding HintReminderDate}" TabIndex="1" />
                        <TextBlock Text="{Binding DateError}"
                                   Foreground="{DynamicResource WidgetErrorBrush}"
                                   FontSize="11" Margin="0,1,0,0" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" Grid.ColumnSpan="2" Margin="10,0,0,0">
                        <TextBlock Text="{Binding TimeLabel}" Style="{StaticResource FieldLabel}" Margin="0,6,0,2" />
                        <StackPanel Orientation="Horizontal" Height="37" Width="130">
                            <TextBox Text="{Binding EditTime, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource RInput_TimeError}" MaxLength="5"
                                     TextAlignment="Left" Tag="{Binding HintReminderTime}" TabIndex="2" Width="60" />
                            <Button Style="{StaticResource AmPmToggle}" Margin="10,0,0,0"
                                    Command="{Binding ToggleAmPmCommand}" TabIndex="3" Width="23" Height="35">
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="{x:Type TextBlock}">
                                            <Setter Property="Text" Value="AM" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAm}" Value="False">
                                                    <Setter Property="Text" Value="PM" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Button>
                        </StackPanel>
                        <TextBlock Text="{Binding TimeError}"
                                   Foreground="{DynamicResource WidgetErrorBrush}"
                                   FontSize="11" Margin="0,1,0,0" />
                    </StackPanel>
                </Grid>

                <!-- Notes -->
                <TextBlock Text="{Binding NotesLabel}" Style="{StaticResource FieldLabel}" Margin="0,6,0,2" />
                <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource MultilineInputStyle}"
                         Height="40" MaxLength="500"
                         TabIndex="4" />

                <!-- Recurrence toggle row -->
                <TextBlock Text="{Binding RecurrenceLabel}" Style="{StaticResource FieldLabel}" Margin="0,6,0,2" />
                <UniformGrid Columns="5">
                    <RadioButton Content="{Binding RecurrenceOptions[0]}"
                                 Style="{StaticResource RecurrenceToggle}"
                                 IsChecked="{Binding EditRecurrenceIndex, Converter={StaticResource IntEqual}, ConverterParameter=0}"
                                 Margin="0,0,3,0" GroupName="Recurrence" TabIndex="5" />
                    <RadioButton Content="{Binding RecurrenceOptions[1]}"
                                 Style="{StaticResource RecurrenceToggle}"
                                 IsChecked="{Binding EditRecurrenceIndex, Converter={StaticResource IntEqual}, ConverterParameter=1}"
                                 Margin="0,0,3,0" GroupName="Recurrence" TabIndex="6" />
                    <RadioButton Content="{Binding RecurrenceOptions[2]}"
                                 Style="{StaticResource RecurrenceToggle}"
                                 IsChecked="{Binding EditRecurrenceIndex, Converter={StaticResource IntEqual}, ConverterParameter=2}"
                                 Margin="0,0,3,0" GroupName="Recurrence" TabIndex="7" />
                    <RadioButton Content="{Binding RecurrenceOptions[3]}"
                                 Style="{StaticResource RecurrenceToggle}"
                                 IsChecked="{Binding EditRecurrenceIndex, Converter={StaticResource IntEqual}, ConverterParameter=3}"
                                 Margin="0,0,3,0" GroupName="Recurrence" TabIndex="8" />
                    <RadioButton Content="{Binding RecurrenceOptions[4]}"
                                 Style="{StaticResource RecurrenceToggle}"
                                 IsChecked="{Binding EditRecurrenceIndex, Converter={StaticResource IntEqual}, ConverterParameter=4}"
                                 GroupName="Recurrence" TabIndex="9" />
                </UniformGrid>

                <!-- End date (only visible for recurring reminders) -->
                <StackPanel x:Name="EndDateSection">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EditRecurrenceIndex}" Value="0">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="{Binding EndDateLabel}" Style="{StaticResource FieldLabel}" Margin="0,6,0,2" />
                    <TextBox Text="{Binding EditEndDate, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource RInput_EndDateError}" MaxLength="12"
                             Tag="{Binding HintReminderDate}" TabIndex="9" />
                    <TextBlock Text="{Binding EndDateError}"
                               Foreground="{DynamicResource WidgetErrorBrush}"
                               FontSize="11" Margin="0,1,0,0" />
                </StackPanel>

                <!-- Save / Cancel -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Style="{StaticResource RBtnSecondary}"
                            Command="{Binding CancelEditCommand}" Margin="0,0,6,0" TabIndex="10">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconWindowClose}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.4"
                                  Fill="Transparent" Stretch="Uniform"
                                  Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding CancelLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource RBtn}"
                            Command="{Binding SaveCommand}" TabIndex="11">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconCheck}"
                                  Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.5"
                                  Fill="Transparent" Stretch="Uniform"
                                  Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,7,0" />
                            <TextBlock Text="{Binding SaveLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Footer: Add button -->
            <Button Grid.Row="3"
                    Command="{Binding StartAddCommand}"
                    HorizontalAlignment="Stretch" Margin="0,6,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource RBtn}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
                <StackPanel Orientation="Horizontal">
                    <Path Data="{StaticResource IconBell}"
                          Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.4"
                          Fill="Transparent" Stretch="Uniform"
                          Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,7,0" />
                    <TextBlock Text="{Binding AddLabel}" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Discard changes inline banner -->
            <Border Grid.Row="0" Grid.RowSpan="4"
                    Background="{DynamicResource WidgetBackgroundBrush}"
                    CornerRadius="6"
                    Visibility="{Binding ShowDiscardBanner, Converter={StaticResource BoolToVis}}">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12">
                    <TextBlock Text="{Binding DiscardTitleLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="15" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,12" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Style="{StaticResource RBtn}"
                                Command="{Binding ConfirmDiscardCommand}"
                                MinWidth="80" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconCheck}"
                                      Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding DiscardYesLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource RBtnSecondary}"
                                Command="{Binding CancelDiscardCommand}"
                                MinWidth="80">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconWindowClose}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.4"
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding CancelLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>


        </Grid>
    </Border>
</Window>
