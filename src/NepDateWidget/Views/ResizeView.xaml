<UserControl x:Class="NepDateWidget.Views.ResizeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             xmlns:conv="clr-namespace:NepDateWidget.Converters"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             AllowDrop="True"
             d:DataContext="{d:DesignInstance vm:ResizeViewModel}"
             d:Width="380">

    <UserControl.Resources>
        <conv:StringToImageSourceConverter x:Key="StringToImageSource" />


    </UserControl.Resources>

    <Grid x:Name="ResizeViewRoot">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <StackPanel Grid.Row="0">
      <!-- Drop zone (hidden once files loaded) -->
      <Border Visibility="{Binding HasFiles, Converter={StaticResource InverseBoolToVis}}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8"
                CornerRadius="8"
                Padding="12,20"
                Margin="0,0,0,8"
                Cursor="Hand"
                MouseLeftButtonDown="DropZone_MouseLeftButtonDown"
                MouseLeftButtonUp="DropZone_Click">
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
            <Style.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
        <StackPanel HorizontalAlignment="Center">
          <Path
    Data="{StaticResource IconDownload}"
    Stroke="{DynamicResource WidgetForegroundBrush}"
    StrokeThickness="1.7"
    StrokeLineJoin="Round"
    Stretch="Uniform"
    Width="28"
    Height="28"
    HorizontalAlignment="Center"
    Margin="0,0,0,6"
    Opacity="0.45" />
          <TextBlock Text="{Binding DropLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="13" HorizontalAlignment="Center" Opacity="0.7" />
          <TextBlock Text="{Binding BrowseLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="11" HorizontalAlignment="Center" Opacity="0.45" Margin="0,2,0,0" />
        </StackPanel>
      </Border>

      <!-- Mixed-type warning -->
      <Border Background="{DynamicResource WidgetErrorBrush}"
                CornerRadius="6" Padding="10,7" Margin="0,0,0,8"
                Visibility="{Binding HasMixedTypeWarning, Converter={StaticResource BoolToVis}}">
        <TextBlock Text="{Binding MixedTypeWarning}"
                       Foreground="{DynamicResource WidgetDayTodayTextBrush}" FontSize="12" TextWrapping="Wrap" />
      </Border>

      <!-- PDF not supported notice -->
      <Border Background="{DynamicResource WidgetInputBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.7" CornerRadius="6" Padding="10,8" Margin="0,0,0,8"
                Visibility="{Binding IsPdfLoaded, Converter={StaticResource BoolToVis}}">
        <TextBlock Text="{Binding PdfNotSupportedLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="12" TextWrapping="Wrap" Opacity="0.75" />
      </Border>

      <!-- File list -->
      <ItemsControl ItemsSource="{Binding Files}" MaxHeight="130" Margin="0,0,0,8"
                    Visibility="{Binding ShowFileList, Converter={StaticResource BoolToVis}}">
          <ItemsControl.Template>
            <ControlTemplate>
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsPresenter />
              </ScrollViewer>
            </ControlTemplate>
          </ItemsControl.Template>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:CompressionFileItemViewModel}">
              <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Thumbnail -->
                <Border Grid.Column="0"
                                    Height="30" VerticalAlignment="Center" Margin="0,0,6,0">
                  <Image Source="{Binding FilePath, Converter={StaticResource StringToImageSource}}"
                                       Height="30" Stretch="Uniform">
                    <Image.Clip>
                      <RectangleGeometry RadiusX="6" RadiusY="6" Rect="0,0,30,30" />
                    </Image.Clip>
                  </Image>
                </Border>
                <!-- File name + size -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                  <TextBlock Text="{Binding FileName}"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           FontSize="12" TextTrimming="CharacterEllipsis" />
                  <TextBlock Text="{Binding FileSizeLabel}"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           Opacity="0.55" FontSize="10.5" />
                </StackPanel>
                <!-- Output size -->
                <TextBlock Grid.Column="2"
                                       Text="{Binding OutputSizeLabel}"
                                       Foreground="{DynamicResource WidgetAccentBrush}"
                                       FontSize="11" VerticalAlignment="Center" Margin="6,0,6,0"
                                       Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}" />
                <!-- Remove button -->
                <Button Grid.Column="3"
                                    Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding FilePath}"
                                    Visibility="{Binding DataContext.IsJobRunning, RelativeSource={RelativeSource AncestorType=UserControl},
                                                 Converter={StaticResource InverseBoolToVis}}"
                                    ToolTip="{Binding DataContext.RemoveFileTooltipLabel, RelativeSource={RelativeSource AncestorType=UserControl}}">
                  <Button.Style>
                    <Style TargetType="Button">
                      <Setter Property="Background"      Value="Transparent" />
                      <Setter Property="BorderThickness" Value="0" />
                      <Setter Property="Padding"         Value="4" />
                      <Setter Property="Cursor"          Value="Hand" />
                      <Setter Property="Template">
                        <Setter.Value>
                          <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                                            Padding="{TemplateBinding Padding}" CornerRadius="4">
                              <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                              <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
                              </Trigger>
                            </ControlTemplate.Triggers>
                          </ControlTemplate>
                        </Setter.Value>
                      </Setter>
                    </Style>
                  </Button.Style>
                  <Path Data="{StaticResource IconWindowClose}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}"
                                      StrokeThickness="1.3" Stretch="Uniform"
                                      Width="9" Height="9" />
                </Button>
              </Grid>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Add more button removed - AllowDrop on the UserControl handles additional files via drag -->

      <!-- Resize dimensions -->
      <StackPanel Margin="0,0,0,16"
                  Visibility="{Binding IsPdfLoaded, Converter={StaticResource InverseBoolToVis}}">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <Path Data="{StaticResource IconRuler}"
                    Stroke="{DynamicResource WidgetForegroundBrush}"
                    StrokeThickness="1.2" Stretch="Uniform"
                    Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,5,0" />
              <TextBlock Text="{Binding DimensionsSectionLabel}"
                         Foreground="{DynamicResource WidgetForegroundBrush}"
                         FontSize="12" FontWeight="SemiBold" />
          </StackPanel>
          <!-- Width × Height inputs -->
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="{Binding WidthLabel}" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
              <TextBox Style="{StaticResource InputBoxStyle}"
                                 Text="{Binding WidthText, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="5" />
            </StackPanel>
            <TextBlock Grid.Column="1" Text="×"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="16" Opacity="0.5"
                               VerticalAlignment="Bottom" Margin="8,0,8,2" />
            <StackPanel Grid.Column="2">
              <TextBlock Text="{Binding HeightLabel}" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
              <TextBox Style="{StaticResource InputBoxStyle}"
                                 Text="{Binding HeightText, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="5" />
            </StackPanel>
            <TextBlock Grid.Column="3"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="10.5" Opacity="0.45"
                               VerticalAlignment="Bottom" Margin="8,0,0,3"
                               Text="{Binding AspectRatioHintLabel}" />
          </Grid>
          <!-- Stretch warning -->
          <Border Background="{DynamicResource WidgetErrorBrush}"
                        CornerRadius="5" Padding="8,5" Margin="0,6,0,0"
                        Visibility="{Binding ShowStretchWarning, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding StretchWarningLabel}"
                               Foreground="{DynamicResource WidgetDayTodayTextBrush}" FontSize="11" TextWrapping="Wrap" />
          </Border>
      </StackPanel>

      <!-- Also compress + quality level -->
      <StackPanel Margin="0,0,0,16"
                  Visibility="{Binding IsPdfLoaded, Converter={StaticResource InverseBoolToVis}}">
          <CheckBox Content="{Binding AlsoCompressLabel}"
                          IsChecked="{Binding AlsoCompress}"
                          Style="{StaticResource WidgetCheckBox}" />
          <StackPanel Visibility="{Binding ShowQualitySlider, Converter={StaticResource BoolToVis}}"
                            Margin="0,8,0,0">
            <TextBlock Text="{Binding LevelSectionLabel}" Style="{StaticResource FieldLabel}" Margin="0,0,0,6" />
            <Slider Minimum="0" Maximum="4"
                            Value="{Binding QualityLevel}"
                            Style="{DynamicResource IosSlider}"
                            IsSnapToTickEnabled="True" TickFrequency="1"
                            SmallChange="1" LargeChange="1"
                            Margin="0,0,0,4" />
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="{Binding LevelSmallestLabel}" Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Left" />
              <TextBlock Grid.Column="1" Text="{Binding LevelLowLabel}"      Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Center" />
              <TextBlock Grid.Column="2" Text="{Binding LevelBalancedLabel}" Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Center" />
              <TextBlock Grid.Column="3" Text="{Binding LevelHighLabel}"     Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Center" />
              <TextBlock Grid.Column="4" Text="{Binding LevelBestLabel}"     Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Right" />
            </Grid>
          </StackPanel>
      </StackPanel>

      <!-- Progress bar -->
      <StackPanel Margin="0,0,0,12"
                  Visibility="{Binding IsJobRunning, Converter={StaticResource BoolToVis}}">
          <Grid Margin="0,0,0,5">
            <TextBlock Text="{Binding ProgressTitleLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="12" FontWeight="SemiBold" />
            <TextBlock Text="{Binding ProgressLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="11" Opacity="0.6" HorizontalAlignment="Right" />
          </Grid>
          <ProgressBar Minimum="0"
                             Maximum="{Binding TotalCount}"
                             Value="{Binding CompletedCount, Mode=OneWay}"
                             Style="{StaticResource WidgetProgressBar}" />
      </StackPanel>

      <!-- Resize / Cancel button -->
      <Grid Visibility="{Binding ShowSummary, Converter={StaticResource InverseBoolToVis}}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0"
                    Style="{StaticResource SecondaryButton}"
                    Command="{Binding CancelCommand}"
                    Margin="0,0,8,0"
                    Visibility="{Binding IsJobRunning, Converter={StaticResource BoolToVis}}">
          <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource IconWindowClose}"
                    Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.3"
                    Fill="Transparent" Stretch="Uniform"
                    Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0" />
              <TextBlock Text="{Binding CancelLabel}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
        <Button Grid.Column="1"
                    Style="{StaticResource AccentButton}"
                    Command="{Binding ResizeCommand}"
                    IsEnabled="{Binding CanResize}">
          <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource IconResize}"
                    Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.3"
                    Fill="Transparent" Stretch="Uniform"
                    Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0" />
              <TextBlock Text="{Binding ResizeButtonLabel}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>
    </StackPanel>

    <!-- Summary banner -->
    <Border Grid.Row="1"
            Background="{DynamicResource WidgetAccentBrushLight}"
            BorderBrush="{DynamicResource WidgetAccentBrush}"
            BorderThickness="1.5"
            CornerRadius="8"
            Padding="10,9"
            Margin="0,8,0,0"
            Visibility="{Binding ShowSummary, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
          <Path Data="{StaticResource IconCheck}"
                Stroke="{DynamicResource WidgetAccentBrush}"
                StrokeThickness="1.8"
                Fill="Transparent" Stretch="Uniform"
                Width="13" Height="13"
                VerticalAlignment="Center" Margin="0,0,8,0" />
          <TextBlock Text="{Binding SummaryFilesSegment}"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
          <TextBlock Text=" | "
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     Opacity="0.35" FontSize="12" VerticalAlignment="Center" />
          <TextBlock Text="{Binding SummaryOrigSizeSegment}"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     FontSize="12" VerticalAlignment="Center" />
          <TextBlock Text=" | "
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     Opacity="0.35" FontSize="12" VerticalAlignment="Center" />
          <TextBlock Text="{Binding SummaryNewSizeSegment}"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     FontSize="12" VerticalAlignment="Center" />
          <TextBlock Text=" | "
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     Opacity="0.35" FontSize="12" VerticalAlignment="Center" />
          <TextBlock Text="{Binding SummarySavedSegment}"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     FontSize="12" VerticalAlignment="Center" />
        </StackPanel>
        <!-- Dismiss -->
        <Button Grid.Column="1"
                Command="{Binding DismissSummaryCommand}"
                VerticalAlignment="Center" Margin="10,0,0,0"
                Cursor="Hand">
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Background"      Value="Transparent" />
              <Setter Property="BorderThickness" Value="0" />
              <Setter Property="Padding"         Value="5" />
              <Setter Property="Opacity"         Value="0.55" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
              <Style.Triggers>
              </Style.Triggers>
            </Style>
          </Button.Style>
          <Path Data="{StaticResource IconWindowClose}"
                Stroke="{DynamicResource WidgetForegroundBrush}"
                StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                Width="10" Height="10" Stretch="Fill" />
        </Button>
      </Grid>
    </Border>
  </Grid>
</UserControl>
