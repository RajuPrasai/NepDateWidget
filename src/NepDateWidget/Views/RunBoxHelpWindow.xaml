<Window x:Class="NepDateWidget.Views.RunBoxHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RunBox Help"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource WidgetForegroundBrush}"
        FontFamily="{DynamicResource WidgetFontFamily}"
        SizeToContent="Height"
        Width="520"
        Opacity="0">

    <Window.Resources>
        <Style x:Key="RbHelpCloseBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Padding"         Value="5,5" />
            <Setter Property="Width"           Value="26" />
            <Setter Property="Height"          Value="26" />
            <Setter Property="Opacity"         Value="0.48" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background"
                                        Value="{DynamicResource WidgetHoverBrush}" />
                                <Setter Property="Opacity" Value="1.0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RbSectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize"   Value="10.5" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity"    Value="0.45" />
            <Setter Property="Margin"     Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetBorderBrush}"
            BorderThickness="0.7"
            CornerRadius="12"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" Opacity="0.30" ShadowDepth="3" Direction="270" />
        </Border.Effect>

        <StackPanel>

            <!-- Header -->
            <Border Padding="18,14,12,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText"
                               Grid.Column="0"
                               Foreground="{DynamicResource WidgetAccentBrush}"
                               FontSize="15" FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0" />
                    <Button Grid.Column="1"
                            Style="{StaticResource RbHelpCloseBtn}"
                            Click="CloseBtn_Click">
                        <Path Data="{StaticResource IconWindowClose}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.3" Stretch="Uniform"
                              Width="10" Height="10" />
                    </Button>
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Height="0.7" Background="{DynamicResource WidgetBorderBrush}" Margin="18,0" />

            <!-- Body -->
            <StackPanel Margin="18,12,18,16">

                <!-- Description -->
                <TextBlock x:Name="DescText"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="12" Opacity="0.80"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14" />

                <!-- Keyboard shortcuts section -->
                <TextBlock x:Name="KeysHeading"
                           Style="{StaticResource RbSectionLabel}" />
                <Border Background="{DynamicResource WidgetInputBrush}"
                        BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,0,0,14">
                    <ItemsControl x:Name="KeysList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Key}"
                                               Foreground="{DynamicResource WidgetAccentBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Cascadia Code, Consolas" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                               FontSize="11" Opacity="0.80"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Active shortcuts section -->
                <TextBlock x:Name="ShortcutsHeading"
                           Style="{StaticResource RbSectionLabel}" />
                <Border x:Name="ShortcutsPanel"
                        Background="{DynamicResource WidgetInputBrush}"
                        BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,0,0,14">
                    <ItemsControl x:Name="ShortcutsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Key}"
                                               Foreground="{DynamicResource WidgetAccentBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Cascadia Code, Consolas" />
                                    <TextBlock Grid.Column="1"
                                               Text="→"
                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                               FontSize="11" Opacity="0.45"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Value}"
                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                               FontSize="11" Opacity="0.80" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Scripts section -->
                <TextBlock x:Name="ScriptsHeading"
                           Style="{StaticResource RbSectionLabel}" />
                <Border x:Name="ScriptsPanel"
                        Background="{DynamicResource WidgetInputBrush}"
                        BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,0,0,4">
                    <ItemsControl x:Name="ScriptsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               Foreground="{DynamicResource WidgetAccentBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Cascadia Code, Consolas" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                               FontSize="11" Opacity="0.80"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </StackPanel>

        </StackPanel>
    </Border>
</Window>
