<Window x:Class="NepDateWidget.Views.RunBoxHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RunBox Help"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource WidgetForegroundBrush}"
        FontFamily="{DynamicResource WidgetFontFamily}"
        SizeToContent="Height"
        Width="520"
        Opacity="0">

    <Window.Resources>

    </Window.Resources>

    <Border Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetBorderBrush}"
            BorderThickness="0.7"
            CornerRadius="12"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" Opacity="0.30" ShadowDepth="3" Direction="270" />
        </Border.Effect>

        <StackPanel>

            <!-- Header -->
            <Border Padding="18,14,12,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText"
                               Grid.Column="0"
                               Foreground="{DynamicResource WidgetAccentBrush}"
                               FontSize="15" FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,0,8,0" />
                    <Button Grid.Column="1"
                            Style="{StaticResource PopupCloseBtn}"
                            Click="CloseBtn_Click">
                        <Path Data="{StaticResource IconWindowClose}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.3" Stretch="Uniform"
                              Width="10" Height="10" />
                    </Button>
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Height="0.7" Background="{DynamicResource WidgetBorderBrush}" Margin="18,0" />

            <!-- Body -->
            <StackPanel Margin="18,12,18,16">

                <!-- Description -->
                <TextBlock x:Name="DescText"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="12" Opacity="0.80"
                           TextWrapping="Wrap"
                           Margin="0,0,0,14" />

                <!-- Keyboard shortcuts section -->
                <TextBlock x:Name="KeysHeading"
                           Style="{StaticResource PopupSectionLabel}" />
                <Border Background="{DynamicResource WidgetInputBrush}"
                        BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,0,0,14">
                    <ItemsControl x:Name="KeysList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Key}"
                                               Foreground="{DynamicResource WidgetAccentBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Cascadia Code, Consolas" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Value}"
                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                               FontSize="11" Opacity="0.80"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Active shortcuts section -->
                <TextBlock x:Name="ShortcutsHeading"
                           Style="{StaticResource PopupSectionLabel}" />
                <Border x:Name="ShortcutsPanel"
                        Background="{DynamicResource WidgetInputBrush}"
                        BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,0,0,14">
                    <ItemsControl x:Name="ShortcutsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="14" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Key}"
                                               Foreground="{DynamicResource WidgetAccentBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Cascadia Code, Consolas" />
                                    <TextBlock Grid.Column="1"
                                               Text="→"
                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                               FontSize="11" Opacity="0.45"
                                               HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding Value}"
                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                               FontSize="11" Opacity="0.80" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Scripts section -->
                <TextBlock x:Name="ScriptsHeading"
                           Style="{StaticResource PopupSectionLabel}" />
                <Border x:Name="ScriptsPanel"
                        Background="{DynamicResource WidgetInputBrush}"
                        BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="6"
                        Padding="10,8"
                        Margin="0,0,0,4">
                    <ItemsControl x:Name="ScriptsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               Foreground="{DynamicResource WidgetAccentBrush}"
                                               FontSize="11" FontWeight="SemiBold"
                                               FontFamily="Cascadia Code, Consolas" />
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Description}"
                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                               FontSize="11" Opacity="0.80"
                                               TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

            </StackPanel>

        </StackPanel>
    </Border>
</Window>
