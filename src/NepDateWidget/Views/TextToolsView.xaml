<UserControl x:Class="NepDateWidget.Views.TextToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             xmlns:cvt="clr-namespace:NepDateWidget.Converters"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             d:DataContext="{d:DesignInstance vm:TextToolsViewModel}"
             d:Width="380">

    <UserControl.Resources>
        <cvt:BoolToVisibilityConverter x:Key="BoolToVis"        Invert="False" />
        <cvt:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"  />

        <!-- Pill mode-selector button (inactive state) -->
        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderBrush"     Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Height"          Value="28" />
            <Setter Property="Padding"         Value="10,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Opacity"         Value="0.55" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
                                <Setter Property="Opacity"    Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Accent button -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
            <Setter Property="BorderThickness" Value="0.7" />
            <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Height"          Value="32" />
            <Setter Property="Padding"         Value="12,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root">
                            <Border x:Name="BgLayer" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" />
                            <Border Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BgLayer" Property="Opacity" Value="0.70" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BgLayer" Property="Opacity" Value="0.52" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="0.7" />
            <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Height"          Value="28" />
            <Setter Property="Padding"         Value="10,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Direction/action button - equal-weight bordered pair (Preeti ↔ Unicode) -->
        <Style x:Key="DirButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="0.7" />
            <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Height"          Value="32" />
            <Setter Property="Padding"         Value="8,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Small case converter button -->
        <Style x:Key="CaseButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Height"   Value="28" />
            <Setter Property="Padding"  Value="6,0" />
        </Style>

        <!-- Stat number label -->
        <Style x:Key="StatNumber" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="18" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="Foreground"   Value="{DynamicResource WidgetAccentBrush}" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>

        <!-- InputBoxStyle, MultilineInputStyle, MultilineOutputStyle: from global TextBoxStyles.xaml -->

        <!-- Themed CheckBox - iOS-style toggle switch -->
        <Style x:Key="WidgetCheckBox" TargetType="CheckBox">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="Cursor"  Value="Hand" />
            <Setter Property="Margin"  Value="0,2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Track"
                                    Width="34" Height="18"
                                    CornerRadius="9"
                                    Background="{DynamicResource WidgetInputBrush}"
                                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                    BorderThickness="0.7">
                                <Border x:Name="Thumb"
                                        Width="14" Height="14"
                                        CornerRadius="7"
                                        Background="{DynamicResource WidgetInputBorderBrush}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="1,0,0,0" />
                            </Border>
                            <ContentPresenter Margin="6,0,0,0" VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"  Value="{DynamicResource WidgetAccentBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                                <Setter TargetName="Thumb" Property="Background"           Value="White" />
                                <Setter TargetName="Thumb" Property="HorizontalAlignment"  Value="Right" />
                                <Setter TargetName="Thumb" Property="Margin"               Value="0,0,1,0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed ProgressBar -->
        <Style x:Key="StrengthBar" TargetType="ProgressBar">
            <Setter Property="Height"  Value="7" />
            <Setter Property="Minimum" Value="0" />
            <Setter Property="Maximum" Value="100" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetSuccessBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="Track"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="3" />
                            <Border x:Name="Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left">
                                <Border.Width>
                                    <MultiBinding>
                                        <MultiBinding.Converter>
                                            <cvt:StrengthBarWidthConverter />
                                        </MultiBinding.Converter>
                                        <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}" />
                                        <Binding Path="ActualWidth" RelativeSource="{RelativeSource TemplatedParent}" />
                                    </MultiBinding>
                                </Border.Width>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding StrengthLevel}" Value="1">
                    <Setter Property="Foreground" Value="{DynamicResource WidgetErrorBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StrengthLevel}" Value="2">
                    <Setter Property="Foreground" Value="{DynamicResource WidgetHolidayBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Criteria tick label -->
        <Style x:Key="CriteriaLabel" TargetType="TextBlock">
            <Setter Property="FontSize"          Value="10" />
            <Setter Property="Margin"            Value="4,0,0,0" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground"        Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="Opacity"           Value="0.8" />
        </Style>

    </UserControl.Resources>

    <Grid MaxWidth="1024">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

<!-- ══ Mode selector - segmented control ══════════════════════════ -->
        <Border Grid.Row="0"
                Background="{DynamicResource WidgetInputBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.7"
                CornerRadius="7"
                Padding="3"
                Margin="8,4,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="2">
                    <Button Command="{Binding SetModeUnicodeCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModeUnicode}" Value="True">
                                        <Setter Property="Opacity"         Value="1" />
                                        <Setter Property="FontWeight"      Value="SemiBold" />
                                        <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                        <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="BorderThickness" Value="0.7" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconUnicode}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.1" Stretch="Uniform" Width="13" Height="13"
                                  VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="{Binding ModeUnicodeLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                          Style="{StaticResource HoverGateStyle}">
                        <Button Style="{StaticResource InfoPillBadgeStyle}"
                                Visibility="{Binding IsModeUnicode, Converter={StaticResource BoolToVis}}"
                                Command="{Binding OpenHelpCommand}" CommandParameter="help.text.unicode" />
                    </Grid>
                </Grid>
                <Grid Grid.Column="1">
                    <Button Command="{Binding SetModeWordCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModeWord}" Value="True">
                                        <Setter Property="Opacity"         Value="1" />
                                        <Setter Property="FontWeight"      Value="SemiBold" />
                                        <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                        <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="BorderThickness" Value="0.7" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconWordCount}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.1" Stretch="Uniform" Width="13" Height="13"
                                  VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="{Binding ModeWordLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                          Style="{StaticResource HoverGateStyle}">
                        <Button Style="{StaticResource InfoPillBadgeStyle}"
                                Visibility="{Binding IsModeWord, Converter={StaticResource BoolToVis}}"
                                Command="{Binding OpenHelpCommand}" CommandParameter="help.text.word" />
                    </Grid>
                </Grid>
                <Grid Grid.Column="0">
                    <Button Command="{Binding SetModePasswordCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModePassword}" Value="True">
                                        <Setter Property="Opacity"         Value="1" />
                                        <Setter Property="FontWeight"      Value="SemiBold" />
                                        <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                        <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="BorderThickness" Value="0.7" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconLock}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.1" Stretch="Uniform" Width="13" Height="13"
                                  VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="{Binding ModePasswordLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                          Style="{StaticResource HoverGateStyle}">
                        <Button Style="{StaticResource InfoPillBadgeStyle}"
                                Visibility="{Binding IsModePassword, Converter={StaticResource BoolToVis}}"
                                Command="{Binding OpenHelpCommand}" CommandParameter="help.text.password" />
                    </Grid>
                </Grid>
                <Grid Grid.Column="3">
                    <Button Command="{Binding SetModeScriptCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModeScript}" Value="True">
                                        <Setter Property="Opacity"         Value="1" />
                                        <Setter Property="FontWeight"      Value="SemiBold" />
                                        <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                        <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="BorderThickness" Value="0.7" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconScript}"
                                  Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                  StrokeThickness="1.1" Stretch="Uniform" Width="13" Height="13"
                                  VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="{Binding ModeScriptLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                          Style="{StaticResource HoverGateStyle}">
                        <Button Style="{StaticResource InfoPillBadgeStyle}"
                                Visibility="{Binding IsModeScript, Converter={StaticResource BoolToVis}}"
                                Command="{Binding OpenHelpCommand}" CommandParameter="help.text.script" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ══ Content area ═════════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="8,8,8,0">

                <!-- ── UNICODE CONVERTER MODE ──────────────────────────────── -->
                <Grid Visibility="{Binding IsModeUnicode, Converter={StaticResource BoolToVis}}">
                <Border BorderBrush="{DynamicResource WidgetBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="8"
                        Padding="12,10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="{Binding UnicodeInputLabel}"
                                   Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="1"
                                 x:Name="UnicodeInputBox"
                                 Style="{StaticResource MultilineInputStyle}"
                                 MinHeight="60" MaxHeight="150"
                                 TabIndex="0"
                                 Margin="0,0,0,8"
                                 Text="{Binding UnicodeInput, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="UnicodeInput_PreviewKeyDown" />
                        <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                            <Button Content="{Binding PreetiToUnicodeLabel}" Command="{Binding SetUnicodeDir0Command}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DirButton}">
                                        <Setter Property="Height" Value="28" />
                                        <Setter Property="Margin" Value="0,0,4,0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUnicodeDir0}" Value="True">
                                                <Setter Property="Background"  Value="{DynamicResource WidgetAccentBrush}" />
                                                <Setter Property="Foreground"  Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{Binding UnicodeToPreetiLabel}" Command="{Binding SetUnicodeDir1Command}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DirButton}">
                                        <Setter Property="Height" Value="28" />
                                        <Setter Property="Margin" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUnicodeDir1}" Value="True">
                                                <Setter Property="Background"  Value="{DynamicResource WidgetAccentBrush}" />
                                                <Setter Property="Foreground"  Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </WrapPanel>
                        <TextBlock Grid.Row="3"
                                   Text="{Binding UnicodeOutputLabel}"
                                   Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="4"
                                 Style="{StaticResource MultilineOutputStyle}"
                                 MinHeight="60"
                                 TabIndex="3"
                                 Text="{Binding UnicodeOutput, Mode=OneWay}"
                                 GotKeyboardFocus="OutputBox_GotKeyboardFocus"
                                 PreviewMouseDown="OutputBox_PreviewMouseDown" />

                        <!-- ── File conversion section ── -->
                        <Border Grid.Row="5"
                                Background="{DynamicResource WidgetInputBrush}"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,10,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{Binding FileSectionLabel}"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,6" />

                                <!-- File picker -->
                                <Grid Grid.Row="1" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource WidgetBackgroundBrush}"
                                            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                            BorderThickness="0.7"
                                            CornerRadius="6"
                                            Height="32"
                                            Padding="8,0">
                                        <TextBlock Text="{Binding UnicodeFileName}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="12" Opacity="0.7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <Button Grid.Column="2"
                                            Content="{Binding FileBrowseLabel}"
                                            Style="{StaticResource DirButton}"
                                            Height="32"
                                            Click="BrowseUnicodeFile_Click" />
                                </Grid>

                                <!-- Direction indicator (synced with combobox above) -->
                                <TextBlock Grid.Row="2" Margin="0,0,0,6"
                                           FontSize="12" Opacity="0.7"
                                           Foreground="{DynamicResource WidgetForegroundBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding PreetiToUnicodeLabel}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UnicodeFileUnicodeToPreeti}" Value="True">
                                                    <Setter Property="Text" Value="{Binding UnicodeToPreetiLabel}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Convert & Save -->
                                <Button Grid.Row="3"
                                        Style="{StaticResource AccentButton}"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding UnicodeFileCanConvert}"
                                        Command="{Binding ConvertUnicodeFileCommand}"
                                        Visibility="{Binding UnicodeFileIsConverting, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconUnicode}"
                                              Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.4"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,7,0" />
                                        <TextBlock Text="{Binding FileConvertLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Grid.Row="3"
                                           Text="{Binding FileConvertingLabel}"
                                           FontSize="12" Height="32" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           Opacity="0.6"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding UnicodeFileIsConverting, Converter={StaticResource BoolToVis}}" />

                                <!-- Status -->
                                <TextBlock Grid.Row="4"
                                           Text="{Binding UnicodeFileStatus}"
                                           FontSize="11" TextWrapping="Wrap"
                                           Margin="0,5,0,0"
                                           Visibility="{Binding UnicodeFileHasStatus, Converter={StaticResource BoolToVis}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetSuccessBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding UnicodeFileHasError}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource WidgetErrorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>
                    </ScrollViewer>
                </Border>
                </Grid>

                <!-- ── WORD TOOLS MODE ──────────────────────────────────────── -->
                <Grid Visibility="{Binding IsModeWord, Converter={StaticResource BoolToVis}}">
                <Border BorderBrush="{DynamicResource WidgetBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="8"
                        Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="{Binding WordInputLabel}"
                                   Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="1"
                                 x:Name="WordInputBox"
                                 Style="{StaticResource MultilineInputStyle}"
                                 MinHeight="60" MaxHeight="150"
                                 TabIndex="0"
                                 Margin="0,0,0,8"
                                 Text="{Binding WordInput, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- Stats row - compact single line -->
                        <Border Grid.Row="2"
                                Background="{DynamicResource WidgetInputBrush}"
                                CornerRadius="5"
                                Padding="8,6"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding WordCountLabel}" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding WordCount}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WidgetAccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <Border Grid.Column="1" Background="{DynamicResource WidgetDividerBrush}" Width="1" />
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CharCountLabel}" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding CharCount}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WidgetAccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                                <Border Grid.Column="3" Background="{DynamicResource WidgetDividerBrush}" Width="1" />
                                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding CharNoSpacesLabel}" Style="{StaticResource FieldLabel}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding CharCountNoSpaces}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WidgetAccentBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Case buttons -->
                        <WrapPanel Grid.Row="3" Margin="0,0,0,8">
                            <Button Content="{Binding CaseUpperLabel}"    Style="{StaticResource CaseButton}" Margin="0,0,4,4" Command="{Binding CaseUpperCommand}" />
                            <Button Content="{Binding CaseLowerLabel}"    Style="{StaticResource CaseButton}" Margin="0,0,4,4" Command="{Binding CaseLowerCommand}" />
                            <Button Content="{Binding CaseTitleLabel}"    Style="{StaticResource CaseButton}" Margin="0,0,4,4" Command="{Binding CaseTitleCommand}" />
                            <Button Content="{Binding CaseSentenceLabel}" Style="{StaticResource CaseButton}" Margin="0,0,4,4" Command="{Binding CaseSentenceCommand}" />
                            <Button Content="{Binding CaseSnakeLabel}"    Style="{StaticResource CaseButton}" Margin="0,0,4,4" Command="{Binding CaseSnakeCommand}" />
                            <Button Content="{Binding CaseCamelLabel}"    Style="{StaticResource CaseButton}" Margin="0,0,4,4" Command="{Binding CaseCamelCommand}" />
                        </WrapPanel>

                        <TextBlock Grid.Row="4"
                                   Text="{Binding WordOutputLabel}"
                                   Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="5"
                                 Style="{StaticResource MultilineOutputStyle}"
                                 Text="{Binding WordOutput, Mode=OneWay}"
                                 GotKeyboardFocus="OutputBox_GotKeyboardFocus"
                                 PreviewMouseDown="OutputBox_PreviewMouseDown" />
                    </Grid>
                </Border>
                </Grid>

                <!-- ── PASSWORD TOOLS MODE ──────────────────────────────────── -->
                <Grid Visibility="{Binding IsModePassword, Converter={StaticResource BoolToVis}}">
                <Border BorderBrush="{DynamicResource WidgetBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="8"
                        Padding="12,10">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False">
                    <StackPanel>

                        <!-- Length slider -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding PwLengthLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0" />
                            <Slider Grid.Column="1"
                                    Style="{DynamicResource IosSlider}"
                                    Minimum="8" Maximum="32"
                                    Value="{Binding PasswordLength, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2"
                                       Text="{Binding PasswordLength}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="11"
                                       VerticalAlignment="Center"
                                       Margin="6,0,0,0"
                                       TextAlignment="Left" />
                        </Grid>

                        <!-- Char set checkboxes -->
                        <WrapPanel Margin="0,0,0,14">
                            <CheckBox Content="{Binding PwUpperLabel}"   Style="{StaticResource WidgetCheckBox}" IsChecked="{Binding PwUpper,   Mode=TwoWay}" Margin="0,0,12,4" />
                            <CheckBox Content="{Binding PwLowerLabel}"   Style="{StaticResource WidgetCheckBox}" IsChecked="{Binding PwLower,   Mode=TwoWay}" Margin="0,0,12,4" />
                            <CheckBox Content="{Binding PwNumbersLabel}" Style="{StaticResource WidgetCheckBox}" IsChecked="{Binding PwNumbers, Mode=TwoWay}" Margin="0,0,12,4" />
                            <CheckBox Content="{Binding PwSymbolsLabel}" Style="{StaticResource WidgetCheckBox}" IsChecked="{Binding PwSymbols, Mode=TwoWay}" Margin="0,0,12,4" />
                            <CheckBox Content="{Binding PwNepaliLabel}"  Style="{StaticResource WidgetCheckBox}" IsChecked="{Binding PwNepali,  Mode=TwoWay}" Margin="0,0,0,4" />
                        </WrapPanel>

                        <!-- Generated password -->
                        <TextBox Style="{StaticResource MultilineOutputStyle}"
                                 MinHeight="60"
                                 Margin="0,0,0,8"
                                 AcceptsReturn="False"
                                 TextWrapping="Wrap"
                                 Text="{Binding GeneratedPassword, Mode=OneWay}"
                                 GotKeyboardFocus="OutputBox_GotKeyboardFocus"
                                 PreviewMouseDown="OutputBox_PreviewMouseDown" />

                        <Button Style="{StaticResource AccentButton}"
                                Margin="0,0,0,12"
                                Command="{Binding GeneratePasswordCommand}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconLock}"
                                      Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.4"
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,7,0" />
                                <TextBlock Text="{Binding PwGenerateLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Section divider -->
                        <Border Height="1"
                                Background="{DynamicResource WidgetDividerBrush}"
                                Margin="0,2,0,12" />

                        <!-- Strength checker -->
                        <TextBlock Text="{Binding PwCheckLabel}"
                                   Style="{StaticResource FieldLabel}" />
                        <TextBox Style="{StaticResource InputBoxStyle}"
                                 Margin="0,0,0,8"
                                 Text="{Binding StrengthInput, UpdateSourceTrigger=PropertyChanged}" />

                        <!-- Strength bar + label -->
                        <Grid Margin="0,0,0,6"
                              Visibility="{Binding HasStrengthInput, Converter={StaticResource BoolToVis}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ProgressBar Grid.Column="0"
                                         Style="{StaticResource StrengthBar}"
                                         Value="{Binding StrengthBarWidth, Mode=OneWay}"
                                         VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding StrengthLabel}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{DynamicResource WidgetSuccessBrush}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StrengthLevel}" Value="1">
                                                <Setter Property="Foreground" Value="{DynamicResource WidgetErrorBrush}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding StrengthLevel}" Value="2">
                                                <Setter Property="Foreground" Value="{DynamicResource WidgetHolidayBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <!-- Criteria checklist -->
                        <StackPanel Visibility="{Binding HasStrengthInput, Converter={StaticResource BoolToVis}}">
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock FontSize="10" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource WidgetSuccessBrush}" />
                                                <Setter Property="Text" Value="&#x2714;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CriteriaLength}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource WidgetErrorBrush}" />
                                                        <Setter Property="Text" Value="&#x2718;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding CriteriaLengthLabel}" Style="{StaticResource CriteriaLabel}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock FontSize="10" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource WidgetSuccessBrush}" />
                                                <Setter Property="Text" Value="&#x2714;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CriteriaUpper}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource WidgetErrorBrush}" />
                                                        <Setter Property="Text" Value="&#x2718;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding CriteriaUpperLabel}" Style="{StaticResource CriteriaLabel}" />
                                </StackPanel>
                            </Grid>
                            <Grid Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <TextBlock FontSize="10" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource WidgetSuccessBrush}" />
                                                <Setter Property="Text" Value="&#x2714;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CriteriaLower}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource WidgetErrorBrush}" />
                                                        <Setter Property="Text" Value="&#x2718;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding CriteriaLowerLabel}" Style="{StaticResource CriteriaLabel}" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock FontSize="10" VerticalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{DynamicResource WidgetSuccessBrush}" />
                                                <Setter Property="Text" Value="&#x2714;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding CriteriaNumber}" Value="False">
                                                        <Setter Property="Foreground" Value="{DynamicResource WidgetErrorBrush}" />
                                                        <Setter Property="Text" Value="&#x2718;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding CriteriaNumberLabel}" Style="{StaticResource CriteriaLabel}" />
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <TextBlock FontSize="10" VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetSuccessBrush}" />
                                            <Setter Property="Text" Value="&#x2714;" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding CriteriaSymbol}" Value="False">
                                                    <Setter Property="Foreground" Value="{DynamicResource WidgetErrorBrush}" />
                                                    <Setter Property="Text" Value="&#x2718;" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text="{Binding CriteriaSymbolLabel}" Style="{StaticResource CriteriaLabel}" />
                            </StackPanel>
                        </StackPanel>

                    </StackPanel>
                    </ScrollViewer>
                </Border>
                </Grid>

                <!-- ── SCRIPT CONVERTER MODE ────────────────────────────────────── -->
                <Grid Visibility="{Binding IsModeScript, Converter={StaticResource BoolToVis}}">
                <Border BorderBrush="{DynamicResource WidgetBorderBrush}"
                        BorderThickness="0.7"
                        CornerRadius="8"
                        Padding="12,10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0"
                                   Text="{Binding ScriptInputLabel}"
                                   Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="1"
                                 x:Name="ScriptInputBox"
                                 Style="{StaticResource MultilineInputStyle}"
                                 MinHeight="60" MaxHeight="150"
                                 TabIndex="0"
                                 Margin="0,0,0,8"
                                 Text="{Binding ScriptBoxA, UpdateSourceTrigger=PropertyChanged}"
                                 PreviewKeyDown="ScriptInput_PreviewKeyDown" />
                        <WrapPanel Grid.Row="2" Margin="0,0,0,8">
                            <Button Content="{Binding ScriptRomanToDevaLabel}" Command="{Binding SetScriptDir0Command}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DirButton}">
                                        <Setter Property="Height" Value="28" />
                                        <Setter Property="Margin" Value="0,0,4,0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScriptDir0}" Value="True">
                                                <Setter Property="Background"  Value="{DynamicResource WidgetAccentBrush}" />
                                                <Setter Property="Foreground"  Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="{Binding ScriptDevaToRomanLabel}" Command="{Binding SetScriptDir1Command}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DirButton}">
                                        <Setter Property="Height" Value="28" />
                                        <Setter Property="Margin" Value="0" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsScriptDir1}" Value="True">
                                                <Setter Property="Background"  Value="{DynamicResource WidgetAccentBrush}" />
                                                <Setter Property="Foreground"  Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                                <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </WrapPanel>
                        <TextBlock Grid.Row="3"
                                   Text="{Binding ScriptOutputLabel}"
                                   Style="{StaticResource FieldLabel}" />
                        <TextBox Grid.Row="4"
                                 Style="{StaticResource MultilineOutputStyle}"
                                 MinHeight="60"
                                 TabIndex="3"
                                 Text="{Binding ScriptBoxB, Mode=OneWay}"
                                 GotKeyboardFocus="OutputBox_GotKeyboardFocus"
                                 PreviewMouseDown="OutputBox_PreviewMouseDown" />

                        <!-- ── File conversion section ── -->
                        <Border Grid.Row="5"
                                Background="{DynamicResource WidgetInputBrush}"
                                CornerRadius="6"
                                Padding="10,8"
                                Margin="0,10,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0"
                                           Text="{Binding FileSectionLabel}"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,6" />

                                <!-- File picker -->
                                <Grid Grid.Row="1" Margin="0,0,0,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="6" />
                                        <ColumnDefinition Width="76" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{DynamicResource WidgetBackgroundBrush}"
                                            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                            BorderThickness="0.7"
                                            CornerRadius="6"
                                            Height="32"
                                            Padding="8,0">
                                        <TextBlock Text="{Binding ScriptFileName}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="12" Opacity="0.7"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Border>
                                    <Button Grid.Column="2"
                                            Content="{Binding FileBrowseLabel}"
                                            Style="{StaticResource DirButton}"
                                            Height="32"
                                            Click="BrowseScriptFile_Click" />
                                </Grid>

                                <!-- Direction indicator (synced with toggle above) -->
                                <TextBlock Grid.Row="2" Margin="0,0,0,6"
                                           FontSize="12" Opacity="0.7"
                                           Foreground="{DynamicResource WidgetForegroundBrush}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding ScriptRomanToDevaLabel}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ScriptFileDevaToRoman}" Value="True">
                                                    <Setter Property="Text" Value="{Binding ScriptDevaToRomanLabel}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Convert & Save -->
                                <Button Grid.Row="3"
                                        Style="{StaticResource AccentButton}"
                                        HorizontalAlignment="Stretch"
                                        IsEnabled="{Binding ScriptFileCanConvert}"
                                        Command="{Binding ConvertScriptFileCommand}"
                                        Visibility="{Binding ScriptFileIsConverting, Converter={StaticResource InverseBoolToVis}}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconScript}"
                                              Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.4"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,7,0" />
                                        <TextBlock Text="{Binding FileConvertLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <TextBlock Grid.Row="3"
                                           Text="{Binding FileConvertingLabel}"
                                           FontSize="12" Height="32" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           Opacity="0.6"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding ScriptFileIsConverting, Converter={StaticResource BoolToVis}}" />

                                <!-- Status -->
                                <TextBlock Grid.Row="4"
                                           Text="{Binding ScriptFileStatus}"
                                           FontSize="11" TextWrapping="Wrap"
                                           Margin="0,5,0,0"
                                           Visibility="{Binding ScriptFileHasStatus, Converter={StaticResource BoolToVis}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetSuccessBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding ScriptFileHasError}" Value="True">
                                                    <Setter Property="Foreground" Value="{DynamicResource WidgetErrorBrush}" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
                </Grid>

        </Grid>

    </Grid>
</UserControl>
