<Window x:Class="NepDateWidget.Views.NotificationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource WidgetForegroundBrush}"
        FontFamily="{DynamicResource WidgetFontFamily}"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Border Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetAccentBrush}"
            BorderThickness="0.7"
            CornerRadius="10"
            ClipToBounds="True"
            MinWidth="280" MaxWidth="340"
            Cursor="Hand"
            MouseLeftButtonDown="Body_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.25" ShadowDepth="3" Direction="270" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="14,10,14,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock x:Name="HeaderText"
                               Foreground="{DynamicResource WidgetAccentBrush}"
                               FontSize="11" FontWeight="SemiBold" />
                    <TextBlock x:Name="TitleText"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                    <TextBlock x:Name="TimeText"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="11" Opacity="0.6" />
                    <TextBlock x:Name="NotesText"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="11" Opacity="0.5"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="Wrap" MaxHeight="36" />
                </StackPanel>

                <Button x:Name="DismissButton" Grid.Column="1"
                        VerticalAlignment="Top"
                        Padding="8,4" FontSize="11" Cursor="Hand"
                        Click="DismissButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="0.8" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Auto-dismiss countdown bar -->
            <Border Grid.Row="1" Height="3" CornerRadius="0,0,10,10"
                    Background="{DynamicResource WidgetInputBrush}" ClipToBounds="True">
                <Border x:Name="CountdownBar"
                        Height="3" CornerRadius="0,0,10,10"
                        Background="{DynamicResource WidgetAccentBrush}"
                        HorizontalAlignment="Left"
                        RenderTransformOrigin="0,0.5" />
            </Border>
        </Grid>
    </Border>
</Window>
