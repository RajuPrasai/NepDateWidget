<UserControl x:Class="NepDateWidget.Views.MoreView"
             x:Name="RootMoreView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             xmlns:views="clr-namespace:NepDateWidget.Views"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             d:DataContext="{d:DesignInstance vm:MoreViewModel}"
             d:Width="380">

    <UserControl.Resources>
        <Style x:Key="SectionHeading" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>

        <Style x:Key="ItemCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource WidgetBackgroundBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="0.7" />
            <Setter Property="CornerRadius"    Value="6" />
            <Setter Property="Padding"         Value="10,8" />
            <Setter Property="Margin"          Value="0,0,0,4" />
        </Style>

        <Style x:Key="MItemBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,4" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid x:Name="Root">
                            <Border x:Name="BgLayer" Background="{TemplateBinding Background}" CornerRadius="4" />
                            <Border Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.40" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="MItemBtnDanger" TargetType="Button" BasedOn="{StaticResource MItemBtn}">
            <Setter Property="Background" Value="{DynamicResource WidgetErrorBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style x:Key="MItemBtnAccent" TargetType="Button" BasedOn="{StaticResource MItemBtn}">
            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Width" Value="Auto" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MItemBtnSecondary" TargetType="Button" BasedOn="{StaticResource MItemBtn}">
            <Setter Property="Background" Value="{DynamicResource WidgetInputBorderBrush}" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="Width" Value="Auto" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- Icon grid button: large square tile with icon + label below -->
        <Style x:Key="GridIconBtnStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderBrush"     Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Width"           Value="72" />
            <Setter Property="Margin"          Value="0,0,8,0" />
            <Setter Property="Padding"         Value="4,12,4,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Tile"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="12,12">
        <StackPanel MaxWidth="1024">

            <!-- ── Icon grid (home screen) ──────────────────────────── -->
            <StackPanel Visibility="{Binding IsGridVisible, Converter={StaticResource BoolToVis}}"
                        Margin="0,0,0,8">
                <!-- Essentials -->
                <Border Style="{StaticResource CardPanel}" Margin="0,0,0,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="{StaticResource IconPin}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                  StrokeThickness="1.2" Stretch="Uniform"
                                  Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding EssentialsHeadingLabel}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                        </StackPanel>
                        <WrapPanel>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="Documents"
                                    Style="{StaticResource GridIconBtnStyle}">
                                <Button.Content>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Background="{DynamicResource WidgetBackgroundBrush}"
                                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                                BorderThickness="0.8" CornerRadius="8" Padding="10"
                                                HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <Path Data="{StaticResource IconFiles}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="22" Height="22" />
                                        </Border>
                                        <TextBlock Text="{Binding DocsHeadingLabel}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="11" TextAlignment="Center"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="Notes"
                                    Style="{StaticResource GridIconBtnStyle}">
                                <Button.Content>
                                    <StackPanel HorizontalAlignment="Center">
                    <Border Background="{DynamicResource WidgetBackgroundBrush}"
                                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                                BorderThickness="0.8" CornerRadius="8" Padding="10"
                                                HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <Path Data="{StaticResource IconText}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="22" Height="22" />
                                        </Border>
                                        <TextBlock Text="{Binding NotesHeadingLabel}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="11" TextAlignment="Center"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="Reminders"
                                    Style="{StaticResource GridIconBtnStyle}">
                                <Button.Content>
                                    <StackPanel HorizontalAlignment="Center">
                    <Border Background="{DynamicResource WidgetBackgroundBrush}"
                                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                                BorderThickness="0.8" CornerRadius="8" Padding="10"
                                                HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <Path Data="{StaticResource IconBell}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="22" Height="22" />
                                        </Border>
                                        <TextBlock Text="{Binding RemindersHeadingLabel}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="11" TextAlignment="Center"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
                <!-- Tools -->
                <Border Style="{StaticResource CardPanel}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="{StaticResource IconDeviceIpadCog}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                  StrokeThickness="1.2" Stretch="Uniform"
                                  Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                            <TextBlock Text="{Binding ToolsHeadingLabel}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                        </StackPanel>
                        <WrapPanel>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="IdPhoto"
                                    Style="{StaticResource GridIconBtnStyle}">
                                <Button.Content>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Background="{DynamicResource WidgetBackgroundBrush}"
                                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                                BorderThickness="0.8" CornerRadius="8" Padding="10"
                                                HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <Path Data="{StaticResource IconIdPhoto}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="22" Height="22" />
                                        </Border>
                                        <TextBlock Text="{Binding IdPhotoNavLabel}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="11" TextAlignment="Center"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="ImageTools"
                                    Style="{StaticResource GridIconBtnStyle}">
                                <Button.Content>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Background="{DynamicResource WidgetBackgroundBrush}"
                                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                                BorderThickness="0.8" CornerRadius="8" Padding="10"
                                                HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <Path Data="{StaticResource IconImageTools}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="22" Height="22" />
                                        </Border>
                                        <TextBlock Text="{Binding ImageToolsNavLabel}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="11" TextAlignment="Center"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Command="{Binding NavigateToCommand}" CommandParameter="QrCode"
                                    Style="{StaticResource GridIconBtnStyle}">
                                <Button.Content>
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Background="{DynamicResource WidgetBackgroundBrush}"
                                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                                BorderThickness="0.8" CornerRadius="8" Padding="10"
                                                HorizontalAlignment="Center" Margin="0,0,0,5">
                                            <Path Data="{StaticResource IconQrCode}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="22" Height="22" />
                                        </Border>
                                        <TextBlock Text="{Binding QrCodeNavLabel}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="11" TextAlignment="Center"
                                                   HorizontalAlignment="Center" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- ── Back button (shown when a sub-view is active) ─────── -->
            <Border Visibility="{Binding IsGridVisible, Converter={StaticResource InverseBoolToVis}}"
                    Background="{DynamicResource WidgetInputBrush}"
                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                    BorderThickness="0.7" CornerRadius="7" Padding="3"
                    Margin="0,0,0,8">
                <!-- Accent pill (Border not Button - nested buttons need separate hit areas) -->
                <Border Background="{DynamicResource WidgetAccentBrush}"
                        CornerRadius="5" Height="28">
                    <!-- Transparent bg forces WPF hit-testing to cover the full grid area -->
                    <Grid Margin="4,0,2,0" Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="26" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="26" />
                        </Grid.ColumnDefinitions>

                        <!-- iOS-style bare chevron back button -->
                        <Button Grid.Column="0" Command="{Binding GoBackCommand}" VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding"         Value="4,4,4,4" />
                                    <Setter Property="Cursor"          Value="Hand" />
                                    <Setter Property="Opacity"         Value="0.7" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <Path Data="{StaticResource IconChevronLeft}"
                                  Stroke="{DynamicResource WidgetDayTodayTextBrush}"
                                  StrokeThickness="2" StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Stretch="Uniform" Width="14" Height="16" VerticalAlignment="Center" />
                        </Button>

                        <!-- Sub-view title - column width is fixed so it never shifts -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,5,0"
                                  Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.3"
                                  Fill="Transparent" Stretch="Uniform">
                                <Path.Style>
                                    <Style TargetType="Path">
                                        <Setter Property="Data" Value="{StaticResource IconNote}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSubViewReminders}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconBell}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSubViewDocuments}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconFiles}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSubViewIdPhoto}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconIdPhoto}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSubViewImageTools}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconImageTools}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsSubViewQrCode}" Value="True">
                                                <Setter Property="Data" Value="{StaticResource IconQrCode}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Path.Style>
                            </Path>
                            <TextBlock Text="{Binding CurrentSubViewTitle}"
                                       Foreground="{DynamicResource WidgetDayTodayTextBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>

                        <!-- Info badge - visible only when mouse is over the pill row -->
                        <Grid Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"
                              Margin="0,0,2,0" Style="{StaticResource HoverGateStyle}">
                            <Button Style="{StaticResource InfoPillBadgeStyle}"
                                    Command="{Binding OpenHelpCommand}"
                                    CommandParameter="{Binding CurrentSubViewHelpKey}" />
                        </Grid>
                    </Grid>
                </Border>
            </Border>

            <!-- ── Notes Section ──────────────────────────────────────── -->
            <StackPanel Visibility="{Binding IsSubViewNotes, Converter={StaticResource BoolToVis}}">
                    <!-- Search bar + Add button in same row -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="{DynamicResource WidgetBackgroundBrush}"
                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                BorderThickness="0.8" CornerRadius="6" Height="34">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="{StaticResource IconScan}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}"
                                      StrokeThickness="1.1" Stretch="Uniform"
                                      Width="13" Height="13" Opacity="0.4"
                                      VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding NoteSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputBoxStyle}"
                                         Tag="{Binding NoteSearchHintLabel}"
                                         Background="Transparent" BorderThickness="0"
                                         Height="34" VerticalAlignment="Center">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Escape" Command="{Binding ClearNoteSearchCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="2"
                                        Command="{Binding ClearNoteSearchCommand}"
                                        Visibility="{Binding NoteSearchClearVisible, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,6,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background"      Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Padding"         Value="3,3" />
                                            <Setter Property="Cursor"          Value="Hand" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <Path Data="{StaticResource IconWindowClose}"
                                          Stroke="{DynamicResource WidgetForegroundBrush}"
                                          StrokeThickness="1.5" Stretch="Uniform"
                                          Width="9" Height="9" />
                                </Button>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" Style="{StaticResource AccentButton}"
                                Command="{Binding AddNoteCommand}"
                                Margin="6,0,0,0"
                                Visibility="{Binding IsNoteFormOpen, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPlus}"
                                      Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding AddNoteLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Add / Edit inline form -->
                    <Border Visibility="{Binding IsNoteFormOpen, Converter={StaticResource BoolToVis}}"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                            BorderThickness="0.7"
                            CornerRadius="7" Padding="12,12" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Path Data="{StaticResource IconNote}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.2"
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding NoteFormTitleLabel}"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Date field -->
                            <TextBlock Text="{Binding NoteFieldDateLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="NoteFormFirstInput"
                                     Text="{Binding NoteFormDateInput, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Height="34"
                                     Tag="{Binding NoteDateFormatHintLabel}"
                                     Margin="0,0,0,10" />

                            <!-- Note text -->
                            <TextBlock Text="{Binding NoteFieldTextLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,0,0,4" />
                            <TextBox Text="{Binding NoteFormText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MultilineInputStyle}"
                                     Tag="Write your note here..."
                                     Height="70" AcceptsReturn="True" TextWrapping="Wrap"
                                     Margin="0,0,0,10" />

                            <!-- Validation error -->
                            <TextBlock Text="{Binding NoteFormError}"
                                       Foreground="{DynamicResource WidgetErrorBrush}"
                                       FontSize="11" Margin="0,0,0,4"
                                       Visibility="{Binding HasNoteFormError, Converter={StaticResource BoolToVis}}" />

                            <!-- Form actions -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelNoteFormCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconWindowClose}"
                                              Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.3"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding CancelLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource AccentButton}"
                                        Command="{Binding SaveNoteFormCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconCheck}"
                                              Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.4"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding SaveLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,10"
                                Visibility="{Binding ShowNoteEmpty, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding NoNotesLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   Opacity="0.5" FontSize="13" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding NoNotesHintLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   Opacity="0.35" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                   TextWrapping="Wrap" MaxWidth="240" TextAlignment="Center" />
                    </StackPanel>

                    <!-- No search results -->
                    <TextBlock Text="{Binding NoNoteResultsLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               Opacity="0.5" FontSize="13" HorizontalAlignment="Center" Margin="0,10"
                               Visibility="{Binding ShowNoteNoResults, Converter={StaticResource BoolToVis}}" />

                    <!-- Notes list -->
                    <ItemsControl ItemsSource="{Binding FilteredNotes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:NoteItemViewModel}">
                                <Border Style="{StaticResource ItemCard}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayDate}"
                                                       Foreground="{DynamicResource WidgetAccentBrush}"
                                                       FontSize="11" Opacity="0.8" />
                                            <TextBlock Text="{Binding Text}"
                                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                                       FontSize="13" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource MItemBtn}" Margin="4,0,0,0"
                                                Command="{Binding DataContext.StartEditNoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding DateKey}">
                                            <Path Data="{StaticResource IconEdit}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="12" Height="12" />
                                        </Button>
                                        <Button Grid.Column="2" Style="{StaticResource MItemBtn}" Margin="4,0,0,0"
                                                Command="{Binding DataContext.DeleteNoteCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding DateKey}">
                                            <Path Data="{StaticResource IconTrash}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="12" Height="12" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
            </StackPanel>

            <!-- ── Reminders Section ──────────────────────────────────── -->
            <StackPanel Visibility="{Binding IsSubViewReminders, Converter={StaticResource BoolToVis}}">
                    <!-- Search bar + Add button in same row -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="{DynamicResource WidgetBackgroundBrush}"
                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                BorderThickness="0.8" CornerRadius="6" Height="34">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Path Grid.Column="0" Data="{StaticResource IconScan}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}"
                                      StrokeThickness="1.1" Stretch="Uniform"
                                      Width="13" Height="13" Opacity="0.4"
                                      VerticalAlignment="Center" Margin="8,0,4,0" />
                                <TextBox Grid.Column="1"
                                         Text="{Binding ReminderSearchText, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputBoxStyle}"
                                         Tag="{Binding ReminderSearchHintLabel}"
                                         Background="Transparent" BorderThickness="0"
                                         Height="34" VerticalAlignment="Center">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Escape" Command="{Binding ClearReminderSearchCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="2"
                                        Command="{Binding ClearReminderSearchCommand}"
                                        Visibility="{Binding ReminderSearchClearVisible, Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,6,0">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background"      Value="Transparent" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Padding"         Value="3,3" />
                                            <Setter Property="Cursor"          Value="Hand" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers />
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </Button.Style>
                                    <Path Data="{StaticResource IconWindowClose}"
                                          Stroke="{DynamicResource WidgetForegroundBrush}"
                                          StrokeThickness="1.5" Stretch="Uniform"
                                          Width="9" Height="9" />
                                </Button>
                            </Grid>
                        </Border>
                        <Button Grid.Column="1" Style="{StaticResource AccentButton}"
                                Command="{Binding AddNewReminderCommand}"
                                Margin="6,0,0,0"
                                Visibility="{Binding IsReminderFormOpen, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPlus}"
                                      Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding AddReminderLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Toggle show/hide completed reminders -->
                    <Button HorizontalAlignment="Right"
                            Margin="0,0,0,10"
                            Command="{Binding ToggleShowCompletedCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Visibility="{Binding HasCompletedReminders, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconCheck}"
                                  Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.3"
                                  Fill="Transparent" Stretch="Uniform"
                                  Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0" />
                            <TextBlock Text="{Binding ToggleCompletedLabel}" FontSize="11" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Add / Edit inline form -->
                    <Border Visibility="{Binding IsReminderFormOpen, Converter={StaticResource BoolToVis}}"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                            BorderThickness="0.7"
                            CornerRadius="7" Padding="12,12" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Path Data="{StaticResource IconBell}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.2"
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding ReminderFormTitleLabel}"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Title -->
                            <TextBlock Text="{Binding ReminderFieldTitleLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,0,0,4" />
                            <TextBox x:Name="ReminderFormFirstInput"
                                     Text="{Binding ReminderFormTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Height="34"
                                     Tag="{Binding HintReminderTitle}"
                                     Margin="0,0,0,2" />
                            <TextBlock Text="{Binding ReminderTitleError}"
                                       Foreground="{DynamicResource WidgetErrorBrush}"
                                       FontSize="11" Margin="0,0,0,8"
                                       Visibility="{Binding HasReminderTitleError, Converter={StaticResource BoolToVis}}" />

                            <!-- Date + Time in same row -->
                            <Grid Margin="0,8,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <!-- Date -->
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ReminderFieldDateLabel}"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,4" />
                                    <TextBox Text="{Binding ReminderFormDate, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputBoxStyle}"
                                             Height="34"
                                             Tag="{Binding HintReminderDate}" />
                                    <TextBlock Text="{Binding ReminderDateError}"
                                               Foreground="{DynamicResource WidgetErrorBrush}"
                                               FontSize="11" Margin="0,2,0,0"
                                               Visibility="{Binding HasReminderDateError, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                                <!-- Time -->
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="{Binding ReminderFieldTimeLabel}"
                                               Style="{StaticResource FieldLabel}"
                                               Margin="0,0,0,4" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox Grid.Column="0"
                                                 Text="{Binding ReminderFormTime, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource InputBoxStyle}"
                                                 Height="34"
                                                 Tag="{Binding HintReminderTime}"
                                                 Margin="0,0,4,0" />
                                        <!-- Single AM/PM toggle -->
                                        <Button Grid.Column="1"
                                                Command="{Binding ToggleReminderAmPmCommand}"
                                                Height="34" Width="48"
                                                Style="{StaticResource AccentButton}">
                                            <TextBlock Text="{Binding ReminderAmPmLabel}"
                                                       FontSize="12" FontWeight="SemiBold" />
                                        </Button>
                                    </Grid>
                                    <TextBlock Text="{Binding ReminderTimeError}"
                                               Foreground="{DynamicResource WidgetErrorBrush}"
                                               FontSize="11" Margin="0,2,0,0"
                                               Visibility="{Binding HasReminderTimeError, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Grid>

                            <!-- Recurrence -->
                            <TextBlock Text="{Binding ReminderFieldRecurLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,0,0,4" />
                            <ComboBox ItemsSource="{Binding ReminderRecurrenceOptions}"
                                      SelectedIndex="{Binding ReminderFormRecurrenceIndex}"
                                      Style="{StaticResource CompactComboBoxStyle}"
                                      Margin="0,0,0,10" />

                            <!-- End Date (only shown when recurrence is set) -->
                            <StackPanel Visibility="{Binding ShowReminderEndDate, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding ReminderFieldEndDateLabel}"
                                           Style="{StaticResource FieldLabel}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding ReminderFormEndDate, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource InputBoxStyle}"
                                         Height="34"
                                         Tag="{Binding HintReminderDate}"
                                         Margin="0,0,0,2" />
                                <TextBlock Text="{Binding ReminderEndDateError}"
                                           Foreground="{DynamicResource WidgetErrorBrush}"
                                           FontSize="11" Margin="0,0,0,8"
                                           Visibility="{Binding HasReminderEndDateError, Converter={StaticResource BoolToVis}}" />
                            </StackPanel>

                            <!-- Notes -->
                            <TextBlock Text="{Binding ReminderFieldNotesLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,0,0,4" />
                            <TextBox Text="{Binding ReminderFormNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MultilineInputStyle}"
                                     Tag="{Binding HintReminderNotes}"
                                     Height="50" AcceptsReturn="True" TextWrapping="Wrap"
                                     Margin="0,0,0,2" />
                            <TextBlock Text="{Binding ReminderFormNotesLength, StringFormat={}{0} / 500}"
                                       HorizontalAlignment="Right"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.4"
                                       Margin="0,0,0,6" />

                            <!-- Form actions -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelReminderFormCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconWindowClose}"
                                              Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.3"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding CancelLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource AccentButton}"
                                        Command="{Binding SaveReminderFormCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconCheck}"
                                              Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.4"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding SaveLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,10"
                                Visibility="{Binding ShowReminderEmpty, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding NoRemindersLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   Opacity="0.5" FontSize="13" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding NoRemindersHintLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   Opacity="0.35" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                   TextWrapping="Wrap" MaxWidth="240" TextAlignment="Center" />
                    </StackPanel>

                    <!-- No search results -->
                    <TextBlock Text="{Binding NoReminderResultsLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               Opacity="0.5" FontSize="13" HorizontalAlignment="Center" Margin="0,10"
                               Visibility="{Binding ShowReminderNoResults, Converter={StaticResource BoolToVis}}" />

                    <!-- Reminders list -->
                    <ItemsControl ItemsSource="{Binding FilteredReminders}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:ReminderItemViewModel}">
                                <Border>
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource ItemCard}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                                                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                                                    <Setter Property="BorderThickness" Value="1.5" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding Date}"
                                                           Foreground="{DynamicResource WidgetAccentBrush}"
                                                           FontSize="11" />
                                                <TextBlock Text="{Binding Time}"
                                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                                           Opacity="0.6" FontSize="11" Margin="6,0,0,0" />
                                                <TextBlock Text="{Binding RecurrenceText}"
                                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                                           Opacity="0.5" FontSize="11" Margin="6,0,0,0" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Notes}"
                                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                                       Opacity="0.5" FontSize="12"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="260" HorizontalAlignment="Left"
                                                       Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}" />
                                        </StackPanel>
                                        <Button Grid.Column="1" Style="{StaticResource MItemBtn}" Margin="4,0,0,0"
                                                Command="{Binding DataContext.EditReminderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"
                                                Visibility="{Binding IsCompleted, Converter={StaticResource InverseBoolToVis}}">
                                            <Path Data="{StaticResource IconEdit}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="12" Height="12" />
                                        </Button>
                                        <Button Grid.Column="2" Style="{StaticResource MItemBtn}" Margin="4,0,0,0"
                                                Command="{Binding DataContext.DeleteReminderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}">
                                            <Path Data="{StaticResource IconTrash}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.2" Stretch="Uniform"
                                                  Width="12" Height="12" />
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
            </StackPanel>

            <!-- ── Documents Section ─────────────────────────────────── -->
            <StackPanel Visibility="{Binding IsSubViewDocuments, Converter={StaticResource BoolToVis}}">

                    <!-- Search bar + Add button in same row -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Search bar -->
                        <Grid Grid.Column="0">
                            <Border x:Name="DocSearchBorder"
                                    Background="{DynamicResource WidgetBackgroundBrush}"
                                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                    BorderThickness="0.8" CornerRadius="6" Height="34">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Path Grid.Column="0" Data="{StaticResource IconScan}"
                                          Stroke="{DynamicResource WidgetForegroundBrush}"
                                          StrokeThickness="1.1" Stretch="Uniform"
                                          Width="13" Height="13" Opacity="0.4"
                                          VerticalAlignment="Center" Margin="8,0,4,0" />
                                    <TextBox x:Name="DocSearchBox"
                                             Grid.Column="1"
                                             Text="{Binding DocSearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource InputBoxStyle}"
                                             Tag="{Binding DocSearchHintLabel}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Height="34"
                                             VerticalAlignment="Center"
                                             GotFocus="SearchBox_GotFocus"
                                             LostFocus="SearchBox_LostFocus">
                                        <TextBox.InputBindings>
                                            <KeyBinding Key="Enter"  Command="{Binding CommitDocSearchCommand}" />
                                            <KeyBinding Key="Escape" Command="{Binding ClearDocSearchCommand}" />
                                        </TextBox.InputBindings>
                                    </TextBox>
                                    <Button Grid.Column="2"
                                            Command="{Binding ClearDocSearchCommand}"
                                            Visibility="{Binding DocSearchClearVisible, Converter={StaticResource BoolToVis}}"
                                            Margin="0,0,6,0">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background"      Value="Transparent" />
                                                <Setter Property="BorderThickness" Value="0" />
                                                <Setter Property="Padding"         Value="3,3" />
                                                <Setter Property="Cursor"          Value="Hand" />
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter />
                                                            </Border>
                                                            <ControlTemplate.Triggers />
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                        <Path Data="{StaticResource IconWindowClose}"
                                              Stroke="{DynamicResource WidgetForegroundBrush}"
                                              StrokeThickness="1.5" Stretch="Uniform"
                                              Width="9" Height="9" />
                                    </Button>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{Binding IsDocSuggestionsOpen}"
                                   PlacementTarget="{Binding ElementName=DocSearchBorder}"
                                   Placement="Bottom"
                                   StaysOpen="True"
                                   AllowsTransparency="True"
                                   Width="{Binding ActualWidth, ElementName=DocSearchBorder}">
                                <Border Background="{DynamicResource WidgetInputBrush}"
                                        BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                        BorderThickness="0.8" CornerRadius="0,0,5,5" Padding="3">
                                    <ItemsControl x:Name="DocSuggestionList"
                                                  ItemsSource="{Binding DocSearchSuggestions}"
                                                  MaxHeight="150">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding}"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Command="{Binding DataContext.SelectDocSuggestionCommand, ElementName=DocSuggestionList}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background"          Value="Transparent" />
                                                            <Setter Property="BorderThickness"     Value="0" />
                                                            <Setter Property="Foreground"          Value="{DynamicResource WidgetForegroundBrush}" />
                                                            <Setter Property="FontSize"            Value="12" />
                                                            <Setter Property="Padding"             Value="8,5" />
                                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                                            <Setter Property="Cursor"              Value="Hand" />
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                CornerRadius="4"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Popup>
                        </Grid>
                        <!-- Add button (hidden while form is open) -->
                        <Button Grid.Column="1" Style="{StaticResource AccentButton}"
                                Command="{Binding ShowAddDocumentCommand}"
                                Margin="6,0,0,0"
                                Visibility="{Binding IsDocFormOpen, Converter={StaticResource InverseBoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconPlus}"
                                      Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.5"
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding AddDocLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Add / Edit inline form -->
                    <Border Visibility="{Binding IsDocFormOpen, Converter={StaticResource BoolToVis}}"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                            BorderThickness="0.7"
                            CornerRadius="7" Padding="10,10" Margin="0,0,0,8">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                <Path Data="{StaticResource IconFiles}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.2"
                                      Fill="Transparent" Stretch="Uniform"
                                      Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                                <TextBlock Text="{Binding DocFormTitleLabel}"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- File (required) -->
                            <TextBlock Text="{Binding DocFieldFileLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,0,0,2" />
                            <Border x:Name="DocDropZone"
                                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                    BorderThickness="0.8"
                                    CornerRadius="8"
                                    Margin="0,0,0,10"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="DocDropZone_MouseLeftButtonDown"
                                    MouseLeftButtonUp="DocDropZone_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                                        <Setter Property="Padding" Value="12,18" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
                                            </Trigger>
                                            <DataTrigger Binding="{Binding DocEditHasFile}" Value="True">
                                                <Setter Property="Padding" Value="10,8" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <!-- Empty state: no file selected -->
                                    <StackPanel HorizontalAlignment="Center"
                                                Visibility="{Binding DocEditHasFile, Converter={StaticResource InverseBoolToVis}}">
                                        <Path Data="{StaticResource IconDownload}"
                                              Stroke="{DynamicResource WidgetForegroundBrush}"
                                              StrokeThickness="1.7"
                                              StrokeLineJoin="Round"
                                              Stretch="Uniform"
                                              Width="28" Height="28"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,6"
                                              Opacity="0.45" />
                                        <TextBlock Text="{Binding DocDropLabel}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="13" HorizontalAlignment="Center" Opacity="0.7" />
                                        <TextBlock Text="{Binding DocBrowseLabel}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="11" HorizontalAlignment="Center" Opacity="0.45" Margin="0,2,0,0" />
                                    </StackPanel>

                                    <!-- Selected state: file chosen -->
                                    <Grid Visibility="{Binding DocEditHasFile, Converter={StaticResource BoolToVis}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0"
                                                Background="{DynamicResource WidgetAccentBrush}"
                                                CornerRadius="3" Padding="5,2" Margin="0,0,8,0"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DocEditFileExtension}"
                                                       Foreground="{DynamicResource WidgetDayTodayTextBrush}"
                                                       FontSize="10" FontWeight="SemiBold" />
                                        </Border>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DocEditFileName}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="12" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" />
                                        <Button Grid.Column="2"
                                                Style="{StaticResource MItemBtn}"
                                                Command="{Binding ClearDocumentFileCommand}"
                                                ToolTip="{Binding DocClearFileLabel}"
                                                Margin="8,0,0,0">
                                            <Path Data="{StaticResource IconWindowClose}"
                                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                                  StrokeThickness="1.5" Stretch="Uniform"
                                                  Width="9" Height="9" />
                                        </Button>
                                    </Grid>
                                </Grid>
                            </Border>

                            <!-- Title -->
                            <Grid Margin="0,0,0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DocFieldTitleLabel}"
                                           Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center" />
                                <ItemsControl Grid.Column="1"
                                              ItemsSource="{Binding DocTitlePresets}"
                                              HorizontalAlignment="Right">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Command="{Binding DataContext.SetDocTitlePresetCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand" Margin="0,0,3,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background"      Value="{DynamicResource WidgetBackgroundBrush}" />
                                                        <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
                                                        <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
                                                        <Setter Property="BorderThickness" Value="0.7" />
                                                        <Setter Property="FontSize"        Value="10.5" />
                                                        <Setter Property="Padding"         Value="6,2" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="4"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <TextBox Text="{Binding DocEditTitle, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Height="34"
                                     Tag="e.g. Citizenship Front, Passport..."
                                     Margin="0,0,0,8" />

                            <!-- Tags -->
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="{Binding DocFieldTagsLabel}"
                                           Style="{StaticResource FieldLabel}"
                                           VerticalAlignment="Center" />
                                <ItemsControl Grid.Column="1"
                                              ItemsSource="{Binding DocTagPresets}"
                                              HorizontalAlignment="Right">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel HorizontalAlignment="Right" /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding}"
                                                    Command="{Binding DataContext.AddDocTagPresetCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Cursor="Hand" Margin="0,0,3,0">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrushLight}" />
                                                        <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
                                                        <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
                                                        <Setter Property="BorderThickness" Value="0.7" />
                                                        <Setter Property="FontSize"        Value="10.5" />
                                                        <Setter Property="Padding"         Value="6,2" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <Border Background="{TemplateBinding Background}"
                                                                            BorderBrush="{TemplateBinding BorderBrush}"
                                                                            BorderThickness="{TemplateBinding BorderThickness}"
                                                                            CornerRadius="10"
                                                                            Padding="{TemplateBinding Padding}">
                                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                    </Border>
                                                                    <ControlTemplate.Triggers>
                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                            <Setter Property="Opacity" Value="0.78" />
                                                                        </Trigger>
                                                                    </ControlTemplate.Triggers>
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <!-- Selected tag chips -->
                            <ItemsControl ItemsSource="{Binding DocEditTags}" Margin="0,0,0,4">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource WidgetAccentBrush}"
                                                CornerRadius="10" Padding="7,2" Margin="0,0,4,3">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding StringFormat='#{0}'}"
                                                           Foreground="{DynamicResource WidgetDayTodayTextBrush}"
                                                           FontSize="11" VerticalAlignment="Center" />
                                                <Button Command="{Binding DataContext.RemoveDocTagCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="4,0,0,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background"      Value="Transparent" />
                                                            <Setter Property="BorderThickness" Value="0" />
                                                            <Setter Property="Padding"         Value="0" />
                                                            <Setter Property="Cursor"          Value="Hand" />
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <ContentPresenter />
                                                                        <ControlTemplate.Triggers />
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                    <Path Data="{StaticResource IconWindowClose}"
                                                          Stroke="{DynamicResource WidgetDayTodayTextBrush}"
                                                          StrokeThickness="1.3" Stretch="Uniform"
                                                          Width="8" Height="8" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Custom tag input -->
                            <TextBox Text="{Binding DocEditTagInput, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Height="34"
                                     Tag="Custom tag... (Enter or comma to add)"
                                     Margin="0,0,0,8">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding AddDocTagFromInputCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>

                            <!-- Notes (optional) -->
                            <TextBlock Text="{Binding DocFieldNotesLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       Margin="0,0,0,2" />
                            <TextBox Text="{Binding DocEditNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource MultilineInputStyle}"
                                     Tag="Optional notes about this document..."
                                     Height="46" Margin="0,0,0,8" />

                            <!-- Validation error -->
                            <TextBlock Text="{Binding DocEditError}"
                                       Foreground="{DynamicResource WidgetErrorBrush}"
                                       FontSize="11" Margin="0,0,0,4"
                                       Visibility="{Binding HasDocEditError, Converter={StaticResource BoolToVis}}" />

                            <!-- Form actions -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Style="{StaticResource SecondaryButton}"
                                        Command="{Binding CancelDocumentEditCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconWindowClose}"
                                              Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.3"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding CancelLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                                <Button Grid.Column="2" Style="{StaticResource AccentButton}"
                                        Command="{Binding SaveDocumentCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <Path Data="{StaticResource IconCheck}"
                                              Stroke="{DynamicResource WidgetDayTodayTextBrush}" StrokeThickness="1.4"
                                              Fill="Transparent" Stretch="Uniform"
                                              Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,5,0" />
                                        <TextBlock Text="{Binding SaveLabel}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Empty state: no documents -->
                    <StackPanel HorizontalAlignment="Center" Margin="0,10"
                                Visibility="{Binding ShowDocEmpty, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="{Binding NoDocsLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   Opacity="0.5" FontSize="13" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding NoDocsHintLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   Opacity="0.35" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,2,0,0"
                                   TextWrapping="Wrap" MaxWidth="240" TextAlignment="Center" />
                    </StackPanel>

                    <!-- Empty state: search no results -->
                    <TextBlock Text="{Binding NoDocsResultsLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               Opacity="0.5" FontSize="13" HorizontalAlignment="Center" Margin="0,10"
                               Visibility="{Binding ShowDocNoResults, Converter={StaticResource BoolToVis}}" />

                    <!-- Documents list -->
                    <ItemsControl ItemsSource="{Binding FilteredDocuments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DocItemViewModel}">
                                <Border Style="{StaticResource ItemCard}">
                                    <StackPanel>
                                        <!-- Title + ext badge + hover-revealed action buttons -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Title}"
                                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="180"
                                                       VerticalAlignment="Center" />
                                            <!-- Extension badge - always visible, click to reveal in Explorer -->
                                            <Button Grid.Column="1" Margin="4,0,0,0"
                                                    Visibility="{Binding HasFile, Converter={StaticResource BoolToVis}}"
                                                    Command="{Binding DataContext.OpenDocumentFolderCommand,
                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"
                                                    VerticalAlignment="Center">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Setter Property="Background"      Value="Transparent" />
                                                        <Setter Property="BorderThickness" Value="0" />
                                                        <Setter Property="Padding"         Value="0" />
                                                        <Setter Property="Cursor"          Value="Hand" />
                                                        <Setter Property="Template">
                                                            <Setter.Value>
                                                                <ControlTemplate TargetType="Button">
                                                                    <ContentPresenter />
                                                                    <ControlTemplate.Triggers />
                                                                </ControlTemplate>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Style>
                                                </Button.Style>
                                                <Border Background="{DynamicResource WidgetAccentBrush}"
                                                        CornerRadius="3" Padding="5,2">
                                                    <TextBlock Text="{Binding FileExtension}"
                                                               Foreground="{DynamicResource WidgetDayTodayTextBrush}"
                                                               FontSize="10" FontWeight="SemiBold" />
                                                </Border>
                                            </Button>
                                            <!-- Action buttons -->
                                            <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Style="{StaticResource MItemBtn}"
                                                        Margin="4,0,0,0"
                                                        IsEnabled="{Binding FileExists}"
                                                        ToolTip="{Binding DataContext.DocOpenLabel,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        Command="{Binding DataContext.OpenDocumentCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <Path Data="{StaticResource IconExternalLink}"
                                                          Stroke="{DynamicResource WidgetForegroundBrush}"
                                                          StrokeThickness="1.2" Stretch="Uniform"
                                                          Width="12" Height="12" />
                                                </Button>
                                                <Button Style="{StaticResource MItemBtn}"
                                                        Margin="4,0,0,0"
                                                        Command="{Binding DataContext.EditDocumentCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <Path Data="{StaticResource IconEdit}"
                                                          Stroke="{DynamicResource WidgetForegroundBrush}"
                                                          StrokeThickness="1.2" Stretch="Uniform"
                                                          Width="12" Height="12" />
                                                </Button>
                                                <Button Style="{StaticResource MItemBtn}"
                                                        Margin="4,0,0,0"
                                                        Command="{Binding DataContext.DeleteDocumentCommand,
                                                                  RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <Path Data="{StaticResource IconTrash}"
                                                          Stroke="{DynamicResource WidgetForegroundBrush}"
                                                          StrokeThickness="1.2" Stretch="Uniform"
                                                          Width="12" Height="12" />
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Row 2: Tag chips -->
                                        <ItemsControl ItemsSource="{Binding Tags}"
                                                      Margin="0,3,0,0"
                                                      Visibility="{Binding HasTags, Converter={StaticResource BoolToVis}}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource WidgetTagBrush}"
                                                            CornerRadius="10" Padding="5,1" Margin="0,0,3,2">
                                                        <TextBlock Text="{Binding StringFormat='#{0}'}"
                                                                   Foreground="{DynamicResource WidgetAccentBrush}"
                                                                   FontSize="10" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- File not found warning -->
                                        <TextBlock Text="{Binding DataContext.DocFileNotFoundLabel,
                                                   RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   Foreground="{DynamicResource WidgetErrorBrush}"
                                                   FontSize="11" Margin="0,3,0,0"
                                                   Visibility="{Binding FileNotFound, Converter={StaticResource BoolToVis}}" />

                                        <!-- Notes -->
                                        <TextBlock Text="{Binding Notes}"
                                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                                   FontSize="12.5" Margin="0,5,0,0"
                                                   TextWrapping="Wrap"
                                                   Visibility="{Binding HasNotes, Converter={StaticResource BoolToVis}}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

            </StackPanel>

            <!-- ── ID Photo Sub-view ──────────────────────────────────── -->
            <Border Background="{DynamicResource WidgetBackgroundBrush}"
                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                    BorderThickness="0.8" CornerRadius="8" Padding="12,10" Margin="0,0,0,4"
                    Visibility="{Binding DataContext.IsSubViewIdPhoto,
                                 ElementName=RootMoreView,
                                 Converter={StaticResource BoolToVis},
                                 FallbackValue=Collapsed}">
                <views:IdPhotoView DataContext="{Binding IdPhoto}" />
            </Border>

            <!-- ── Image Tools Sub-view ──────────────────────────────── -->
            <Border Background="{DynamicResource WidgetBackgroundBrush}"
                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                    BorderThickness="0.8" CornerRadius="8" Padding="12,10" Margin="0,0,0,4"
                    Visibility="{Binding DataContext.IsSubViewImageTools,
                                 ElementName=RootMoreView,
                                 Converter={StaticResource BoolToVis},
                                 FallbackValue=Collapsed}">
                <views:ImageToolsView DataContext="{Binding DataContext.ImageTools, ElementName=RootMoreView}" />
            </Border>

            <!-- ── QR Code Sub-view ───────────────────────────────────── -->
            <Border Background="{DynamicResource WidgetBackgroundBrush}"
                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                    BorderThickness="0.8" CornerRadius="8" Padding="12,10" Margin="0,0,0,4"
                    Visibility="{Binding DataContext.IsSubViewQrCode,
                                 ElementName=RootMoreView,
                                 Converter={StaticResource BoolToVis},
                                 FallbackValue=Collapsed}">
                <views:QrCodeView DataContext="{Binding QrCode}" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
