<UserControl x:Class="NepDateWidget.Views.BankingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             xmlns:cvt="clr-namespace:NepDateWidget.Converters"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             d:DataContext="{d:DesignInstance vm:BankingViewModel}"
             d:Width="380">

    <UserControl.Resources>
        <cvt:BoolToVisibilityConverter x:Key="BoolToVis"        Invert="False" />
        <cvt:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"  />

        <Style x:Key="PillButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderBrush"     Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Height"          Value="28" />
            <Setter Property="Padding"         Value="14,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Opacity"         Value="0.55" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
                    <Setter Property="Opacity" Value="0.9" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DirButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="0.7" />
            <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Height"          Value="36" />
            <Setter Property="Padding"         Value="8,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.82" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="Stop">
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
            <Setter Property="BorderThickness" Value="0.7" />
            <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="Height"          Value="36" />
            <Setter Property="Padding"         Value="8,0" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.68" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">

        <StackPanel Margin="8,4,8,0"
                    MaxWidth="1024">

        <!-- Mode selector: Interest | EMI -->
        <Border Background="{DynamicResource WidgetInputBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.7"
                CornerRadius="7"
                Padding="3"
                Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Command="{Binding SetModeInterestCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsModeInterest}" Value="True">
                                    <Setter Property="Opacity"         Value="1" />
                                    <Setter Property="FontWeight"      Value="SemiBold" />
                                    <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                    <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="BorderThickness" Value="0.7" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconCalculator}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.1" Stretch="Uniform" Width="13" Height="13"
                              VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding ModeInterestLabel}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="1" Command="{Binding SetModeEmiCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsModeEmi}" Value="True">
                                    <Setter Property="Opacity"         Value="1" />
                                    <Setter Property="FontWeight"      Value="SemiBold" />
                                    <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                    <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="BorderThickness" Value="0.7" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{StaticResource IconCalculator}"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.1" Stretch="Uniform" Width="13" Height="13"
                              VerticalAlignment="Center" Margin="0,0,5,0" />
                        <TextBlock Text="{Binding ModeEmiLabel}" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Card border -->
        <Border BorderBrush="{DynamicResource WidgetBorderBrush}"
                BorderThickness="0.7"
                CornerRadius="8"
                Padding="12,10">
        <StackPanel>

        <!-- ── INTEREST mode ────────────────────────────────────────────────── -->
        <StackPanel Visibility="{Binding IsModeInterest, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,4">

            <TextBlock Text="{Binding InterestPrincipalLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="11" Opacity="0.5" Margin="0,0,0,3" />
            <TextBox Text="{Binding InterestPrincipal, UpdateSourceTrigger=PropertyChanged}"
                     Tag="{Binding HintPrincipal}"
                     Style="{StaticResource InputBoxStyle}"
                     Margin="0,0,0,8" />

            <!-- From / To labels -->
            <Grid Margin="0,2,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"  />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*"  />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding InterestFromLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="11" Opacity="0.5" />
                <TextBlock Grid.Column="2" Text="{Binding InterestToLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="11" Opacity="0.5" />
            </Grid>

            <!-- From / BS-AD toggle / To -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"  />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="*"  />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding InterestFromDate, UpdateSourceTrigger=PropertyChanged}"
                         Tag="{Binding InterestDatePlaceholder}"
                         Style="{StaticResource InputBoxStyle}" />
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="4,0">
                    <Button Content="BS" Command="{Binding SetInterestBsCommand}" Width="38"
                            Margin="0,0,4,0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DirButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InterestUseBs}" Value="True">
                                        <Setter Property="Background"  Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="Foreground"  Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    <Button Content="AD" Command="{Binding SetInterestAdCommand}" Width="38">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource DirButton}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InterestUseBs}" Value="False">
                                        <Setter Property="Background"  Value="{DynamicResource WidgetAccentBrush}" />
                                        <Setter Property="Foreground"  Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                        <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
                <TextBox Grid.Column="2"
                         Text="{Binding InterestToDate, UpdateSourceTrigger=PropertyChanged}"
                         Tag="{Binding InterestDatePlaceholder}"
                         Style="{StaticResource InputBoxStyle}" />
            </Grid>

            <!-- Column headers for rate rows -->
            <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="90" />
                    <ColumnDefinition Width="32" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding InterestFromLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="11" Opacity="0.5" />
                <TextBlock Grid.Column="2" Text="{Binding InterestRateColLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="11" Opacity="0.5" />
            </Grid>

            <!-- Rate rows -->
            <ItemsControl ItemsSource="{Binding InterestRows}" Margin="0,0,0,6">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="28" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding FromDate, UpdateSourceTrigger=PropertyChanged}"
                                     IsReadOnly="{Binding IsFirstRow}"
                                     Tag="{Binding DataContext.HintDateBs, RelativeSource={RelativeSource AncestorType=UserControl}}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource InputBoxStyle}">
                                        <Style.Triggers>
                                            <Trigger Property="IsReadOnly" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                                                <Setter Property="Opacity"    Value="0.7" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TextBox Grid.Column="2"
                                     Text="{Binding Rate, UpdateSourceTrigger=PropertyChanged}"
                                     Tag="{Binding DataContext.HintRate, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                     Style="{StaticResource InputBoxStyle}" />
                            <Button Grid.Column="4"
                                    Command="{Binding RemoveCommand}"
                                    Content="−"
                                    Width="28" FontSize="16"
                                    Visibility="{Binding IsFirstRow, Converter={StaticResource InverseBoolToVis}}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DirButton}">
                                        <Setter Property="Padding" Value="0" />
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Add period button -->
            <Button Content="{Binding InterestAddLabel}"
                    Command="{Binding AddInterestRowCommand}"
                    HorizontalAlignment="Left"
                    Margin="0,0,0,10">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                        <Setter Property="Opacity" Value="0.8" />
                    </Style>
                </Button.Style>
            </Button>

            <!-- Calculate button -->
            <Button Content="{Binding InterestCalcLabel}"
                    Command="{Binding CalculateInterestCommand}"
                    Height="36" HorizontalAlignment="Stretch"
                    Margin="0,0,0,6"
                    Style="{StaticResource AccentButton}" />

            <!-- Error -->
            <TextBlock Text="{Binding InterestError}"
                       Foreground="{DynamicResource WidgetErrorBrush}"
                       FontSize="12" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Margin="0,0,0,4"
                       Visibility="{Binding InterestHasError, Converter={StaticResource BoolToVis}}" />

            <!-- Result panel -->
            <Border Padding="10" CornerRadius="6"
                    Background="{DynamicResource WidgetInputBrush}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Opacity"    Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding InterestHasResult}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0" To="1" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <TextBlock Text="{Binding InterestBreakdownText}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="12" TextWrapping="Wrap"
                               Margin="0,0,0,8" />
                    <Border Height="1" Background="{DynamicResource WidgetDividerBrush}"
                            Margin="0,0,0,8" />
                    <TextBlock Text="{Binding InterestTotalText}"
                               Foreground="{DynamicResource WidgetSuccessBrush}"
                               FontSize="13" FontWeight="SemiBold"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

        </StackPanel><!-- end INTEREST mode -->

        <!-- ── EMI mode ─────────────────────────────────────────────────────── -->
        <StackPanel Visibility="{Binding IsModeEmi, Converter={StaticResource BoolToVis}}"
                    Margin="0,0,0,4">

            <!-- Row 1: Loan Amount (left) + Start Date BS (right) -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding EmiLoanLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="11" Opacity="0.5" Margin="0,0,0,3" />
                    <TextBox Text="{Binding EmiLoanAmount, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{Binding HintLoan}"
                             Style="{StaticResource InputBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding EmiStartDateLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="11" Opacity="0.5" Margin="0,0,0,3" />
                    <TextBox Text="{Binding EmiStartDate, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{Binding HintDateBs}"
                             Style="{StaticResource InputBoxStyle}" />
                </StackPanel>
            </Grid>

            <!-- Annual Rate % and Months on the same row -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding EmiRateLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="11" Opacity="0.5" Margin="0,0,0,3" />
                    <TextBox Text="{Binding EmiAnnualRate, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{Binding HintRate}"
                             Style="{StaticResource InputBoxStyle}" />
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="{Binding EmiMonthsLabel}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="11" Opacity="0.5" Margin="0,0,0,3" />
                    <TextBox Text="{Binding EmiMonths, UpdateSourceTrigger=PropertyChanged}"
                             Tag="{Binding HintMonths}"
                             Style="{StaticResource InputBoxStyle}" />
                </StackPanel>
            </Grid>

            <!-- Calculate button -->
            <Button Content="{Binding EmiCalcLabel}"
                    Command="{Binding CalculateEmiCommand}"
                    Height="36" HorizontalAlignment="Stretch"
                    Margin="0,0,0,6"
                    Style="{StaticResource AccentButton}" />

            <!-- Error -->
            <TextBlock Text="{Binding EmiError}"
                       Foreground="{DynamicResource WidgetErrorBrush}"
                       FontSize="12" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Margin="0,0,0,4"
                       Visibility="{Binding EmiHasError, Converter={StaticResource BoolToVis}}" />

            <!-- Result panel -->
            <StackPanel>
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Setter Property="Opacity"    Value="0" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding EmiHasResult}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             From="0" To="1" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>

                <!-- Summary strip -->
                <Border Padding="10,8" CornerRadius="6"
                        Background="{DynamicResource WidgetInputBrush}"
                        Margin="0,0,0,6">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="{Binding EmiMonthlyLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding EmiMonthlyText}"
                                   Foreground="{DynamicResource WidgetSuccessBrush}"
                                   FontSize="14" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" />

                        <Border Grid.Row="1" Grid.ColumnSpan="2"
                                Height="1" Background="{DynamicResource WidgetDividerBrush}"
                                Margin="0,6" />

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                   Text="{Binding EmiTotalPaymentLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   FontSize="12" Opacity="0.7" VerticalAlignment="Center"
                                   Margin="0,0,0,4" />
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding EmiTotalPaymentText}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" Margin="0,0,0,4" />

                        <TextBlock Grid.Row="3" Grid.Column="0"
                                   Text="{Binding EmiTotalInterestLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   FontSize="12" Opacity="0.7" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="3" Grid.Column="1"
                                   Text="{Binding EmiTotalInterestText}"
                                   Foreground="{DynamicResource WidgetErrorBrush}"
                                   FontSize="12" FontWeight="SemiBold"
                                   HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <!-- Schedule table -->
                <Border CornerRadius="6"
                        Background="{DynamicResource WidgetInputBrush}"
                        Padding="0,0,0,4">
                    <StackPanel>
                        <Grid Margin="8,6,8,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="62" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding EmiColYearLabel}"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Grid.Column="1" Text="{Binding EmiColPrincipalLabel}"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Grid.Column="2" Text="{Binding EmiColInterestLabel}"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Grid.Column="3" Text="{Binding EmiColTotalLabel}"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Grid.Column="4" Text="{Binding EmiColBalanceLabel}"
                                       FontSize="11" FontWeight="SemiBold" Opacity="0.5"
                                       HorizontalAlignment="Right"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                        </Grid>

                        <Border Height="1" Background="{DynamicResource WidgetDividerBrush}"
                                Margin="8,0,8,2" />

                        <ItemsControl ItemsSource="{Binding EmiScheduleRows}" MaxHeight="220">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Button Visibility="{Binding IsYearRow, Converter={StaticResource BoolToVis}}"
                                                Command="{Binding DataContext.ToggleEmiYearCommand,
                                                          RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Background="Transparent" BorderThickness="0"
                                                Cursor="Hand" Padding="0">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="RowBd" Background="Transparent" Padding="8,4">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="62" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                <TextBlock Text="{Binding Period}"
                                                                           FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                                                           VerticalAlignment="Center" />
                                                                <Path Width="8" Height="8" Margin="4,0,0,0"
                                                                      Fill="{DynamicResource WidgetForegroundBrush}"
                                                                      Opacity="0.45" VerticalAlignment="Center">
                                                                    <Path.Style>
                                                                        <Style TargetType="Path">
                                                                            <Setter Property="Data" Value="M 0,0 L 4,4 L 8,0" />
                                                                            <Setter Property="Stretch" Value="Uniform" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                                                    <Setter Property="Data" Value="M 0,4 L 4,0 L 8,4" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Path.Style>
                                                                </Path>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding Principal}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right"
                                                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Interest}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right"
                                                                       Foreground="{DynamicResource WidgetErrorBrush}" />
                                                            <TextBlock Grid.Column="3" Text="{Binding TotalPayment}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right"
                                                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                                                            <TextBlock Grid.Column="4" Text="{Binding Balance}"
                                                                       FontSize="12" FontWeight="SemiBold"
                                                                       HorizontalAlignment="Right"
                                                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                                                        </Grid>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="RowBd" Property="Background"
                                                                    Value="{DynamicResource WidgetHoverBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Button.Template>
                                        </Button>

                                        <Border Visibility="{Binding IsYearRow, Converter={StaticResource InverseBoolToVis}}"
                                                Padding="8,3">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="62" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Margin="10,0,0,0">
                                                    <TextBlock Text="{Binding Period}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                                               Opacity="0.85" />
                                                    <TextBlock Text="{Binding BsDate}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource WidgetForegroundBrush}"
                                                               Opacity="0.45" />
                                                </StackPanel>
                                                <TextBlock Grid.Column="1" Text="{Binding Principal}"
                                                           FontSize="12" HorizontalAlignment="Right"
                                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                                           Opacity="0.85" />
                                                <TextBlock Grid.Column="2" Text="{Binding Interest}"
                                                           FontSize="12" HorizontalAlignment="Right"
                                                           Foreground="{DynamicResource WidgetErrorBrush}"
                                                           Opacity="0.75" />
                                                <TextBlock Grid.Column="3" Text="{Binding TotalPayment}"
                                                           FontSize="12" HorizontalAlignment="Right"
                                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                                           Opacity="0.85" />
                                                <TextBlock Grid.Column="4" Text="{Binding Balance}"
                                                           FontSize="12" HorizontalAlignment="Right"
                                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                                           Opacity="0.85" />
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel><!-- end EMI mode -->

        </StackPanel>
        </Border><!-- close card -->

        </StackPanel>
    </ScrollViewer>
</UserControl>
