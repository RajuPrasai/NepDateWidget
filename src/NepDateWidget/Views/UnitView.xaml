<UserControl x:Class="NepDateWidget.Views.UnitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             d:DataContext="{d:DesignInstance vm:UnitViewModel}"
             d:Width="380">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Focusable="False"
                  PanningMode="VerticalOnly">

        <StackPanel Margin="8,8,8,0"
                    MaxWidth="1024">

<!-- Mode selector: Area | Weight -->
            <Border Background="{DynamicResource WidgetInputBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.7"
                CornerRadius="7"
                Padding="3"
                Margin="0,0,0,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Button Command="{Binding SetModeAreaCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModeArea}" Value="True">
                                            <Setter Property="Opacity"         Value="1" />
                                            <Setter Property="FontWeight"      Value="SemiBold" />
                                            <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
                                            <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
                                            <Setter Property="BorderThickness" Value="0.7" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconArea}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.1" Stretch="Uniform" Width="13" Height="13"
                                      VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="{Binding ModeLabelArea}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                              Style="{StaticResource HoverGateStyle}">
                            <Button Style="{StaticResource InfoPillBadgeStyle}"
                                    Visibility="{Binding IsModeArea, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding OpenHelpCommand}" CommandParameter="help.unit.area" />
                        </Grid>
                    </Grid>

                    <Grid Grid.Column="1">
                        <Button Command="{Binding SetModeWeightCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PillButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsModeWeight}" Value="True">
                                            <Setter Property="Opacity"         Value="1" />
                                            <Setter Property="FontWeight"      Value="SemiBold" />
                                            <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrush}" />
                                            <Setter Property="Foreground"      Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetAccentBrush}" />
                                            <Setter Property="BorderThickness" Value="0.7" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconWeight}"
                                      Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                      StrokeThickness="1.1" Stretch="Uniform" Width="13" Height="13"
                                      VerticalAlignment="Center" Margin="0,0,5,0" />
                                <TextBlock Text="{Binding ModeLabelWeight}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Grid HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                              Style="{StaticResource HoverGateStyle}">
                            <Button Style="{StaticResource InfoPillBadgeStyle}"
                                    Visibility="{Binding IsModeWeight, Converter={StaticResource BoolToVis}}"
                                    Command="{Binding OpenHelpCommand}" CommandParameter="help.unit.weight" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>
            <Border BorderBrush="{DynamicResource WidgetBorderBrush}"
                BorderThickness="0.7"
                CornerRadius="8"
                Padding="12,14">
                <StackPanel>

                    <!-- AREA mode -->
                    <StackPanel Visibility="{Binding IsModeArea, Converter={StaticResource BoolToVis}}">

                        <!-- From row label -->
                        <TextBlock Text="{Binding AreaFromLabel}"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,0,0,3" />

                        <!-- From: value + unit -->
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
          ItemsSource="{Binding AreaUnits}"
          SelectedIndex="{Binding AreaFromUnit}"
          Style="{StaticResource LargeComboBoxStyle}"
          MaxDropDownHeight="200" />
                            
                            <TextBox x:Name="AreaInputBox"
                         Grid.Column="2"
                         Text="{Binding AreaFromValue, UpdateSourceTrigger=PropertyChanged}"
                         Tag="{Binding HintAreaValue}"
                         Style="{StaticResource InputBoxStyle}"
                         ContextMenu="{x:Null}" />
                        </Grid>

                        <!-- To row label -->
                        <TextBlock Text="{Binding AreaToLabel}"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,0,0,3" />

                        <!-- To: result + unit + copy -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox Grid.Column="0"
ItemsSource="{Binding AreaUnits}"
SelectedIndex="{Binding AreaToUnit}"
Style="{StaticResource LargeComboBoxStyle}"
MaxDropDownHeight="200" />
                            <TextBox Grid.Column="2"
                         Text="{Binding AreaResult, Mode=OneWay}" Tag="--"
                         Style="{StaticResource OutputBoxStyle}"
                         GotKeyboardFocus="OutputBox_GotKeyboardFocus"
                         PreviewMouseDown="OutputBox_PreviewMouseDown" />
                        </Grid>

                        <!-- Error -->
                        <TextBlock Margin="0,6,0,0" Text="{Binding AreaError}"
                       FontSize="12" Foreground="{DynamicResource WidgetErrorBrush}"
                       HorizontalAlignment="Center"
                       Visibility="{Binding AreaHasError, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                    <!-- WEIGHT mode -->
                    <StackPanel Visibility="{Binding IsModeWeight, Converter={StaticResource BoolToVis}}">

                        <TextBlock Text="{Binding WeightFromLabel}"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,0,0,3" />

                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="WeightInputBox"
                         Grid.Column="2"
                         Text="{Binding WeightFromValue, UpdateSourceTrigger=PropertyChanged}"
                         Tag="{Binding HintWeightValue}"
                         Style="{StaticResource InputBoxStyle}"
                         ContextMenu="{x:Null}" />
                            <ComboBox Grid.Column="0"
                          ItemsSource="{Binding WeightUnits}"
                          SelectedIndex="{Binding WeightFromUnit}"
                          Style="{StaticResource LargeComboBoxStyle}"
                          MaxDropDownHeight="200" />
                        </Grid>

                        <TextBlock Text="{Binding WeightToLabel}"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,0,0,3" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="8" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="2"
                         Text="{Binding WeightResult, Mode=OneWay}" Tag="--"
                         Style="{StaticResource OutputBoxStyle}"
                         GotKeyboardFocus="OutputBox_GotKeyboardFocus"
                         PreviewMouseDown="OutputBox_PreviewMouseDown" />
                            <ComboBox Grid.Column="0"
                          ItemsSource="{Binding WeightUnits}"
                          SelectedIndex="{Binding WeightToUnit}"
                          Style="{StaticResource LargeComboBoxStyle}"
                          MaxDropDownHeight="200" />
                        </Grid>

                        <!-- Error -->
                        <TextBlock Margin="0,6,0,0" Text="{Binding WeightError}"
                       FontSize="12" Foreground="{DynamicResource WidgetErrorBrush}"
                       HorizontalAlignment="Center"
                       Visibility="{Binding WeightHasError, Converter={StaticResource BoolToVis}}" />
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
