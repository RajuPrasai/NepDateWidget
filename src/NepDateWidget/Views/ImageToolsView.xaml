<UserControl x:Class="NepDateWidget.Views.ImageToolsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             xmlns:conv="clr-namespace:NepDateWidget.Converters"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             AllowDrop="True"
             d:DataContext="{d:DesignInstance vm:ImageToolsViewModel}"
             d:Width="380">

  <UserControl.Resources>
    <conv:StringToImageSourceConverter x:Key="StringToImageSource" />

    <!-- Chevron geometries for collapsible toggles -->
    <StreamGeometry x:Key="ChevronDown">M6 9l6 6l6 -6</StreamGeometry>
    <StreamGeometry x:Key="ChevronUp">M6 15l6 -6l6 6</StreamGeometry>

    <!-- Format chip: unselected state; DataTriggers per chip override background when selected -->
    <Style x:Key="FormatChipBase" TargetType="Button">
      <Setter Property="Background"      Value="{DynamicResource WidgetAccentBrushLight}" />
      <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding"         Value="8,4" />
      <Setter Property="Cursor"          Value="Hand" />
      <Setter Property="Margin"          Value="0,0,4,4" />
      <Setter Property="FontSize"        Value="11" />
      <Setter Property="FontWeight"      Value="SemiBold" />
      <Setter Property="Height"          Value="26" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="13"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.4" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <StackPanel>

    <!-- Drop zone: hidden once files are loaded -->
    <Border x:Name="DropZone"
            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
            BorderThickness="0.8"
            CornerRadius="8"
            Padding="12,20"
            Margin="0,0,0,12"
            Cursor="Hand"
            MouseLeftButtonDown="DropZone_MouseLeftButtonDown"
            MouseLeftButtonUp="DropZone_Click"
            Visibility="{Binding HasFiles, Converter={StaticResource InverseBoolToVis}}">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
          <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
            </Trigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <StackPanel HorizontalAlignment="Center">
        <Path Data="{StaticResource IconDownload}"
              Stroke="{DynamicResource WidgetForegroundBrush}"
              StrokeThickness="1.7" StrokeLineJoin="Round"
              Stretch="Uniform" Width="28" Height="28"
              HorizontalAlignment="Center" Margin="0,0,0,6" Opacity="0.45" />
        <TextBlock Text="{Binding DropLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="13" HorizontalAlignment="Center" Opacity="0.7" />
        <TextBlock Text="{Binding BrowseLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="11" HorizontalAlignment="Center" Opacity="0.45" Margin="0,2,0,0" />
      </StackPanel>
    </Border>

    <!-- Mixed-type warning banner -->
    <Border Background="{DynamicResource WidgetAccentBrushLight}"
            BorderBrush="{DynamicResource WidgetAccentBrush}"
            BorderThickness="1"
            CornerRadius="6" Padding="10,7" Margin="0,0,0,12"
            Visibility="{Binding HasMixedTypeWarning, Converter={StaticResource BoolToVis}}">
      <TextBlock Text="{Binding MixedTypeWarning}"
                 Foreground="{DynamicResource WidgetForegroundBrush}" FontSize="12" TextWrapping="Wrap" />
    </Border>

    <!-- File list: visible while files loaded and no summary is showing -->
    <ItemsControl ItemsSource="{Binding Files}" MaxHeight="140" Margin="0,0,0,12"
                  Visibility="{Binding ShowFileList, Converter={StaticResource BoolToVis}}">
      <ItemsControl.Template>
        <ControlTemplate>
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsPresenter />
          </ScrollViewer>
        </ControlTemplate>
      </ItemsControl.Template>
      <ItemsControl.ItemTemplate>
        <DataTemplate DataType="{x:Type vm:CompressionFileItemViewModel}">
          <Grid Margin="0,0,0,3">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- Thumbnail -->
            <Border Grid.Column="0" Height="30" VerticalAlignment="Center" Margin="0,0,6,0">
              <Image Source="{Binding FilePath, Converter={StaticResource StringToImageSource}}"
                     Height="30" Stretch="Uniform">
                <Image.Clip>
                  <RectangleGeometry RadiusX="6" RadiusY="6" Rect="0,0,30,30" />
                </Image.Clip>
              </Image>
            </Border>
            <!-- File name + size + dimensions -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
              <TextBlock Text="{Binding FileName}"
                         Foreground="{DynamicResource WidgetForegroundBrush}"
                         FontSize="12" TextTrimming="CharacterEllipsis" />
              <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding FileSizeLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           Opacity="0.55" FontSize="10.5" />
                <TextBlock Text=" · "
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           Opacity="0.35" FontSize="10.5"
                           Visibility="{Binding HasDimensions, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding Dimensions}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           Opacity="0.45" FontSize="10.5"
                           Visibility="{Binding HasDimensions, Converter={StaticResource BoolToVis}}" />
              </StackPanel>
            </StackPanel>
            <!-- Savings label shown when done -->
            <TextBlock Grid.Column="2"
                       Text="{Binding SavingsLabel}"
                       Foreground="{DynamicResource WidgetAccentBrush}"
                       FontSize="11" VerticalAlignment="Center" Margin="6,0,6,0"
                       Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}" />
            <!-- Remove button - hidden while job running -->
            <Button Grid.Column="3"
                    Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding FilePath}"
                    Visibility="{Binding DataContext.IsJobRunning, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}"
                    ToolTip="{Binding DataContext.RemoveFileTooltipLabel, RelativeSource={RelativeSource AncestorType=UserControl}}">
              <Button.Style>
                <Style TargetType="Button">
                  <Setter Property="Background"      Value="Transparent" />
                  <Setter Property="BorderThickness" Value="0" />
                  <Setter Property="Padding"         Value="4" />
                  <Setter Property="Cursor"          Value="Hand" />
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
                          <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </Button.Style>
              <Path Data="{StaticResource IconWindowClose}"
                    Stroke="{DynamicResource WidgetForegroundBrush}"
                    StrokeThickness="1.3" Stretch="Uniform"
                    Width="9" Height="9" />
            </Button>
          </Grid>
        </DataTemplate>
      </ItemsControl.ItemTemplate>
    </ItemsControl>

    <!-- Add more files bar - compact button shown when file list is visible -->
    <Button Style="{StaticResource SecondaryButton}"
            Command="{Binding LoadFilesCommand}"
            Height="26" Margin="0,0,0,12"
            Visibility="{Binding ShowFileList, Converter={StaticResource BoolToVis}}">
      <StackPanel Orientation="Horizontal">
        <Path Data="{StaticResource IconPlus}"
              Stroke="{DynamicResource WidgetForegroundBrush}"
              StrokeThickness="1.5" Stretch="Uniform"
              Width="9" Height="9" VerticalAlignment="Center"
              Opacity="0.7" Margin="0,0,6,0" />
        <TextBlock Text="{Binding AddMoreLabel}"
                   FontSize="11" VerticalAlignment="Center" Opacity="0.7" />
      </StackPanel>
    </Button>

    <!-- Mode toggles row -->
    <StackPanel Orientation="Horizontal" Margin="0,0,0,10"
                Visibility="{Binding HasFiles, Converter={StaticResource BoolToVis}}">
      <!-- Compress toggle - disabled for RAW files -->
      <CheckBox Content="{Binding CompressToggleLabel}"
                IsChecked="{Binding IsCompressEnabled}"
                IsEnabled="{Binding CanToggleCompress}"
                Margin="0,0,14,0">
        <CheckBox.Style>
          <Style TargetType="CheckBox" BasedOn="{StaticResource WidgetCheckBox}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsRawOnlyFiles}" Value="True">
                <Setter Property="ToolTip" Value="{Binding CompressRawTooltip}" />
                <Setter Property="Opacity" Value="0.45" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </CheckBox.Style>
      </CheckBox>
      <!-- Resize toggle - disabled for PDF -->
      <CheckBox Content="{Binding ResizeToggleLabel}"
                IsChecked="{Binding IsResizeEnabled}"
                IsEnabled="{Binding CanToggleResize}"
                Margin="0,0,14,0">
        <CheckBox.Style>
          <Style TargetType="CheckBox" BasedOn="{StaticResource WidgetCheckBox}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasAnyPdfFile}" Value="True">
                <Setter Property="ToolTip" Value="{Binding PdfNoResizeTooltip}" />
                <Setter Property="Opacity" Value="0.45" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </CheckBox.Style>
      </CheckBox>
      <!-- Convert toggle - disabled for PDF -->
      <CheckBox Content="{Binding ConvertToggleLabel}"
                IsChecked="{Binding IsConvertEnabled}"
                IsEnabled="{Binding CanToggleConvert}">
        <CheckBox.Style>
          <Style TargetType="CheckBox" BasedOn="{StaticResource WidgetCheckBox}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding HasAnyPdfFile}" Value="True">
                <Setter Property="ToolTip" Value="{Binding PdfNoConvertTooltip}" />
                <Setter Property="Opacity" Value="0.45" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </CheckBox.Style>
      </CheckBox>
    </StackPanel>

    <!-- ── Compress card ──────────────────────────────────────────────────── -->
    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12"
            Visibility="{Binding ShowCompressSection, Converter={StaticResource BoolToVis}}">
      <StackPanel>
        <TextBlock Text="{Binding SectionCompressLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12" />

        <!-- Quality slider - hidden for lossless formats when Convert is ON -->
        <StackPanel Visibility="{Binding ShowQualitySlider, Converter={StaticResource BoolToVis}}">
          <Slider Minimum="0" Maximum="4"
                  Value="{Binding QualityLevel}"
                  Style="{DynamicResource IosSlider}"
                  IsSnapToTickEnabled="True" TickFrequency="1"
                  SmallChange="1" LargeChange="1"
                  Margin="0,0,0,4" />
          <Grid Margin="9,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"                         Text="{Binding LevelSmallestLabel}" Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Left" />
            <TextBlock Grid.Column="0" Grid.ColumnSpan="2"     Text="{Binding LevelLowLabel}"      Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="1" Grid.ColumnSpan="2"     Text="{Binding LevelBalancedLabel}" Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="2" Grid.ColumnSpan="2"     Text="{Binding LevelHighLabel}"     Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Center" />
            <TextBlock Grid.Column="3"                         Text="{Binding LevelBestLabel}"     Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Right" />
          </Grid>
        </StackPanel>

        <!-- Strip metadata - inside compress card, hidden for PDF -->
        <CheckBox Content="{Binding StripMetaLabel}"
                  IsChecked="{Binding StripMetadata}"
                  Style="{StaticResource WidgetCheckBox}"
                  Margin="0,10,0,0"
                  Visibility="{Binding ShowStripMetaOption, Converter={StaticResource BoolToVis}}" />

        <!-- Advanced toggle for format-specific options (GIF/TIFF/PDF only) -->
        <Button Command="{Binding ToggleAdvancedCommand}"
                Margin="0,10,0,0"
                Cursor="Hand"
                Visibility="{Binding ShowAdvancedToggle, Converter={StaticResource BoolToVis}}">
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Background"      Value="Transparent" />
              <Setter Property="BorderThickness" Value="0" />
              <Setter Property="Padding"         Value="0" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="Button">
                    <ContentPresenter />
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </Button.Style>
          <StackPanel Orientation="Horizontal">
            <Path Margin="0,0,5,0" VerticalAlignment="Center" Width="8" Height="8" Stretch="Uniform">
              <Path.Style>
                <Style TargetType="Path">
                  <Setter Property="Data" Value="{StaticResource ChevronDown}" />
                  <Setter Property="Stroke" Value="{DynamicResource WidgetForegroundBrush}" />
                  <Setter Property="StrokeThickness" Value="1.3" />
                  <Setter Property="Opacity" Value="0.6" />
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding ShowAdvancedOptions}" Value="True">
                      <Setter Property="Data" Value="{StaticResource ChevronUp}" />
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </Path.Style>
            </Path>
            <TextBlock Text="{Binding AdvancedLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="11" Opacity="0.6" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Collapsible advanced section -->
        <StackPanel Visibility="{Binding ShowAdvancedOptions, Converter={StaticResource BoolToVis}}"
                    Margin="0,8,0,0">
          <!-- GIF options -->
          <StackPanel Visibility="{Binding ShowGifOptions, Converter={StaticResource BoolToVis}}" Margin="0,0,0,6">
            <TextBlock Text="{Binding AdvGifLabel}" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
            <CheckBox Content="{Binding AdvOptimizeGifLabel}"
                      IsChecked="{Binding OptimizeGifFrames}"
                      Style="{StaticResource WidgetCheckBox}" />
          </StackPanel>

          <!-- TIFF options -->
          <StackPanel Visibility="{Binding ShowTiffOptions, Converter={StaticResource BoolToVis}}" Margin="0,0,0,6">
            <TextBlock Text="{Binding AdvTiffLabel}" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding TiffCompressionOptions}"
                      SelectedItem="{Binding TiffCompression}"
                      Style="{StaticResource ThemedComboBoxStyle}" />
          </StackPanel>

          <!-- PDF options -->
          <StackPanel Visibility="{Binding ShowPdfOptions, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding AdvPdfLabel}" Style="{StaticResource FieldLabel}" Margin="0,0,0,4" />
            <CheckBox Content="{Binding AdvLinearizeLabel}"
                      IsChecked="{Binding LinearizePdf}"
                      Style="{StaticResource WidgetCheckBox}" />
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </Border>

    <!-- ── Resize card ────────────────────────────────────────────────────── -->
    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12"
            Visibility="{Binding ShowResizeSection, Converter={StaticResource BoolToVis}}">
      <StackPanel>
        <TextBlock Text="{Binding SectionResizeLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12" />
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>
          <!-- Labels row -->
          <TextBlock Grid.Row="0" Grid.Column="0"
                     Text="{Binding WidthLabelText}"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     FontSize="10.5" Opacity="0.65" Margin="0,0,0,2" />
          <TextBlock Grid.Row="0" Grid.Column="2"
                     Text="{Binding HeightLabelText}"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     FontSize="10.5" Opacity="0.65" Margin="0,0,0,2" />
          <!-- Inputs row -->
          <TextBox Grid.Row="1" Grid.Column="0"
                   Style="{StaticResource InputBoxStyle}"
                   Text="{Binding WidthText, UpdateSourceTrigger=PropertyChanged}"
                   IsEnabled="{Binding IsJobNotRunning}"
                   MaxLength="5"
                   Tag="{Binding WidthHintLabel}"
                   Margin="0,0,6,0" />
          <TextBlock Grid.Row="1" Grid.Column="1" Text="×"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     Opacity="0.5" FontSize="14"
                     VerticalAlignment="Center" Margin="0,0,6,0" />
          <TextBox Grid.Row="1" Grid.Column="2"
                   Style="{StaticResource InputBoxStyle}"
                   Text="{Binding HeightText, UpdateSourceTrigger=PropertyChanged}"
                   IsEnabled="{Binding IsJobNotRunning}"
                   MaxLength="5"
                   Tag="{Binding HeightHintLabel}"
                   Margin="0,0,6,0" />
          <TextBlock Grid.Row="1" Grid.Column="3" Text="px"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     Opacity="0.5" FontSize="11"
                     VerticalAlignment="Center" />
        </Grid>
      </StackPanel>
    </Border>

    <!-- ── Convert card ───────────────────────────────────────────────────── -->
    <Border Style="{StaticResource CardPanel}" Margin="0,0,0,12"
            Visibility="{Binding ShowConvertSection, Converter={StaticResource BoolToVis}}">
      <StackPanel>
        <TextBlock Text="{Binding SectionConvertLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="12" FontWeight="SemiBold" Margin="0,0,0,12" />

        <!-- Primary format chips - 4 common formats -->
        <WrapPanel>
          <!-- JPEG -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="jpg">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatJpeg}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            JPEG
          </Button>

          <!-- PNG -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="png">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatPng}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            PNG
          </Button>

          <!-- WebP -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="webp">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatWebp}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            WebP
          </Button>

          <!-- AVIF -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="avif">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatAvif}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            AVIF
          </Button>

          <!-- PDF - hidden when input files are already PDFs (PDF→PDF is invalid) -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="pdf"
                  Visibility="{Binding IsFormatPdfChipVisible, Converter={StaticResource BoolToVis}}">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatPdf}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            PDF
          </Button>

          <!-- More formats toggle chip -->
          <Button Command="{Binding ToggleMoreFormatsCommand}">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Setter Property="Opacity" Value="0.7" />
              </Style>
            </Button.Style>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="{Binding MoreFormatsLabel}" VerticalAlignment="Center" />
              <Path Margin="4,1,0,0" VerticalAlignment="Center" Width="7" Height="7" Stretch="Uniform">
                <Path.Style>
                  <Style TargetType="Path">
                    <Setter Property="Data" Value="{StaticResource ChevronDown}" />
                    <Setter Property="Stroke" Value="{DynamicResource WidgetForegroundBrush}" />
                    <Setter Property="StrokeThickness" Value="1.2" />
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding ShowMoreFormats}" Value="True">
                        <Setter Property="Data" Value="{StaticResource ChevronUp}" />
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </Path.Style>
              </Path>
            </StackPanel>
          </Button>
        </WrapPanel>

        <!-- Secondary format chips - hidden by default -->
        <WrapPanel Margin="0,4,0,0"
                   Visibility="{Binding ShowMoreFormats, Converter={StaticResource BoolToVis}}">
          <!-- GIF -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="gif">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatGif}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            GIF
          </Button>

          <!-- BMP -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="bmp">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatBmp}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            BMP
          </Button>

          <!-- TIFF -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="tif">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatTiff}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            TIFF
          </Button>

          <!-- ICO -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="ico">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatIco}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            ICO
          </Button>

          <!-- TGA -->
          <Button Command="{Binding SelectFormatCommand}" CommandParameter="tga">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsFormatTga}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            TGA
          </Button>
        </WrapPanel>

        <!-- PDF→image page mode options - visible when all input is PDF and target is an image format -->
        <WrapPanel Margin="0,8,0,0"
                   Visibility="{Binding ShowPdfConvertOptions, Converter={StaticResource BoolToVis}}">
          <!-- First page -->
          <Button Command="{Binding SelectPdfPageModeCommand}" CommandParameter="FirstPageOnly">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPdfPageModeFirstOnly}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <TextBlock Text="{Binding PdfPageModeFirstLabel}" />
          </Button>
          <!-- All pages, one per file -->
          <Button Command="{Binding SelectPdfPageModeCommand}" CommandParameter="AllPagesPerFile">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPdfPageModeAllPerFile}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <TextBlock Text="{Binding PdfPageModePerFileLabel}" />
          </Button>
          <!-- All pages, combined image -->
          <Button Command="{Binding SelectPdfPageModeCommand}" CommandParameter="AllPagesCombined">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPdfPageModeCombined}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <TextBlock Text="{Binding PdfPageModeCombinedLabel}" />
          </Button>
        </WrapPanel>

        <!-- Image→PDF combine mode - visible when images loaded, PDF target, multiple files -->
        <WrapPanel Margin="0,8,0,0"
                   Visibility="{Binding ShowImageToPdfOptions, Converter={StaticResource BoolToVis}}">
          <!-- One PDF per image -->
          <Button Command="{Binding SelectImageToPdfModeCommand}" CommandParameter="OnePerFile">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsImageToPdfOnePerFile}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <TextBlock Text="{Binding ImgToPdfOnePerFileLabel}" />
          </Button>
          <!-- Combined multi-page PDF -->
          <Button Command="{Binding SelectImageToPdfModeCommand}" CommandParameter="CombinedPdf">
            <Button.Style>
              <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsImageToPdfCombined}" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Button.Style>
            <TextBlock Text="{Binding ImgToPdfCombinedLabel}" />
          </Button>
        </WrapPanel>
      </StackPanel>
    </Border>

    <!-- ── Progress area ──────────────────────────────────────────────────── -->
    <StackPanel Margin="0,0,0,12"
                Visibility="{Binding IsJobRunning, Converter={StaticResource BoolToVis}}">
      <Grid Margin="0,0,0,5">
        <TextBlock Text="{Binding ProgressTitleLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="12" FontWeight="SemiBold" />
        <TextBlock Text="{Binding ProgressLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="11" Opacity="0.6" HorizontalAlignment="Right" />
      </Grid>
      <ProgressBar Value="{Binding CompletedCount, Mode=OneWay}"
                   Maximum="{Binding TotalCount}"
                   Style="{StaticResource WidgetProgressBar}" />
    </StackPanel>

    <!-- ── Action button row ─────────────────────────────────────────────── -->

    <!-- Mode 1: Summary active - full-width Reset button -->
    <Button Margin="0,0,0,4"
            Style="{StaticResource SecondaryButton}"
            Command="{Binding DismissSummaryCommand}"
            Height="36"
            Visibility="{Binding ShowSummary, Converter={StaticResource BoolToVis}}">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
        <Path Data="{StaticResource IconRefresh}"
              Stroke="{DynamicResource WidgetForegroundBrush}"
              StrokeThickness="1.5" Fill="Transparent"
              Stretch="Uniform" Width="13" Height="13"
              VerticalAlignment="Center" Margin="0,0,7,0" />
        <TextBlock Text="{Binding ResetButtonLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   VerticalAlignment="Center" />
      </StackPanel>
    </Button>

    <!-- Mode 2: Normal / running - Reset (when idle) + Process/Cancel -->
    <Grid Margin="0,0,0,4"
          Visibility="{Binding ShowSummary, Converter={StaticResource InverseBoolToVis}}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />   <!-- Reset: collapses to 0 when hidden -->
        <ColumnDefinition Width="Auto" />   <!-- Spacer: collapses to 0 when hidden -->
        <ColumnDefinition Width="*" />      <!-- Process/Cancel: always takes remaining space -->
      </Grid.ColumnDefinitions>
      <!-- Reset: icon + text, visible only when idle with files loaded -->
      <Button Grid.Column="0"
              Style="{StaticResource SecondaryButton}"
              Command="{Binding DismissSummaryCommand}"
              Visibility="{Binding ShowResetButton, Converter={StaticResource BoolToVis}}"
              Height="36">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <Path Data="{StaticResource IconRefresh}"
                Stroke="{DynamicResource WidgetForegroundBrush}"
                StrokeThickness="1.5" Fill="Transparent"
                Stretch="Uniform" Width="13" Height="13"
                VerticalAlignment="Center" Margin="0,0,7,0" />
          <TextBlock Text="{Binding ResetButtonLabel}"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <!-- Spacer: collapses when Reset is hidden so Process gets full width during job -->
      <Border Grid.Column="1" Width="8"
              Visibility="{Binding ShowResetButton, Converter={StaticResource BoolToVis}}" />
      <!-- Process / Cancel button: always in col 2 -->
      <Button Grid.Column="2"
              Style="{StaticResource AccentButton}"
              Command="{Binding RunCommand}"
              IsEnabled="{Binding IsRunButtonEnabled}"
              Height="36">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
          <Path Data="{StaticResource IconLightning}"
                Fill="{DynamicResource WidgetDayTodayTextBrush}"
                Stretch="Uniform" Width="11" Height="13"
                VerticalAlignment="Center" Margin="0,0,7,0" />
          <TextBlock Text="{Binding ActionButtonLabel}"
                     Foreground="{DynamicResource WidgetDayTodayTextBrush}"
                     VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- ── Summary banner ────────────────────────────────────────────────── -->
    <Border Background="{DynamicResource WidgetAccentBrushLight}"
            BorderBrush="{DynamicResource WidgetAccentBrush}"
            BorderThickness="1.5"
            CornerRadius="8"
            Padding="10,9"
            Margin="0,4,0,0"
            Visibility="{Binding ShowSummary, Converter={StaticResource BoolToVis}}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Summary content - wraps gracefully with FlowDirection trick -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <!-- Check icon + file count -->
          <StackPanel Orientation="Horizontal">
            <Path Data="{StaticResource IconCheck}"
                  Stroke="{DynamicResource WidgetAccentBrush}"
                  StrokeThickness="1.8" Fill="Transparent" Stretch="Uniform"
                  Width="13" Height="13" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBlock Text="{Binding SummaryFilesSegment}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Size comparison row - shown only when Compress or Resize was active -->
          <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                      Visibility="{Binding SummaryShowSizeComparison, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding SummaryOrigSizeSegment}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="11" VerticalAlignment="Center" />
            <TextBlock Text=" → "
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       Opacity="0.4" FontSize="11" VerticalAlignment="Center" />
            <TextBlock Text="{Binding SummaryNewSizeSegment}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="11" VerticalAlignment="Center" />
            <TextBlock Text=" · "
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       Opacity="0.4" FontSize="11" VerticalAlignment="Center" />
            <TextBlock Text="{Binding SummarySavedSegment}"
                       Foreground="{DynamicResource WidgetAccentBrush}"
                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
          </StackPanel>

          <!-- Output-size row - shown only for convert-only jobs -->
          <TextBlock Margin="0,4,0,0"
                     Text="{Binding SummaryOutputSegment}"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     FontSize="11"
                     Visibility="{Binding SummaryShowSizeComparison, Converter={StaticResource InverseBoolToVis}}" />
        </StackPanel>

        <!-- Dismiss button -->
        <Button Grid.Column="1"
                Command="{Binding DismissSummaryCommand}"
                VerticalAlignment="Top" Margin="10,0,0,0"
                Cursor="Hand">
          <Button.Style>
            <Style TargetType="Button">
              <Setter Property="Background"      Value="Transparent" />
              <Setter Property="BorderThickness" Value="0" />
              <Setter Property="Padding"         Value="5" />
              <Setter Property="Opacity"         Value="0.55" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </Button.Style>
          <Path Data="{StaticResource IconWindowClose}"
                Stroke="{DynamicResource WidgetForegroundBrush}"
                StrokeThickness="1.5" Stretch="Uniform"
                Width="10" Height="10" />
        </Button>

      </Grid>
    </Border>

  </StackPanel>
</UserControl>
