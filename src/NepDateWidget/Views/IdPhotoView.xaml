<UserControl x:Class="NepDateWidget.Views.IdPhotoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             xmlns:conv="clr-namespace:NepDateWidget.Converters"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             AllowDrop="True"
             d:DataContext="{d:DesignInstance vm:IdPhotoViewModel}"
             d:Width="380">

  <UserControl.Resources>
    <conv:IntEqualConverter         x:Key="IntEq" />

    <!-- Preset / color radio-button pill style -->
    <Style x:Key="OptionPillStyle" TargetType="RadioButton">
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Foreground"            Value="{DynamicResource WidgetForegroundBrush}" />
      <Setter Property="FontSize"              Value="11" />
      <Setter Property="Cursor"                Value="Hand" />
      <Setter Property="Margin"                Value="0,0,6,6" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Bd"
                                Background="{DynamicResource WidgetAccentBrushLight}"
                                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                BorderThickness="0.8" CornerRadius="5"
                                Padding="8,5">
              <ContentPresenter VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource WidgetAccentBrush}" />
                <Setter Property="Foreground"
                                        Value="{DynamicResource WidgetDayTodayTextBrush}" />
              </Trigger>

            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </UserControl.Resources>

  <StackPanel>

    <!-- ── Drop zone (hidden once a photo is loaded) ──────────────── -->
    <Border Visibility="{Binding HasPhoto, Converter={StaticResource InverseBoolToVis}}"
                BorderBrush="{DynamicResource WidgetAccentBrushLight}"
                BorderThickness="0.8" CornerRadius="8"
                Padding="12,20" Margin="0,0,0,8"
                Cursor="Hand"
                MouseLeftButtonDown="DropZone_MouseLeftButtonDown"
                MouseLeftButtonUp="DropZone_Click">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
        </Style>
      </Border.Style>
      <StackPanel HorizontalAlignment="Center">
        <Path Data="{StaticResource IconDownload}"
                      Stroke="{DynamicResource WidgetForegroundBrush}"
                      StrokeThickness="1.7" StrokeLineJoin="Round"
                      Stretch="Uniform" Width="28" Height="28"
                      HorizontalAlignment="Center" Margin="0,0,0,6" Opacity="0.45" />
        <TextBlock Text="{Binding DropLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="13" HorizontalAlignment="Center" Opacity="0.7" />
        <TextBlock Text="{Binding BrowseLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="11" HorizontalAlignment="Center"
                           Opacity="0.45" Margin="0,2,0,0" />
      </StackPanel>
    </Border>

    <!-- ── Crop canvas (shown once a photo is loaded) ─────────────── -->
    <Border Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"
                CornerRadius="8" ClipToBounds="True"
                Margin="0,0,0,4">
      <Grid x:Name="CropContainer"
              MaxHeight="280" ClipToBounds="True"
              SizeChanged="CropContainer_SizeChanged"
              MouseWheel="CropContainer_MouseWheel">
        <Grid x:Name="CropInner">
          <Image x:Name="CropImage"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
          <Canvas x:Name="CropCanvas"
                        Background="Transparent"
                        Cursor="Arrow"
                        MouseLeftButtonDown="CropCanvas_MouseDown"
                        MouseMove="CropCanvas_MouseMove"
                        MouseLeftButtonUp="CropCanvas_MouseUp"
                        MouseLeave="CropCanvas_MouseLeave">
            <!-- Four dark overlay panels outside the crop frame — set by code-behind -->
            <Rectangle x:Name="OvTop"    Fill="#BB000000" IsHitTestVisible="False" />
            <Rectangle x:Name="OvBottom" Fill="#BB000000" IsHitTestVisible="False" />
            <Rectangle x:Name="OvLeft"   Fill="#BB000000" IsHitTestVisible="False" />
            <Rectangle x:Name="OvRight"  Fill="#BB000000" IsHitTestVisible="False" />
            <!-- Crop frame (square mode) -->
            <Border x:Name="CropFrame"
                            BorderBrush="White" BorderThickness="1.5"
                            Background="Transparent"
                            IsHitTestVisible="False">
              <TextBlock x:Name="CropHint"
                                   Text="{Binding CropHintLabel}"
                                   Foreground="White" FontSize="10"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Bottom"
                                   Margin="4,0,4,4" Opacity="0.75"
                                   TextWrapping="Wrap" TextAlignment="Center" />
            </Border>
            <!-- Circle mode overlay (EvenOdd rect−ellipse mask) and frame -->
            <Path x:Name="OvCircle" Fill="#BB000000" IsHitTestVisible="False" Visibility="Collapsed" />
            <Ellipse x:Name="CropCircle" Stroke="White" StrokeThickness="1.5"
                             IsHitTestVisible="False" Visibility="Collapsed" />
          </Canvas>
        </Grid>
      </Grid>
    </Border>

    <!-- ── Clear button row (shown once a photo is loaded) ──────────── -->
    <Grid Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"
              Margin="0,0,0,10">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <WrapPanel Grid.Column="0">
        <RadioButton Content="{Binding CropSquareLabel}"
                                 IsChecked="{Binding CropShape, Converter={StaticResource IntEq}, ConverterParameter='0'}"
                                 Style="{StaticResource OptionPillStyle}" Margin="0,0,6,0" />
        <RadioButton Content="{Binding CropCircleLabel}"
                                 IsChecked="{Binding CropShape, Converter={StaticResource IntEq}, ConverterParameter='1'}"
                                 Style="{StaticResource OptionPillStyle}" Margin="0,0,0,0" />
      </WrapPanel>
      <Button Grid.Column="2" HorizontalAlignment="Right"
                  Command="{Binding ClearCommand}"
                  Style="{StaticResource SecondaryButton}">
        <StackPanel Orientation="Horizontal">
          <Path Data="{StaticResource IconWindowClose}"
                Stroke="{DynamicResource WidgetForegroundBrush}" StrokeThickness="1.3"
                Fill="Transparent" Stretch="Uniform"
                Width="10" Height="10" VerticalAlignment="Center" Margin="0,0,5,0" />
          <TextBlock Text="{Binding ClearLabel}" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </Grid>

    <!-- ── Format section ─────────────────────────────────────────── -->
    <Border Background="{DynamicResource WidgetBackgroundBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8" CornerRadius="8"
                Padding="12,14" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="{Binding FormatSectionLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="14" FontWeight="SemiBold" Opacity="0.9"
                           Margin="0,0,0,10" />
        <!-- Preset pills -->
        <WrapPanel Margin="0,0,0,10">
          <RadioButton Content="{Binding Preset0Label}"
                                 IsChecked="{Binding PresetIndex, Converter={StaticResource IntEq}, ConverterParameter='0'}"
                                 Style="{StaticResource OptionPillStyle}" />
          <RadioButton Content="{Binding Preset1Label}"
                                 IsChecked="{Binding PresetIndex, Converter={StaticResource IntEq}, ConverterParameter='1'}"
                                 Style="{StaticResource OptionPillStyle}" />
          <RadioButton Content="{Binding Preset2Label}"
                                 IsChecked="{Binding PresetIndex, Converter={StaticResource IntEq}, ConverterParameter='2'}"
                                 Style="{StaticResource OptionPillStyle}" />
          <RadioButton Content="{Binding Preset3Label}"
                                 IsChecked="{Binding PresetIndex, Converter={StaticResource IntEq}, ConverterParameter='3'}"
                                 Style="{StaticResource OptionPillStyle}" />
        </WrapPanel>
        <!-- Unit + dimensions row -->
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <!-- Unit selector -->
          <Border Grid.Column="0"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                            BorderThickness="0.8" CornerRadius="6" Height="32">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="{Binding UnitLabel}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center" Margin="8,0,4,0" />
              <ComboBox Grid.Column="1"
                                      SelectedIndex="{Binding UnitIndex}"
                                      Style="{StaticResource ThemedComboBoxStyle}"
                                      Background="Transparent" BorderThickness="0"
                                      Height="32" MinWidth="46" FontSize="11">
                <ComboBoxItem>mm</ComboBoxItem>
                <ComboBoxItem>cm</ComboBoxItem>
                <ComboBoxItem>in</ComboBoxItem>
                <ComboBoxItem>px</ComboBoxItem>
              </ComboBox>
            </Grid>
          </Border>
          <!-- Width input -->
          <Border Grid.Column="2"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderThickness="0.8" CornerRadius="6" Height="32">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource WidgetInputBorderBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPhotoWidthValid}" Value="False">
                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetErrorBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="{Binding WidthMmLabel}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center" Margin="8,0,4,0" />
              <TextBox Grid.Column="1"
                                     Text="{Binding CustomWidthText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Background="Transparent" BorderThickness="0"
                                     Height="32" VerticalAlignment="Center" />
            </Grid>
          </Border>
          <!-- Height input -->
          <Border Grid.Column="4"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderThickness="0.8" CornerRadius="6" Height="32">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource WidgetInputBorderBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsPhotoHeightValid}" Value="False">
                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetErrorBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="{Binding HeightMmLabel}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center" Margin="8,0,4,0" />
              <TextBox Grid.Column="1"
                                     Text="{Binding CustomHeightText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Background="Transparent" BorderThickness="0"
                                     Height="32" VerticalAlignment="Center" />
            </Grid>
          </Border>
        </Grid>
        <!-- Save Photo row -->
        <Grid Margin="0,10,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <Button Grid.Column="1"
                            Command="{Binding ExportPhotoCommand}"
                            IsEnabled="{Binding CanExport}"
                            Style="{StaticResource AccentButton}"
                            Height="36">
            <StackPanel Orientation="Horizontal">
              <Path Data="{StaticResource IconCheck}"
                                  Stroke="{DynamicResource WidgetDayTodayTextBrush}"
                                  StrokeThickness="1.5" Fill="Transparent"
                                  Stretch="Uniform" Width="10" Height="10"
                                  VerticalAlignment="Center" Margin="0,0,6,0" />
              <TextBlock Text="{Binding SavePhotoLabel}" VerticalAlignment="Center" />
            </StackPanel>
          </Button>
        </Grid>
      </StackPanel>
    </Border>

    <!-- ── Sheet size section ─────────────────────────────────────── -->
    <Border Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVis}}"
                Background="{DynamicResource WidgetBackgroundBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8" CornerRadius="8"
                Padding="12,14" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="{Binding SheetSectionLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="14" FontWeight="SemiBold" Opacity="0.9"
                           Margin="0,0,0,10" />
        <!-- Sheet preset pills -->
        <WrapPanel Margin="0,0,0,10">
          <RadioButton Content="{Binding Sheet0Label}"
                                 IsChecked="{Binding SheetSizeIndex, Converter={StaticResource IntEq}, ConverterParameter='0'}"
                                 Style="{StaticResource OptionPillStyle}" />
          <RadioButton Content="{Binding Sheet1Label}"
                                 IsChecked="{Binding SheetSizeIndex, Converter={StaticResource IntEq}, ConverterParameter='1'}"
                                 Style="{StaticResource OptionPillStyle}" />
          <RadioButton Content="{Binding Sheet2Label}"
                                 IsChecked="{Binding SheetSizeIndex, Converter={StaticResource IntEq}, ConverterParameter='2'}"
                                 Style="{StaticResource OptionPillStyle}" />
          <RadioButton Content="{Binding Sheet3Label}"
                                 IsChecked="{Binding SheetSizeIndex, Converter={StaticResource IntEq}, ConverterParameter='3'}"
                                 Style="{StaticResource OptionPillStyle}" />
        </WrapPanel>
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <!-- Sheet unit selector -->
          <Border Grid.Column="0"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                            BorderThickness="0.8" CornerRadius="6" Height="32">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="{Binding SheetUnitLabel}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center" Margin="8,0,4,0" />
              <ComboBox Grid.Column="1"
                                      SelectedIndex="{Binding SheetUnitIndex}"
                                      Style="{StaticResource ThemedComboBoxStyle}"
                                      Background="Transparent" BorderThickness="0"
                                      Height="32" MinWidth="46" FontSize="11">
                <ComboBoxItem>mm</ComboBoxItem>
                <ComboBoxItem>cm</ComboBoxItem>
                <ComboBoxItem>in</ComboBoxItem>
              </ComboBox>
            </Grid>
          </Border>
          <!-- Sheet W input -->
          <Border Grid.Column="2"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderThickness="0.8" CornerRadius="6" Height="32">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource WidgetInputBorderBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSheetWidthValid}" Value="False">
                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetErrorBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="{Binding SheetWidthLabel}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center" Margin="8,0,4,0" />
              <TextBox Grid.Column="1"
                                     Text="{Binding SheetWidthMmText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Background="Transparent" BorderThickness="0"
                                     Height="32" VerticalAlignment="Center" />
            </Grid>
          </Border>
          <!-- Sheet H input -->
          <Border Grid.Column="4"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderThickness="0.8" CornerRadius="6" Height="32">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource WidgetInputBorderBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSheetHeightValid}" Value="False">
                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetErrorBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="{Binding SheetHeightLabel}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center" Margin="8,0,4,0" />
              <TextBox Grid.Column="1"
                                     Text="{Binding SheetHeightMmText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Background="Transparent" BorderThickness="0"
                                     Height="32" VerticalAlignment="Center" />
            </Grid>
          </Border>
        </Grid>
        <!-- Orientation -->
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <WrapPanel Grid.Column="1">
            <RadioButton Content="{Binding AutoLabel}"
                                     IsChecked="{Binding SheetOrientation, Converter={StaticResource IntEq}, ConverterParameter='0'}"
                                     Style="{StaticResource OptionPillStyle}" />
            <RadioButton Content="{Binding PortraitLabel}"
                                     IsChecked="{Binding SheetOrientation, Converter={StaticResource IntEq}, ConverterParameter='1'}"
                                     Style="{StaticResource OptionPillStyle}" />
            <RadioButton Content="{Binding LandscapeLabel}"
                                     IsChecked="{Binding SheetOrientation, Converter={StaticResource IntEq}, ConverterParameter='2'}"
                                     Style="{StaticResource OptionPillStyle}" />
          </WrapPanel>
        </Grid>
        <!-- Columns and Rows — empty = auto-calculated -->
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border Grid.Column="0"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderThickness="0.8" CornerRadius="6" Height="32">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource WidgetInputBorderBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSheetColsValid}" Value="False">
                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetErrorBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="{Binding ColsLabel}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center" Margin="8,0,4,0" />
              <TextBox Grid.Column="1"
                                     Text="{Binding SheetColsText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Background="Transparent" BorderThickness="0"
                                     Height="32" VerticalAlignment="Center" />
            </Grid>
          </Border>
          <Border Grid.Column="2"
                            Background="{DynamicResource WidgetBackgroundBrush}"
                            BorderThickness="0.8" CornerRadius="6" Height="32">
            <Border.Style>
              <Style TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource WidgetInputBorderBrush}" />
                <Style.Triggers>
                  <DataTrigger Binding="{Binding IsSheetRowsValid}" Value="False">
                    <Setter Property="BorderBrush" Value="{DynamicResource WidgetErrorBrush}" />
                  </DataTrigger>
                </Style.Triggers>
              </Style>
            </Border.Style>
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                                       Text="{Binding RowsLabel}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="11" Opacity="0.5"
                                       VerticalAlignment="Center" Margin="8,0,4,0" />
              <TextBox Grid.Column="1"
                                     Text="{Binding SheetRowsText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource InputBoxStyle}"
                                     Background="Transparent" BorderThickness="0"
                                     Height="32" VerticalAlignment="Center" />
            </Grid>
          </Border>
        </Grid>
        <!-- Save Sheet button -->
        <Button Command="{Binding ExportSheetCommand}"
                        IsEnabled="{Binding CanExportSheet}"
                        Style="{StaticResource AccentButton}"
                        Height="36"
                        HorizontalAlignment="Right">
          <StackPanel Orientation="Horizontal">
            <Path Data="{StaticResource IconWordCount}"
                              Stroke="{DynamicResource WidgetDayTodayTextBrush}"
                              StrokeThickness="1.3" Fill="Transparent"
                              Stretch="Uniform" Width="10" Height="10"
                              VerticalAlignment="Center" Margin="0,0,6,0" />
            <TextBlock Text="{Binding SaveSheetLabel}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </StackPanel>
    </Border>

    <!-- ── Status bar ─────────────────────────────────────────────── -->
    <Border Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}"
                CornerRadius="6" Padding="10,7" Margin="0,0,0,6">
      <Border.Style>
        <Style TargetType="Border">
          <Setter Property="Background"
                            Value="{DynamicResource WidgetInputBrush}" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding StatusIsError}" Value="True">
              <Setter Property="Background"
                                    Value="{DynamicResource WidgetErrorBrush}" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </Border.Style>
      <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="12" TextWrapping="Wrap">
        <TextBlock.Style>
          <Style TargetType="TextBlock">
            <Style.Triggers>
              <DataTrigger Binding="{Binding StatusIsError}" Value="True">
                <Setter Property="Foreground" Value="White" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </TextBlock.Style>
      </TextBlock>
    </Border>


  </StackPanel>
</UserControl>
