<UserControl x:Class="NepDateWidget.Views.QrCodeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             d:DataContext="{d:DesignInstance vm:QrCodeViewModel}"
             d:Width="380">

  <UserControl.Resources>

    <!-- Type selector pill - RadioButton styled to match OptionPillStyle used across tools -->
    <Style x:Key="TypePillStyle" TargetType="RadioButton">
      <Setter Property="OverridesDefaultStyle" Value="True" />
      <Setter Property="Foreground"            Value="{DynamicResource WidgetForegroundBrush}" />
      <Setter Property="FontSize"              Value="11" />
      <Setter Property="Cursor"                Value="Hand" />
      <Setter Property="Margin"                Value="0,0,6,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border x:Name="Bd"
                    Background="{DynamicResource WidgetAccentBrushLight}"
                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                    BorderThickness="0.8" CornerRadius="5"
                    Padding="10,5">
              <ContentPresenter VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource WidgetAccentBrush}" />
                <Setter Property="Foreground"
                                        Value="{DynamicResource WidgetDayTodayTextBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

  </UserControl.Resources>

  <StackPanel>

    <!-- ── Mode selector ─────────────────────────────────────────────── -->
    <WrapPanel Margin="0,0,0,8">
      <RadioButton Content="{Binding ModeGenerateLabel}"
                   IsChecked="{Binding IsModeGenerate}"
                   Style="{StaticResource TypePillStyle}" />
      <RadioButton Content="{Binding ModeDecodeLabel}"
                   IsChecked="{Binding IsModeDecode}"
                   Style="{StaticResource TypePillStyle}" />
    </WrapPanel>

    <!-- ── Generate mode ─────────────────────────────────────────────── -->
    <StackPanel Visibility="{Binding IsModeGenerate, Converter={StaticResource BoolToVis}}">

    <!-- ── Type selector ──────────────────────────────────────────────── -->
    <WrapPanel Margin="0,0,0,12">
      <RadioButton Content="{Binding TypeTextUrlLabel}"
                   IsChecked="{Binding IsTypeTextUrl}"
                   Style="{StaticResource TypePillStyle}" />
      <RadioButton Content="{Binding TypeWifiLabel}"
                   IsChecked="{Binding IsTypeWifi}"
                   Style="{StaticResource TypePillStyle}" />
      <RadioButton Content="{Binding TypeVCardLabel}"
                   IsChecked="{Binding IsTypeVCard}"
                   Style="{StaticResource TypePillStyle}" />
    </WrapPanel>

    <!-- ── Text / URL input ───────────────────────────────────────────── -->
    <Border Visibility="{Binding IsTypeTextUrl, Converter={StaticResource BoolToVis}}"
            Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
            BorderThickness="0.8" CornerRadius="8"
            Padding="12,14" Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="{Binding InputLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="12" FontWeight="SemiBold" Opacity="0.75"
                   Margin="0,0,0,6" />
        <TextBox Text="{Binding TextInput, UpdateSourceTrigger=PropertyChanged}"
                 Style="{StaticResource InputBoxStyle}"
                 FontSize="12" Height="32"
                 VerticalContentAlignment="Center"
                 Tag="{Binding InputHint}" />
      </StackPanel>
    </Border>

    <!-- ── WiFi input ─────────────────────────────────────────────────── -->
    <Border Visibility="{Binding IsTypeWifi, Converter={StaticResource BoolToVis}}"
            Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
            BorderThickness="0.8" CornerRadius="8"
            Padding="12,14" Margin="0,0,0,12">
      <StackPanel>

        <!-- Network row -->
        <TextBlock Text="{Binding WifiNetworkLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="12" FontWeight="SemiBold" Opacity="0.75"
                   Margin="0,0,0,5" />
        <Grid Margin="0,0,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="6" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!-- Network dropdown -->
          <Border Grid.Column="0"
                  Background="{DynamicResource WidgetBackgroundBrush}"
                  BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                  BorderThickness="0.8" CornerRadius="6" Height="32">
            <ComboBox ItemsSource="{Binding WifiNetworks}"
                      SelectedItem="{Binding SelectedWifiNetwork}"
                      Style="{StaticResource ThemedComboBoxStyle}"
                      Background="Transparent" BorderThickness="0"
                      Height="32" FontSize="11"
                      VerticalContentAlignment="Center">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Ssid}" FontSize="11" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Border>

          <!-- Refresh button -->
          <Button Grid.Column="2"
                  Command="{Binding LoadWifiNetworksCommand}"
                  Style="{StaticResource SecondaryButton}"
                  Height="32" Padding="10,0" ToolTip="{Binding WifiRefreshLabel}">
            <Path Data="{StaticResource IconRefresh}"
                  Stroke="{DynamicResource WidgetForegroundBrush}"
                  StrokeThickness="1.3" Stretch="Uniform"
                  Width="13" Height="13" />
          </Button>
        </Grid>

        <!-- No networks hint -->
        <TextBlock Text="{Binding WifiNoNetworksLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="11" Opacity="0.5"
                   Margin="0,0,0,6">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Visibility" Value="Collapsed" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding HasWifiNetworks}" Value="False">
                  <Setter Property="Visibility" Value="Visible" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>

        <!-- Password row -->
        <TextBlock Text="{Binding WifiPasswordLabel}"
                   Foreground="{DynamicResource WidgetForegroundBrush}"
                   FontSize="12" FontWeight="SemiBold" Opacity="0.75"
                   Margin="0,0,0,6" />
        <Border Background="{DynamicResource WidgetBackgroundBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8" CornerRadius="6" Height="32"
                Margin="0,0,0,10"
                ToolTip="{Binding WifiPasswordTooltip}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="28" />
              <ColumnDefinition Width="28" />
            </Grid.ColumnDefinitions>
            <!-- Lock icon -->
            <Path Grid.Column="0"
                  Data="{StaticResource IconLock}"
                  Stroke="{DynamicResource WidgetForegroundBrush}"
                  StrokeThickness="1.1" Stretch="Uniform"
                  Width="12" Height="12" Opacity="0.45"
                  Margin="8,0,4,0" VerticalAlignment="Center" />
            <!-- Visible TextBox (when WifiPasswordVisible=true) -->
            <TextBox Grid.Column="1"
                     Text="{Binding WifiPassword, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBoxStyle}"
                     FontSize="11" Background="Transparent" BorderThickness="0"
                     VerticalContentAlignment="Center"
                     Tag="{Binding WifiPasswordHint}"
                     Visibility="{Binding WifiPasswordVisible, Converter={StaticResource BoolToVis}}" />
            <!-- Masked TextBox (when WifiPasswordVisible=false) -->
            <TextBox Grid.Column="1"
                     Text="{Binding WifiPasswordMasked, Mode=OneWay}"
                     IsReadOnly="True"
                     Style="{StaticResource InputBoxStyle}"
                     FontSize="11" Background="Transparent" BorderThickness="0"
                     VerticalContentAlignment="Center"
                     Tag="{Binding WifiPasswordHint}"
                     Visibility="{Binding WifiPasswordVisible, Converter={StaticResource InverseBoolToVis}}" />
            <!-- Eye toggle button -->
            <Button Grid.Column="2"
                    Command="{Binding TogglePasswordVisibilityCommand}"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" VerticalAlignment="Stretch">
              <Grid Width="13" Height="13">
                <Path Data="{StaticResource IconEye}"
                      Stroke="{DynamicResource WidgetForegroundBrush}"
                      StrokeThickness="1.2" Stretch="Uniform"
                      Opacity="0.55"
                      Visibility="{Binding WifiPasswordVisible, Converter={StaticResource InverseBoolToVis}}" />
                <Path Data="{StaticResource IconEyeOff}"
                      Stroke="{DynamicResource WidgetForegroundBrush}"
                      StrokeThickness="1.2" Stretch="Uniform"
                      Opacity="0.55"
                      Visibility="{Binding WifiPasswordVisible, Converter={StaticResource BoolToVis}}" />
              </Grid>
            </Button>
            <!-- Copy password button -->
            <Button Grid.Column="3"
                    Command="{Binding CopyWifiPasswordCommand}"
                    Background="Transparent" BorderThickness="0"
                    Cursor="Hand" VerticalAlignment="Stretch"
                    ToolTip="{Binding CopyLabel}">
              <Path Data="{StaticResource IconCopy}"
                    Stroke="{DynamicResource WidgetForegroundBrush}"
                    StrokeThickness="1.2" Stretch="Uniform"
                    Width="13" Height="13" Opacity="0.55" />
            </Button>
          </Grid>
        </Border>

        <!-- Hidden network checkbox -->
        <CheckBox IsChecked="{Binding WifiIsHidden}"
                  Content="{Binding WifiHiddenLabel}"
                  Foreground="{DynamicResource WidgetForegroundBrush}"
                  FontSize="11" Cursor="Hand" />
      </StackPanel>
    </Border>

    <!-- ── vCard input ────────────────────────────────────────────────── -->
    <Border Visibility="{Binding IsTypeVCard, Converter={StaticResource BoolToVis}}"
            Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
            BorderThickness="0.8" CornerRadius="8"
            Padding="12,14" Margin="0,0,0,12">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="6" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="8" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- First name -->
        <Border Grid.Row="0" Grid.Column="0"
                Background="{DynamicResource WidgetBackgroundBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8" CornerRadius="6" Height="32">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding VCardFirstLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="10" Opacity="0.5"
                       VerticalAlignment="Center" Margin="8,0,4,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding VCardFirstName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBoxStyle}"
                     FontSize="11" Background="Transparent" BorderThickness="0"
                     VerticalContentAlignment="Center" />
          </Grid>
        </Border>

        <!-- Last name -->
        <Border Grid.Row="0" Grid.Column="2"
                Background="{DynamicResource WidgetBackgroundBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8" CornerRadius="6" Height="32">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding VCardLastLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="10" Opacity="0.5"
                       VerticalAlignment="Center" Margin="8,0,4,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding VCardLastName, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBoxStyle}"
                     FontSize="11" Background="Transparent" BorderThickness="0"
                     VerticalContentAlignment="Center" />
          </Grid>
        </Border>

        <!-- Phone -->
        <Border Grid.Row="2" Grid.Column="0"
                Background="{DynamicResource WidgetBackgroundBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8" CornerRadius="6" Height="32">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding VCardPhoneLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="10" Opacity="0.5"
                       VerticalAlignment="Center" Margin="8,0,4,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding VCardPhone, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBoxStyle}"
                     FontSize="11" Background="Transparent" BorderThickness="0"
                     VerticalContentAlignment="Center" />
          </Grid>
        </Border>

        <!-- Email -->
        <Border Grid.Row="2" Grid.Column="2"
                Background="{DynamicResource WidgetBackgroundBrush}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8" CornerRadius="6" Height="32">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding VCardEmailLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="10" Opacity="0.5"
                       VerticalAlignment="Center" Margin="8,0,4,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding VCardEmail, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource InputBoxStyle}"
                     FontSize="11" Background="Transparent" BorderThickness="0"
                     VerticalContentAlignment="Center" />
          </Grid>
        </Border>

      </Grid>
    </Border>

    <!-- ── Generate button ────────────────────────────────────────────── -->
    <Button Command="{Binding GenerateCommand}"
            Content="{Binding GenerateLabel}"
            Style="{StaticResource AccentButton}"
            HorizontalAlignment="Stretch"
            Margin="0,0,0,10" />

    <!-- ── QR preview + actions ───────────────────────────────────────── -->
    <StackPanel Visibility="{Binding HasQrBitmap, Converter={StaticResource BoolToVis}}">
      <!-- White-background frame so the QR is always readable against any theme -->
      <Border Background="White"
              BorderBrush="{DynamicResource WidgetInputBorderBrush}"
              BorderThickness="0.8" CornerRadius="6"
              HorizontalAlignment="Center"
              Padding="8" Margin="0,0,0,10">
        <Image Source="{Binding GeneratedQrBitmap}"
               MaxHeight="240" MaxWidth="240"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="NearestNeighbor" />
      </Border>

      <!-- Save / Copy row -->
      <Grid Margin="0,0,0,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="8" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Button Grid.Column="0"
                Command="{Binding SaveCommand}"
                Content="{Binding SaveLabel}"
                IsEnabled="{Binding HasQrBitmap}"
                Style="{StaticResource AccentButton}" />
        <Button Grid.Column="2"
                Command="{Binding CopyToClipboardCommand}"
                Content="{Binding CopyLabel}"
                IsEnabled="{Binding HasQrBitmap}"
                Style="{StaticResource SecondaryButton}" />
      </Grid>
    </StackPanel>

    </StackPanel> <!-- end generate mode -->

    <!-- ── Decode mode ───────────────────────────────────────────────── -->
    <Border Visibility="{Binding IsModeDecode, Converter={StaticResource BoolToVis}}"
            Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetInputBorderBrush}"
            BorderThickness="0.8" CornerRadius="8"
            Padding="12,14" Margin="0,0,0,12">
      <StackPanel>

        <!-- Drop zone -->
        <Border x:Name="DecodeDrop"
                Background="{DynamicResource WidgetAccentBrushLight}"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8" CornerRadius="6"
                AllowDrop="True"
                Drop="OnDecodeDrop"
                DragEnter="OnDecodeDragEnter"
                DragLeave="OnDecodeDragLeave"
                MinHeight="64" Margin="0,0,0,10"
                Cursor="Hand">
          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                      Margin="0,14">
            <Path Data="{StaticResource IconQrCode}"
                  Stroke="{DynamicResource WidgetForegroundBrush}"
                  StrokeThickness="1.2" Stretch="Uniform"
                  Width="24" Height="24" Opacity="0.35"
                  HorizontalAlignment="Center" Margin="0,0,0,6" />
            <TextBlock Text="{Binding DecodeHintLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="11" Opacity="0.55" TextWrapping="Wrap"
                       TextAlignment="Center" />
          </StackPanel>
        </Border>

        <!-- Browse button -->
        <Button Command="{Binding BrowseDecodeImageCommand}"
                Style="{StaticResource SecondaryButton}"
                HorizontalAlignment="Stretch"
                Height="32" Margin="0,0,0,10">
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Path Data="{StaticResource IconFolderOpen}"
                  Stroke="{DynamicResource WidgetForegroundBrush}"
                  StrokeThickness="1.2" Stretch="Uniform"
                  Width="13" Height="13" Margin="0,0,6,0" VerticalAlignment="Center" />
            <TextBlock Text="{Binding DecodeBrowseLabel}" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <!-- Decoded result (shown once HasDecodeResult is true) -->
        <StackPanel Visibility="{Binding HasDecodeResult, Converter={StaticResource BoolToVis}}">
          <TextBlock Text="{Binding DecodeResultLabel}"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     FontSize="11" FontWeight="SemiBold" Opacity="0.75"
                     Margin="0,0,0,6" />
          <Border Background="{DynamicResource WidgetInputBrush}"
                  BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                  BorderThickness="0.8" CornerRadius="6"
                  Padding="10,8" Margin="0,0,0,8">
            <TextBox Text="{Binding DecodeResult, Mode=OneWay}"
                     IsReadOnly="True"
                     OverridesDefaultStyle="True"
                     IsUndoEnabled="False"
                     FontSize="11" FontFamily="Consolas"
                     Foreground="{DynamicResource WidgetForegroundBrush}"
                     SelectionBrush="{DynamicResource WidgetAccentBrush}"
                     TextWrapping="Wrap"
                     MaxHeight="108">
              <TextBox.Template>
                <ControlTemplate TargetType="TextBox">
                  <ScrollViewer x:Name="PART_ContentHost"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                Padding="0" />
                </ControlTemplate>
              </TextBox.Template>
            </TextBox>
          </Border>
          <Button Command="{Binding CopyDecodeResultCommand}"
                  Content="{Binding DecodeCopyLabel}"
                  Style="{StaticResource SecondaryButton}"
                  HorizontalAlignment="Stretch"
                  Height="32" />
        </StackPanel>

      </StackPanel>
    </Border>

    <!-- ── Status message ────────────────────────────────────────────── -->
    <TextBlock Text="{Binding StatusMessage}"
               Visibility="{Binding HasStatusMessage, Converter={StaticResource BoolToVis}}"
               Foreground="{DynamicResource WidgetForegroundBrush}"
               FontSize="11" Opacity="0.65" TextWrapping="Wrap"
               Margin="0,8,0,0" />

  </StackPanel>
</UserControl>
