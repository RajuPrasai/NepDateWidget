<UserControl x:Class="NepDateWidget.Views.ImageConverterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             xmlns:conv="clr-namespace:NepDateWidget.Converters"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             AllowDrop="True"
             d:DataContext="{d:DesignInstance vm:ImageConverterViewModel}"
             d:Width="380">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"        Invert="False" />
        <conv:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"  />
        <conv:StringToImageSourceConverter x:Key="StringToImageSource" />

        <Style x:Key="LevelLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10.5" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="Opacity"    Value="0.65" />
        </Style>

        <!-- Format chip: unselected state; DataTrigger per chip overrides when selected -->
        <Style x:Key="FormatChipBase" TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource WidgetAccentBrushLight}" />
            <Setter Property="Foreground"       Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="BorderThickness"  Value="0" />
            <Setter Property="Padding"          Value="9,4" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Margin"           Value="0,0,4,4" />
            <Setter Property="FontSize"         Value="11" />
            <Setter Property="FontWeight"       Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <StackPanel>
        <!-- Drop zone -->
        <Border x:Name="DropZone"
                BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                BorderThickness="0.8"
                CornerRadius="8"
                Padding="12,20"
                Margin="0,0,0,8"
                Cursor="Hand"
                MouseLeftButtonDown="DropZone_MouseLeftButtonDown"
                MouseLeftButtonUp="DropZone_Click">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center">
                <Path Data="M14,3 L14,15 M9,10 L14,15 L19,10 M6,21 L22,21"
                      Stroke="{DynamicResource WidgetForegroundBrush}"
                      StrokeThickness="1.7" StrokeLineJoin="Round"
                      Stretch="Uniform" Width="28" Height="28"
                      HorizontalAlignment="Center" Margin="0,0,0,6" Opacity="0.45" />
                <TextBlock Text="{Binding DropLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="13" HorizontalAlignment="Center" Opacity="0.7" />
                <TextBlock Text="{Binding BrowseLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="11" HorizontalAlignment="Center" Opacity="0.45" Margin="0,2,0,0" />
            </StackPanel>
        </Border>

        <!-- File list (visible when files loaded and no summary) -->
        <ItemsControl ItemsSource="{Binding Files}" MaxHeight="130" Margin="0,0,0,8"
                      Visibility="{Binding ShowFileList, Converter={StaticResource BoolToVis}}">
            <ItemsControl.Template>
                <ControlTemplate>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsPresenter />
                    </ScrollViewer>
                </ControlTemplate>
            </ItemsControl.Template>
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:CompressionFileItemViewModel}">
                    <Grid Margin="0,0,0,3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Thumbnail -->
                        <Border Grid.Column="0" Height="30" VerticalAlignment="Center" Margin="0,0,6,0">
                            <Image Source="{Binding FilePath, Converter={StaticResource StringToImageSource}}"
                                   Height="30" Stretch="Uniform">
                                <Image.Clip>
                                    <RectangleGeometry RadiusX="6" RadiusY="6" Rect="0,0,30,30" />
                                </Image.Clip>
                            </Image>
                        </Border>
                        <!-- Filename + input size -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding FileName}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="12" TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{Binding FileSizeLabel}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.55" FontSize="10.5" />
                        </StackPanel>
                        <!-- Output size (shown after done) -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding OutputSizeLabel}"
                                   Foreground="{DynamicResource WidgetAccentBrush}"
                                   FontSize="11" VerticalAlignment="Center" Margin="6,0,6,0"
                                   Visibility="{Binding IsDone, Converter={StaticResource BoolToVis}}" />
                        <!-- Remove button -->
                        <Button Grid.Column="3"
                                Command="{Binding DataContext.RemoveFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                CommandParameter="{Binding FilePath}"
                                ToolTip="{Binding DataContext.RemoveFileLabel, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Visibility="{Binding DataContext.IsJobRunning, RelativeSource={RelativeSource AncestorType=UserControl},
                                             Converter={StaticResource InverseBoolToVis}}">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background"      Value="Transparent" />
                                    <Setter Property="BorderThickness" Value="0" />
                                    <Setter Property="Padding"         Value="4" />
                                    <Setter Property="Cursor"          Value="Hand" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        Padding="{TemplateBinding Padding}" CornerRadius="4">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource WidgetAccentBrushLight}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <Path Data="M6 18L18 6M6 6l12 12"
                                  Stroke="{DynamicResource WidgetForegroundBrush}"
                                  StrokeThickness="1.3" Stretch="Uniform"
                                  Width="9" Height="9" />
                        </Button>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Format section -->
        <StackPanel Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Path Data="{StaticResource IconImageConvert}"
                      Stroke="{DynamicResource WidgetForegroundBrush}"
                      StrokeThickness="1.2" Stretch="Uniform"
                      Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,5,0" />
                <TextBlock Text="{Binding FormatSectionLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="12" FontWeight="SemiBold" />
            </StackPanel>
            <!-- Format chips -->
            <WrapPanel>
                <!-- JPEG -->
                <Button Command="{Binding SelectFormatCommand}" CommandParameter="jpg">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormatJpeg}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="JPEG" />
                </Button>
                <!-- PNG -->
                <Button Command="{Binding SelectFormatCommand}" CommandParameter="png">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormatPng}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="PNG" />
                </Button>
                <!-- WebP -->
                <Button Command="{Binding SelectFormatCommand}" CommandParameter="webp">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormatWebp}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="WebP" />
                </Button>
                <!-- AVIF -->
                <Button Command="{Binding SelectFormatCommand}" CommandParameter="avif">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormatAvif}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="AVIF" />
                </Button>
                <!-- GIF -->
                <Button Command="{Binding SelectFormatCommand}" CommandParameter="gif">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormatGif}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="GIF" />
                </Button>
                <!-- BMP -->
                <Button Command="{Binding SelectFormatCommand}" CommandParameter="bmp">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormatBmp}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="BMP" />
                </Button>
                <!-- TIFF -->
                <Button Command="{Binding SelectFormatCommand}" CommandParameter="tif">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormatTiff}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="TIFF" />
                </Button>
                <!-- ICO -->
                <Button Command="{Binding SelectFormatCommand}" CommandParameter="ico">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormatIco}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="ICO" />
                </Button>
                <!-- TGA -->
                <Button Command="{Binding SelectFormatCommand}" CommandParameter="tga">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource FormatChipBase}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsFormatTga}" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <TextBlock Text="TGA" />
                </Button>
            </WrapPanel>
        </StackPanel>

        <!-- Quality section (lossy formats only: JPEG, WebP, AVIF) -->
        <StackPanel Margin="0,0,0,10"
                    Visibility="{Binding ShowQuality, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Path Data="{StaticResource IconSettings}"
                      Stroke="{DynamicResource WidgetForegroundBrush}"
                      StrokeThickness="1.2" Stretch="Uniform"
                      Width="11" Height="11" VerticalAlignment="Center" Margin="0,0,5,0" />
                <TextBlock Text="{Binding QualitySectionLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="12" FontWeight="SemiBold" />
            </StackPanel>
            <!-- Apply compression toggle -->
            <CheckBox Content="{Binding CompressToggleLabel}"
                      IsChecked="{Binding ApplyCompression}"
                      Style="{StaticResource WidgetCheckBox}"
                      Margin="0,0,0,8" />
            <!-- Quality slider (only when compression is enabled) -->
            <StackPanel Visibility="{Binding ShowQualitySlider, Converter={StaticResource BoolToVis}}">
                <Slider Minimum="0" Maximum="4"
                        Value="{Binding QualityLevel}"
                        Style="{DynamicResource IosSlider}"
                        IsSnapToTickEnabled="True" TickFrequency="1"
                        SmallChange="1" LargeChange="1"
                        Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding LevelSmallestLabel}"  Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Left" />
                    <TextBlock Grid.Column="1" Text="{Binding LevelLowLabel}"       Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="2" Text="{Binding LevelBalancedLabel}"  Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="3" Text="{Binding LevelHighLabel}"      Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Center" />
                    <TextBlock Grid.Column="4" Text="{Binding LevelBestLabel}"      Style="{StaticResource LevelLabelStyle}" HorizontalAlignment="Right" />
                </Grid>
            </StackPanel>
        </StackPanel>

        <!-- Strip metadata toggle -->
        <CheckBox Content="{Binding StripMetaLabel}"
                  IsChecked="{Binding StripMetadata}"
                  Style="{StaticResource WidgetCheckBox}"
                  Margin="0,0,0,10" />

        <!-- Progress -->
        <StackPanel Margin="0,0,0,8"
                    Visibility="{Binding IsJobRunning, Converter={StaticResource BoolToVis}}">
            <Grid Margin="0,0,0,5">
                <TextBlock Text="{Binding ProgressTitleLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="12" FontWeight="SemiBold" />
                <TextBlock Text="{Binding ProgressLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="11" Opacity="0.6" HorizontalAlignment="Right" />
            </Grid>
            <ProgressBar Minimum="0"
                         Maximum="{Binding TotalCount}"
                         Value="{Binding CompletedCount, Mode=OneWay}"
                         Style="{StaticResource WidgetProgressBar}" />
        </StackPanel>

        <!-- Convert button -->
        <Button Style="{StaticResource AccentButton}"
                Command="{Binding ConvertCommand}"
                IsEnabled="{Binding IsConvertButtonEnabled}"
                Height="36"
                Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal">
                <Path Data="{StaticResource IconImageConvert}"
                      Stroke="{DynamicResource WidgetDayTodayTextBrush}"
                      StrokeThickness="1.3" Stretch="Uniform"
                      Width="12" Height="12" VerticalAlignment="Center" Margin="0,0,6,0" />
                <TextBlock Text="{Binding ConvertButtonLabel}" VerticalAlignment="Center" />
            </StackPanel>
        </Button>

        <!-- Summary banner -->
        <Border Background="{DynamicResource WidgetAccentBrushLight}"
                BorderBrush="{DynamicResource WidgetAccentBrush}"
                BorderThickness="1.5"
                CornerRadius="8"
                Padding="10,9"
                Visibility="{Binding ShowSummary, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" FlowDirection="LeftToRight">
                    <Path Data="{StaticResource IconCheck}"
                          Stroke="{DynamicResource WidgetAccentBrush}"
                          StrokeThickness="1.8" Fill="Transparent"
                          Stretch="Uniform" Width="13" Height="13"
                          VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Text="{Binding SummaryFilesSegment}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                    <TextBlock Text=" | "
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               Opacity="0.35" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding SummarySizeSegment}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="12" VerticalAlignment="Center" />
                </StackPanel>
                <!-- Dismiss -->
                <Button Grid.Column="1"
                        Command="{Binding DismissSummaryCommand}"
                        VerticalAlignment="Center" Margin="10,0,0,0"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background"      Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Padding"         Value="5" />
                            <Setter Property="Opacity"         Value="0.55" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
                                                <Setter Property="Opacity"    Value="1" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <Path Data="M6 18L18 6M6 6l12 12"
                          Stroke="{DynamicResource WidgetForegroundBrush}"
                          StrokeThickness="1.4" Stretch="Uniform"
                          Width="10" Height="10" />
                </Button>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
