<UserControl x:Class="NepDateWidget.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             Foreground="{DynamicResource WidgetForegroundBrush}"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             d:DataContext="{d:DesignInstance vm:AboutViewModel}"
             d:Width="380">

    <UserControl.Resources>

        <!-- Muted section label -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Opacity"    Value="0.55" />
            <Setter Property="Margin"     Value="0,0,0,8" />
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="8,6,8,14"
                    MaxWidth="1024">

            <!-- ── Hero ─────────────────────────────────────────────────────── -->
            <Border Background="{DynamicResource WidgetBackgroundBrush}"
                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                    BorderThickness="0.7"
                    CornerRadius="8"
                    Padding="16,14,16,14"
                    Margin="0,0,0,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                        <Image Source="/Assets/icon.png"
                               Width="20" Height="20"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               VerticalAlignment="Center"
                               Margin="0,0,7,0"
                               IsHitTestVisible="False" />
                        <TextBlock Text="NepDate Widget"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource WidgetAccentBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding TaglineLabel}"
                               FontSize="13"
                               Opacity="0.8"
                               Margin="1,4,0,6" />
          <Border Background="{DynamicResource WidgetDayTodayTextBrush}"
                            BorderBrush="{DynamicResource WidgetInputBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="8,2,8,2"
                            HorizontalAlignment="Left">
            <TextBlock FontSize="12" Opacity="0.8" Foreground="{DynamicResource WidgetSuccessBrush}">
                            <Run Text="v" /><Run Text="{Binding AppVersion, Mode=OneWay}"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Support ───────────────────────────────────────────────────── -->
            <Border Background="{DynamicResource WidgetBackgroundBrush}"
                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                    BorderThickness="0.7"
                    CornerRadius="8"
                    Padding="14,12,14,14"
                    Margin="0,0,0,18">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="{StaticResource IconHeart}"
                              Stroke="{DynamicResource WidgetSuccessBrush}"
                              StrokeThickness="1.1"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              VerticalAlignment="Center"
                              Margin="0,0,7,0" />
                        <TextBlock Text="{Binding SupportHeading}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WidgetSuccessBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <TextBlock Text="{Binding SupportBody}"
                               FontSize="12"
                               Opacity="0.75"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <Button Style="{StaticResource AccentButtonSm}"
                            Command="{Binding OpenSupportCommand}"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconHeart}"
                                  Stroke="{DynamicResource WidgetDayTodayTextBrush}"
                                  StrokeThickness="1.4"
                                  Fill="Transparent"
                                  Stretch="Uniform"
                                  Width="13" Height="13"
                                  VerticalAlignment="Center"
                                  Margin="0,0,7,0" />
                            <TextBlock Text="{Binding SupportButtonLabel}" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- ── Links ─────────────────────────────────────────────────────── -->
            <Border Background="{DynamicResource WidgetBackgroundBrush}"
                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                    BorderThickness="0.7"
                    CornerRadius="8"
                    Padding="14,12,14,12"
                    Margin="0,0,0,8">
                <StackPanel>
                    <TextBlock Text="{Binding LinksHeading}"
                               Style="{StaticResource SectionLabel}" />
                    <UniformGrid Columns="2" Rows="2">
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding OpenRepoCommand}"
                                Margin="0,0,4,4">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconScript}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}"
                                      StrokeThickness="1.1"
                                      Stretch="Uniform"
                                      Width="11" Height="11"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,0" />
                                <TextBlock Text="{Binding RepoButtonLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding OpenBugReportCommand}"
                                Margin="0,0,0,4">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconNote}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}"
                                      StrokeThickness="1.1"
                                      Stretch="Uniform"
                                      Width="11" Height="11"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,0" />
                                <TextBlock Text="{Binding BugButtonLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding OpenChangelogCommand}"
                                Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconFiles}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}"
                                      StrokeThickness="1.1"
                                      Stretch="Uniform"
                                      Width="11" Height="11"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,0" />
                                <TextBlock Text="{Binding ChangelogButtonLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}"
                                Command="{Binding OpenWebsiteCommand}"
                                Margin="0,0,0,0">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconExternalLink}"
                                      Stroke="{DynamicResource WidgetForegroundBrush}"
                                      StrokeThickness="1.1"
                                      Stretch="Uniform"
                                      Width="11" Height="11"
                                      VerticalAlignment="Center"
                                      Margin="0,0,6,0" />
                                <TextBlock Text="{Binding WebsiteButtonLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </UniformGrid>
                </StackPanel>
            </Border>

            <!-- ── Footer ───────────────────────────────────────────────────── -->
            <StackPanel HorizontalAlignment="Center" Margin="0,4,0,0">
                <TextBlock Text="{Binding BuiltByLabel}"
                           FontSize="11"
                           Opacity="0.38"
                           HorizontalAlignment="Center" />
                <TextBlock Text="© 2025-2026 NepDate Widget"
                           FontSize="10"
                           Opacity="0.28"
                           HorizontalAlignment="Center"
                           Margin="0,2,0,0" />
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</UserControl>
