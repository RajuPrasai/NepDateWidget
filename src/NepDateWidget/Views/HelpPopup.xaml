<Window x:Class="NepDateWidget.Views.HelpPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Help"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource WidgetForegroundBrush}"
        FontFamily="{DynamicResource WidgetFontFamily}"
        SizeToContent="Height"
        Width="340"
        Opacity="0">

    <Window.Resources>
    </Window.Resources>

    <Border Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetBorderBrush}"
            BorderThickness="0.7"
            CornerRadius="12"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" Opacity="0.30" ShadowDepth="3" Direction="270" />
        </Border.Effect>

        <StackPanel>

            <!-- Header -->
            <Border Padding="16,8,12,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="TitleText"
                               Grid.Column="0"
                               Foreground="{DynamicResource WidgetAccentBrush}"
                               FontSize="15" FontWeight="Bold"
                               TextTrimming="CharacterEllipsis"
                               Margin="0,2.5,8,0" />
                    <Button Grid.Column="1"
                            Style="{StaticResource PopupCloseBtn}"
                            Click="CloseBtn_Click">
                        <Path Data="{StaticResource IconWindowClose}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.3" Stretch="Uniform"
                              Width="10" Height="10" />
                    </Button>
                </Grid>
            </Border>

            <!-- Separator -->
            <Border Height="0.7" Background="{DynamicResource WidgetBorderBrush}" Margin="0,0" />

            <!-- Body -->
            <StackPanel Margin="10,12,10,10">

                <!-- Description -->
                <TextBlock x:Name="DescText"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="13.5" Opacity="1"
                           TextWrapping="Wrap"
                           Margin="0,0,0,12" />

                <!-- How to use -->
                <TextBlock x:Name="HowHeading"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="14" FontWeight="SemiBold"
                           Opacity="0.7"
                           Margin="0,0,0,6" />
                <ItemsControl x:Name="HowList" Margin="0,0,0,12">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="·"
                                           Foreground="{DynamicResource WidgetAccentBrush}"
                                           FontSize="14" FontWeight="Bold"
                                           VerticalAlignment="Top"
                                           Margin="0,-1,0,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding}"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           FontSize="13" Opacity="0.85"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Benefits -->
                <TextBlock x:Name="WhyHeading"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="14" FontWeight="SemiBold"
                           Opacity="0.7"
                           Margin="0,0,0,6" />
                <ItemsControl x:Name="WhyList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="·"
                                           Foreground="{DynamicResource WidgetAccentBrush}"
                                           FontSize="14" FontWeight="Bold"
                                           VerticalAlignment="Top"
                                           Margin="0,-1,0,0" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding}"
                                           Foreground="{DynamicResource WidgetForegroundBrush}"
                                           FontSize="13" Opacity="0.85"
                                           TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

        </StackPanel>
    </Border>
</Window>
