<UserControl x:Class="NepDateWidget.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
             xmlns:cvt="clr-namespace:NepDateWidget.Converters"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             TextOptions.TextFormattingMode="Display"
             TextOptions.TextRenderingMode="ClearType"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel}"
             d:Width="380">

    <UserControl.Resources>
        <cvt:BoolToVisibilityConverter x:Key="BoolToVis"        Invert="False" />
        <cvt:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True"  />
        <CubicEase x:Key="SmoothEase" EasingMode="EaseInOut" />
        <!-- Toggle style for option buttons (radio-like) -->
        <Style x:Key="OptionButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="0.7" />
            <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Height"          Value="28" />
            <Setter Property="Padding"         Value="10,0" />
            <Setter Property="Margin"          Value="0,0,4,4" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0.82" Duration="0:0:0.1" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard FillBehavior="Stop">
                                            <DoubleAnimation Storyboard.TargetName="Bd"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="1" Duration="0:0:0.15" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource WidgetHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Checkbox style - iOS-style toggle switch -->
        <Style x:Key="SettingsCheckBox" TargetType="CheckBox">
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="Cursor"  Value="Hand" />
            <Setter Property="Margin"  Value="0,5" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Border x:Name="Track"
                                    Width="36" Height="20"
                                    CornerRadius="10"
                                    Background="{DynamicResource WidgetInputBrush}"
                                    BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                    BorderThickness="0.7">
                                <Border x:Name="Thumb"
                                        Width="16" Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource WidgetInputBorderBrush}"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Margin="1,0,0,0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="ThumbTranslate" X="0" />
                                    </Border.RenderTransform>
                                </Border>
                            </Border>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background"  Value="{DynamicResource WidgetAccentBrush}" />
                                <Setter TargetName="Track" Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}" />
                                <Setter TargetName="Thumb" Property="Background"  Value="White" />
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="18" Duration="0:0:0.18"
                                                             EasingFunction="{StaticResource SmoothEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate"
                                                             Storyboard.TargetProperty="X"
                                                             To="0" Duration="0:0:0.18"
                                                             EasingFunction="{StaticResource SmoothEase}" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label (card title) -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="Margin"     Value="0,0,0,8" />
        </Style>

        <!-- Bootstrap-style card panel -->
        <Style x:Key="CardPanel" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource WidgetBackgroundBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="0.7" />
            <Setter Property="CornerRadius"    Value="8" />
            <Setter Property="Padding"         Value="10,8" />
            <Setter Property="Margin"          Value="0,0,0,8" />
        </Style>

        <!-- Fully themed ComboBox: fixes white-background in dark mode -->
        <Style x:Key="ThemedComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height"          Value="28" />
            <Setter Property="Background"      Value="{DynamicResource WidgetInputBrush}" />
            <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="BorderBrush"     Value="{DynamicResource WidgetInputBorderBrush}" />
            <Setter Property="BorderThickness" Value="0.7" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Padding"         Value="6,0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility"   Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll"              Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Background / border -->
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4" />
                            <!-- Transparent full-area click target that toggles the dropdown -->
                            <ToggleButton Focusable="False"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                       RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ToggleButton">
                                                    <Border Background="Transparent" />
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                            <!-- Selected-item display -->
                            <ContentPresenter x:Name="ContentSite"
                                              Margin="8,0,28,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False" />
                            <!-- Dropdown arrow -->
                            <TextBlock Text="▾"
                                       FontSize="11"
                                       Foreground="{TemplateBinding Foreground}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,8,0"
                                       IsHitTestVisible="False" />
                            <!-- Dropdown popup -->
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource WidgetInputBrush}"
                                        BorderBrush="{DynamicResource WidgetInputBorderBrush}"
                                        BorderThickness="0.7"
                                        CornerRadius="4"
                                        Margin="0,2,0,0">
                                    <Border.Resources>
                                        <Style TargetType="ComboBoxItem">
                                            <Setter Property="OverridesDefaultStyle" Value="True" />
                                            <Setter Property="Background"      Value="{DynamicResource WidgetInputBrush}" />
                                            <Setter Property="Foreground"      Value="{DynamicResource WidgetForegroundBrush}" />
                                            <Setter Property="Padding"         Value="8,5" />
                                            <Setter Property="BorderThickness" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ComboBoxItem">
                                                        <Border Background="{TemplateBinding Background}"
                                                                TextElement.Foreground="{TemplateBinding Foreground}"
                                                                Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsHighlighted" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
                                                    <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Resources>
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="Background"
                                        Value="{DynamicResource WidgetHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="MainBorder" Property="Background"
                                        Value="{DynamicResource WidgetHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  Focusable="False"
                  PanningMode="VerticalOnly">
        <StackPanel Margin="10,8,10,10"
                    MaxWidth="1024">

            <!-- ══ Card: Appearance ════════════════════════════════════════ -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="{Binding AppearanceSectionLabel}" Style="{StaticResource SectionLabel}" />

                    <!-- Language -->
                    <TextBlock Text="{Binding LanguageLabel}"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,0,4" />
                    <WrapPanel Margin="0,0,0,10">
                        <Button Content="English" Command="{Binding SetLanguageEnCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLanguageEn}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="नेपाली" Command="{Binding SetLanguageNeCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLanguageNe}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>

                    <!-- Theme -->
                    <TextBlock Text="{Binding ThemeLabel}"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,0,4" />
                    <WrapPanel Margin="0,0,0,10">
                        <Button Content="{Binding ThemeDarkLabel}" Command="{Binding SetThemeDarkCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsThemeDark}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding ThemeLightLabel}" Command="{Binding SetThemeLightCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsThemeLight}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>

                    <!-- Background Preset -->
                    <TextBlock Text="{Binding BackgroundLabel}"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,0,4" />
                    <WrapPanel Margin="0,0,0,10">
                        <Button Content="{Binding PresetDefaultLabel}"  Command="{Binding SetPresetDefaultCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetDefault}"    Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding PresetOceanLabel}"    Command="{Binding SetPresetOceanCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetOcean}"      Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding PresetForestLabel}"   Command="{Binding SetPresetForestCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetForest}"     Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding PresetSunsetLabel}"   Command="{Binding SetPresetSunsetCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetSunset}"     Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding PresetMonoLabel}"     Command="{Binding SetPresetMonoCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetMonochrome}"  Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding PresetAuroraLabel}"   Command="{Binding SetPresetAuroraCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetAurora}"     Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding PresetCherryLabel}"   Command="{Binding SetPresetCherryCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetCherry}"     Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding PresetMidnightLabel}" Command="{Binding SetPresetMidnightCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetMidnight}"   Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding PresetSlateLabel}"    Command="{Binding SetPresetSlateCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetSlate}"      Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding PresetEmberLabel}"    Command="{Binding SetPresetEmberCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPresetEmber}"      Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>

                    <!-- Corner Style -->
                    <TextBlock Text="{Binding CornerStyleLabel}"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,0,0,4" />
                    <WrapPanel>
                        <Button Content="{Binding CornerRoundedLabel}" Command="{Binding SetCornerRoundedCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCornerRounded}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="{Binding CornerSharpLabel}"   Command="{Binding SetCornerSharpCommand}">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCornerSharp}"   Value="True">
                                            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>

                    <!-- Font -->
                    <TextBlock Text="{Binding FontLabel}"
                               Style="{StaticResource FieldLabel}"
                               Margin="0,6,0,4" />
                    <ComboBox ItemsSource="{x:Static vm:SettingsViewModel.FontFamilyNames}"
                              SelectedItem="{Binding FontFamily}"
                              MaxDropDownHeight="220"
                              Style="{StaticResource ThemedComboBoxStyle}"
                              Margin="0,0,0,6" />
                    <!-- Help badges -->
                    <CheckBox Content="{Binding ShowHelpBadgesLabel}"
                              IsChecked="{Binding ShowHelpBadges}"
                              Style="{StaticResource SettingsCheckBox}"
                              Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- ══ Card: Collapsed Display ═════════════════════════════════ -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="{Binding CollapsedDisplayLabel}" Style="{StaticResource SectionLabel}" />

                    <!-- Master toggle: Show Timezone (controls time/tz/offset/format) -->
                    <CheckBox Content="{Binding ShowTimezoneLabel}"
                              IsChecked="{Binding ShowTimezone}"
                              Style="{StaticResource SettingsCheckBox}" />

                    <!-- Timezone sub-settings: only visible when ShowTimezone is checked -->
                    <StackPanel Visibility="{Binding ShowTimezone, Converter={StaticResource BoolToVis}}"
                                Margin="16,0,0,0">
                        <!-- Clock format: 12h / 24h -->
                        <TextBlock Text="{Binding ClockFormatLabel}"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,6,0,4" />
                        <WrapPanel Margin="0,0,0,8">
                            <Button Content="12h" Command="{Binding SetClockFormat12hCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsClockFormat12h}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="24h" Command="{Binding SetClockFormat24hCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource OptionButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsClockFormat24h}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}"/>
                                                <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource WidgetAccentBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </WrapPanel>

                        <TextBlock Text="{Binding TimezoneLabel}"
                                   Style="{StaticResource FieldLabel}"
                                   Margin="0,6,0,4" />
                        <ComboBox ItemsSource="{Binding Timezones}"
                                  SelectedItem="{Binding SelectedTimezone}"
                                  DisplayMemberPath="DisplayName"
                                  TextSearch.TextPath="DisplayName"
                                  IsTextSearchEnabled="True"
                                  MaxDropDownHeight="340"
                                  Style="{StaticResource ThemedComboBoxStyle}"
                                  Margin="0,0,0,6" />

                        <CheckBox Content="{Binding ShowOffsetLabel}"
                                  IsChecked="{Binding ShowOffset}"
                                  Style="{StaticResource SettingsCheckBox}" />
                        <CheckBox Content="{Binding ShowSecondsLabel}"
                                  IsChecked="{Binding ShowSecondsInClock}"
                                  Style="{StaticResource SettingsCheckBox}" />
                    </StackPanel>

