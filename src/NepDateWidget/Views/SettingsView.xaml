                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource WidgetForegroundBrush}" />
                                                    </Trigger>
                                                    <DataTrigger Binding="{Binding IsHighlightColorBrown}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource WidgetForegroundBrush}" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- ══ Card: Behavior ══════════════════════════════════════════ -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="{Binding BehaviorSectionLabel}" Style="{StaticResource SectionLabel}" />
                    <CheckBox Content="{Binding AnimationLabel}"
                              IsChecked="{Binding AnimationEnabled}"
                              Style="{StaticResource SettingsCheckBox}" />
                    <CheckBox Content="{Binding AutoStartLabel}"
                              IsChecked="{Binding AutoStart}"
                              Style="{StaticResource SettingsCheckBox}" />
                </StackPanel>
            </Border>

            <!-- ══ Card: Notification ═══════════════════════════════════════ -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="{Binding NotificationSectionLabel}" Style="{StaticResource SectionLabel}" />
                    <CheckBox Content="{Binding NotificationSoundLabel}"
                              IsChecked="{Binding NotificationSound}"
                              Style="{StaticResource SettingsCheckBox}" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding NotificationDurationLabel}"
                                   Style="{StaticResource FieldLabel}"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding NotificationDurationDisplay}"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <Slider Minimum="5" Maximum="60"
                            Value="{Binding NotificationDurationSeconds}"
                            SmallChange="5" LargeChange="10"
                            TickFrequency="5" IsSnapToTickEnabled="True"
                            Style="{DynamicResource IosSlider}" />
                    <Button Content="{Binding TestNotificationLabel}"
                            Command="{Binding TestNotificationCommand}"
                            Style="{StaticResource OptionButton}"
                            HorizontalAlignment="Left"
                            Margin="0,6,0,0" />
                </StackPanel>
            </Border>

            <!-- Log file size ──────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding LogSizeLabel}"
                                   Style="{StaticResource SectionLabel}"
                                   Margin="0" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LogMaxSizeMbDisplay}"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   VerticalAlignment="Center" />
                    </Grid>
                    <Slider Minimum="5" Maximum="100"
                            Value="{Binding LogMaxSizeMb}"
                            SmallChange="5" LargeChange="10"
                            TickFrequency="5" IsSnapToTickEnabled="True"
                            Style="{DynamicResource IosSlider}" />
                </StackPanel>
            </Border>

            <!-- Hotkey configuration ─────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="{Binding HotkeyLabel}"
                               Style="{StaticResource SectionLabel}" />
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="HotkeyInput"
                                 Text="{Binding HotkeyDisplayText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Style="{StaticResource InputBoxStyle}"
                                 Cursor="Hand"
                                 GotFocus="HotkeyInput_GotFocus"
                                 LostFocus="HotkeyInput_LostFocus"
                                 PreviewKeyDown="HotkeyInput_PreviewKeyDown" />
                        <Button Grid.Column="1"
                                Content="{Binding HotkeyClearLabel}"
                                Command="{Binding ClearHotkeyCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="6,0,0,0"
                                VerticalAlignment="Center" />
                    </Grid>
                    <TextBlock Text="{Binding HotkeyErrorText}"
                               Foreground="{DynamicResource WidgetErrorBrush}"
                               FontSize="11"
                               Visibility="{Binding HasHotkeyError, Converter={StaticResource BoolToVis}}"
                               Margin="0,4,0,0"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <!-- Data files ───────────────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}">
                <StackPanel>
                    <TextBlock Text="Data Files"
                               Style="{StaticResource SectionLabel}" />

                    <!-- Individual file rows -->
                    <!-- settings.json -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconSettings}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="settings.json"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="Preferences and widget configuration"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenSettingsFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- shortcuts.json -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconScript}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="shortcuts.json"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="RunBox prefix shortcuts - add, edit, or disable"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenShortcutsFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- reminders.json -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconBell}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="reminders.json"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="All reminders and their recurrence rules"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenRemindersFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- notes.json -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconNote}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="notes.json"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="Calendar day notes"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenNotesFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- documents.json -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconText}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="documents.json"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="Saved document library entries"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenDocumentsFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- run-history.json -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconClock}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="run-history.json"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="RunBox command history"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenRunHistoryFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- scripts.json -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconScript}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="scripts.json"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="User-defined script commands for RunBox"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenScriptsFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- runtime.json -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconSettings}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="runtime.json"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="Internal app state (notifications)"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenRuntimeFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- nepdate.log -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconText}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="localization.json"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="UI localization strings (en / ne)"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenLocalizationFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- nepdate.log -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Path Grid.Column="0"
                              Data="{StaticResource IconText}"
                              Stroke="{DynamicResource WidgetForegroundBrush}"
                              StrokeThickness="1.2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Stretch="Uniform"
                              Width="12" Height="12"
                              Opacity="0.45"
                              VerticalAlignment="Center"
                              Margin="0,0,9,0" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="nepdate.log"
                                       FontSize="12" FontFamily="Cascadia Code, Consolas, monospace"
                                       Foreground="{DynamicResource WidgetForegroundBrush}" />
                            <TextBlock Text="Application activity and error log"
                                       FontSize="10.5"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       Opacity="0.45"
                                       Margin="0,1,0,0" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="Open"
                                Command="{Binding OpenLogFileCommand}"
                                Style="{StaticResource OptionButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <!-- Backup / restore ────────────────────────────────── -->
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0"
                                Content="{Binding ExportBackupLabel}"
                                Command="{Binding ExportBackupCommand}"
                                Style="{StaticResource OptionButton}"
                                HorizontalAlignment="Stretch" />
                        <Button Grid.Column="2"
                                Content="{Binding ImportBackupLabel}"
                                Command="{Binding ImportBackupCommand}"
                                Style="{StaticResource OptionButton}"
                                HorizontalAlignment="Stretch" />
                    </Grid>

                    <!-- Inline toast for missing files -->
                    <TextBlock Text="{Binding DataFileMessage}"
                               FontSize="11"
                               Foreground="{DynamicResource WidgetAccentBrush}"
                               Opacity="0.85"
                               Margin="0,6,0,0"
                               Visibility="{Binding HasDataFileMessage, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Border>

            <!-- Reset to defaults ───────────────────────────────── -->
            <Border Style="{StaticResource CardPanel}">
                <Button Content="{Binding ResetToDefaultsLabel}"
                        Command="{Binding ResetToDefaultsCommand}"
                        Style="{StaticResource OptionButton}"
                        HorizontalAlignment="Stretch"
                        Background="{DynamicResource WidgetAccentBrush}"
                        Foreground="{DynamicResource WidgetDayTodayTextBrush}"
                        BorderBrush="{DynamicResource WidgetAccentBrush}" />
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
