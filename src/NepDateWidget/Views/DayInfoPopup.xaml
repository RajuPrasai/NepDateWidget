<Window x:Class="NepDateWidget.Views.DayInfoPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:NepDateWidget.ViewModels"
        xmlns:conv="clr-namespace:NepDateWidget.Converters"
        Title="Day Info"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Foreground="{DynamicResource WidgetForegroundBrush}"
        SizeToContent="Height"
        Width="380"
        d:DataContext="{d:DesignInstance vm:DayInfoViewModel}"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:BoolToVisibilityConverter x:Key="InverseBoolToVis" Invert="True" />

        <Style x:Key="DBtn" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource WidgetAccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetDayTodayTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DBtnSecondary" TargetType="Button" BasedOn="{StaticResource DBtn}">
            <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
        </Style>

        <Style x:Key="DBtnIcon" TargetType="Button" BasedOn="{StaticResource DBtn}">
            <Setter Property="Background" Value="{DynamicResource WidgetInputBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="Padding" Value="4,4" />
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
        </Style>

        <Style x:Key="DLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource WidgetForegroundBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Margin" Value="0,4,0,2" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource WidgetBackgroundBrush}"
            BorderBrush="{DynamicResource WidgetBorderBrush}"
            BorderThickness="0.7"
            CornerRadius="10"
            ClipToBounds="True"
            Padding="18,16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" Opacity="0.25" ShadowDepth="2" Direction="270" />
        </Border.Effect>

        <StackPanel>

            <!-- ── Header ──────────────────────────────────────────────── -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding BsDateLong}"
                               Foreground="{DynamicResource WidgetForegroundBrush}"
                               FontSize="16" FontWeight="SemiBold" />
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding DayOfWeekLabel}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   FontSize="12" Opacity="0.55" />
                        <TextBlock Text=" • "
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   FontSize="12" Opacity="0.55"
                                   Visibility="{Binding AdDateLong, Converter={StaticResource BoolToVis}}" />
                        <TextBlock Text="{Binding AdDateLong}"
                                   Foreground="{DynamicResource WidgetForegroundBrush}"
                                   FontSize="12" Opacity="0.55" />
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1" Command="{Binding CloseCommand}"
                        Style="{StaticResource DBtnIcon}"
                        VerticalAlignment="Top">
                    <Path Data="M18 6L6 18M6 6l12 12"
                          Stroke="{DynamicResource WidgetForegroundBrush}"
                          StrokeThickness="1.5" Stretch="Uniform"
                          Width="12" Height="12" />
                </Button>
            </Grid>

            <!-- public holiday badge -->
            <Border CornerRadius="4" Padding="6,2" Margin="0,0,0,4"
                    Background="{DynamicResource WidgetDaySaturdayBrush}"
                    HorizontalAlignment="Left"
                    Visibility="{Binding IsHoliday, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding HolidayBadgeLabel}"
                           Foreground="White"
                           FontSize="12" FontWeight="SemiBold" />
            </Border>

            <Border Height="0.7"
                    Background="{DynamicResource WidgetDividerBrush}"
                    Margin="0,0,0,6" />

            <!-- ── Calendar info ─────────────────────────────────────── -->

            <!-- Tithi row -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4"
                        Visibility="{Binding HasTithi, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding TithiLabel}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="13" Opacity="0.6" Margin="0,0,6,0" />
                <TextBlock Text="{Binding TithiText}"
                           Foreground="{DynamicResource WidgetForegroundBrush}"
                           FontSize="13" FontWeight="SemiBold" />
            </StackPanel>

            <!-- Events section -->
            <TextBlock Text="{Binding EventsLabel}" Style="{StaticResource DLabel}" />
            <TextBlock Text="{Binding NoEventsLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       Opacity="0.45" FontSize="13" Margin="0,0,0,6"
                       Visibility="{Binding HasEvents, Converter={StaticResource InverseBoolToVis}}" />
            <ItemsControl ItemsSource="{Binding Events}"
                          Margin="0,0,0,6"
                          Visibility="{Binding HasEvents, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <Ellipse Width="6" Height="6"
                                     Fill="{DynamicResource WidgetAccentBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="{Binding}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="13"
                                       TextWrapping="Wrap"
                                       MaxWidth="300" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Height="0.7"
                    Background="{DynamicResource WidgetDividerBrush}"
                    Margin="0,0,0,6" />

            <!-- ── Note section ──────────────────────────────────────── -->
            <TextBlock Text="{Binding NoteLabel}" Style="{StaticResource DLabel}" Margin="0,0,0,4" />

            <!-- Existing note display -->
            <TextBlock Text="{Binding NoteText}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       FontSize="13" TextWrapping="Wrap"
                       Margin="0,0,0,4"
                       Visibility="{Binding IsNotEditingNote, Converter={StaticResource BoolToVis}}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasExistingNote}" Value="False">
                                <Setter Property="Text" Value="{Binding NoNoteLabel}" />
                                <Setter Property="Opacity" Value="0.45" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Note edit box -->
            <TextBox Text="{Binding NoteEditBuffer, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource MultilineInputStyle}"
                     Height="60" MaxLength="500"
                     Margin="0,0,0,4"
                     x:Name="NoteBox"
                     AcceptsReturn="True" TextWrapping="Wrap"
                     Visibility="{Binding IsEditingNote, Converter={StaticResource BoolToVis}}" />

            <!-- Note action buttons -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <Button Content="{Binding NoteEditButtonLabel}"
                        Style="{StaticResource DBtnSecondary}"
                        Command="{Binding ToggleNoteEditCommand}"
                        Padding="8,4" />
                <Button Content="{Binding CancelLabel}"
                        Style="{StaticResource DBtnSecondary}"
                        Command="{Binding CancelNoteCommand}"
                        Padding="8,4" Margin="4,0,0,0"
                        Visibility="{Binding IsEditingNote, Converter={StaticResource BoolToVis}}" />
            </StackPanel>

            <Border Height="0.7"
                    Background="{DynamicResource WidgetDividerBrush}"
                    Margin="0,0,0,6" />

            <!-- ── Reminders summary ─────────────────────────────────── -->
            <TextBlock Text="{Binding RemindersLabel}" Style="{StaticResource DLabel}" Margin="0,0,0,4" />
            <TextBlock Text="{Binding NoRemindersLabel}"
                       Foreground="{DynamicResource WidgetForegroundBrush}"
                       Opacity="0.45" FontSize="13" Margin="0,0,0,6"
                       Visibility="{Binding HasReminders, Converter={StaticResource InverseBoolToVis}}" />
            <ItemsControl ItemsSource="{Binding ReminderTitles}"
                          Margin="0,0,0,6"
                          Visibility="{Binding HasReminders, Converter={StaticResource BoolToVis}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Margin="0,1">
                            <Ellipse Width="6" Height="6"
                                     Fill="{DynamicResource WidgetAccentBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="{Binding}"
                                       Foreground="{DynamicResource WidgetForegroundBrush}"
                                       FontSize="13"
                                       TextTrimming="CharacterEllipsis"
                                       MaxWidth="300" />
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ── Footer buttons ────────────────────────────────────── -->
            <Grid Margin="0,2,0,0">
                <Button Content="{Binding AddReminderLabel}"
                        Style="{StaticResource DBtn}"
                        Command="{Binding AddReminderCommand}"
                        HorizontalAlignment="Stretch" />
            </Grid>

        </StackPanel>
    </Border>
</Window>
